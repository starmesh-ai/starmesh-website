---
---
<section id="integrations" class="py-24 px-6 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-[600px] h-[400px]" style="background: radial-gradient(ellipse, rgba(99,102,241,0.06) 0%, transparent 70%);"></div>
  </div>

  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Integrations</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Connects with everything <span class="gradient-text">your team already uses</span>
      </h2>
      <p class="text-[#A1A1AA] max-w-xl mx-auto">Pull from any conversation source. Deliver to any warehouse. Zero custom pipelines.</p>
    </div>

    <!-- ── Hub & Spoke SVG Diagram ── -->
    <div class="relative rounded-2xl border border-white/[0.06] overflow-hidden mb-10" style="background: #0a0a0d;">
      <!-- dot grid -->
      <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.022) 1px, transparent 1px); background-size: 22px 22px;"></div>

      <svg viewBox="0 0 760 420" xmlns="http://www.w3.org/2000/svg" class="w-full relative">
        <defs>
          <filter id="int-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="3" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="int-center" x="-60%" y="-60%" width="220%" height="220%">
            <feGaussianBlur stdDeviation="10" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <radialGradient id="int-cg" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#6366F1" stop-opacity="0.2"/>
            <stop offset="100%" stop-color="#6366F1" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="int-left" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#6366F1" stop-opacity="0.25"/>
            <stop offset="100%" stop-color="#6366F1" stop-opacity="0.6"/>
          </linearGradient>
          <linearGradient id="int-right" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#8B5CF6" stop-opacity="0.6"/>
            <stop offset="100%" stop-color="#8B5CF6" stop-opacity="0.25"/>
          </linearGradient>
          <!-- Logo clip paths -->
          <clipPath id="i-c1"><rect x="54"  y="66"  width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c2"><rect x="24"  y="151" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c3"><rect x="24"  y="231" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c4"><rect x="54"  y="316" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c5"><rect x="206" y="28"  width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c6"><rect x="206" y="364" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c7"><rect x="596" y="66"  width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c8"><rect x="606" y="151" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c9"><rect x="606" y="241" width="28" height="28" rx="5"/></clipPath>
          <clipPath id="i-c10"><rect x="591" y="326" width="28" height="28" rx="5"/></clipPath>
        </defs>

        <!-- Center glow -->
        <circle cx="380" cy="210" r="120" fill="url(#int-cg)"/>

        <!-- ── Center node ── -->
        <circle cx="380" cy="210" r="78" fill="none" stroke="rgba(99,102,241,0.1)" stroke-width="1.5" stroke-dasharray="5 5">
          <animateTransform attributeName="transform" type="rotate" from="0 380 210" to="360 380 210" dur="25s" repeatCount="indefinite"/>
        </circle>
        <circle cx="380" cy="210" r="66" fill="none" stroke="rgba(139,92,246,0.15)" stroke-width="1" stroke-dasharray="2 7">
          <animateTransform attributeName="transform" type="rotate" from="360 380 210" to="0 380 210" dur="18s" repeatCount="indefinite"/>
        </circle>
        <circle cx="380" cy="210" r="54" fill="#111114" stroke="rgba(99,102,241,0.45)" stroke-width="1.5" filter="url(#int-center)"/>
        <text x="380" y="203" text-anchor="middle" fill="#FAFAFA" font-size="12" font-weight="700" font-family="Inter,sans-serif">Starmesh</text>
        <line x1="352" y1="210" x2="408" y2="210" stroke="rgba(99,102,241,0.3)" stroke-width="0.75"/>
        <text x="380" y="222" text-anchor="middle" fill="#818CF8" font-size="9" font-family="Inter,sans-serif">AI Engine</text>

        <!-- ── SOURCE NODES (left arc) ── -->
        <!-- Each path goes from node center to center circle edge at ~(326, 210) -->

        <!-- Zoom: top-left -->
        <path id="iz1" d="M 118,80 C 220,80 270,160 326,210" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/zoom.us?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="54" y="66" width="28" height="28" clip-path="url(#i-c1)"/><text x="113" y="85" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Zoom</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0s"><mpath href="#iz1"/></animateMotion></circle>

        <!-- Salesforce: mid-left-top -->
        <path id="iz2" d="M 88,165 C 190,165 270,185 326,210" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/salesforce.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="24" y="151" width="28" height="28" clip-path="url(#i-c2)"/><text x="93" y="170" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Salesforce</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.5s"><mpath href="#iz2"/></animateMotion></circle>

        <!-- Teams: mid-left -->
        <path id="iz3" d="M 88,245 C 190,245 270,230 326,210" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/microsoft.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="24" y="231" width="28" height="28" clip-path="url(#i-c3)"/><text x="83" y="250" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Teams</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1s"><mpath href="#iz3"/></animateMotion></circle>

        <!-- Gmail: mid-left-bottom -->
        <path id="iz4" d="M 118,330 C 220,330 270,260 326,210" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/gmail.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="54" y="316" width="28" height="28" clip-path="url(#i-c4)"/><text x="113" y="335" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Gmail</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.5s"><mpath href="#iz4"/></animateMotion></circle>

        <!-- Gong: top -->
        <path id="iz5" d="M 260,42 C 305,42 340,120 380,156" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/gong.io?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="206" y="28" width="28" height="28" clip-path="url(#i-c5)"/><text x="258" y="47" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Gong</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="2s"><mpath href="#iz5"/></animateMotion></circle>

        <!-- HubSpot: bottom -->
        <path id="iz6" d="M 260,378 C 305,378 340,300 380,264" fill="none" stroke="url(#int-left)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/hubspot.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="206" y="364" width="28" height="28" clip-path="url(#i-c6)"/><text x="258" y="383" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">HubSpot</text></g>
        <circle r="3" fill="#6366F1" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.8s"><mpath href="#iz6"/></animateMotion></circle>

        <!-- ── DESTINATION NODES (right arc) ── -->

        <!-- BigQuery: top-right -->
        <path id="od1" d="M 434,210 C 500,210 540,120 630,80" fill="none" stroke="url(#int-right)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/cloud.google.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="596" y="66" width="28" height="28" clip-path="url(#i-c7)"/><text x="656" y="85" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">BigQuery</text></g>
        <circle r="3" fill="#8B5CF6" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.3s"><mpath href="#od1"/></animateMotion></circle>

        <!-- Snowflake: mid-right-top -->
        <path id="od2" d="M 434,210 C 510,210 560,175 642,165" fill="none" stroke="url(#int-right)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/snowflake.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="606" y="151" width="28" height="28" clip-path="url(#i-c8)"/><text x="666" y="170" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Snowflake</text></g>
        <circle r="3" fill="#8B5CF6" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="0.9s"><mpath href="#od2"/></animateMotion></circle>

        <!-- Databricks: mid-right-bottom -->
        <path id="od3" d="M 434,210 C 510,210 560,245 642,255" fill="none" stroke="url(#int-right)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/databricks.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="606" y="241" width="28" height="28" clip-path="url(#i-c9)"/><text x="666" y="260" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">Databricks</text></g>
        <circle r="3" fill="#8B5CF6" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="1.5s"><mpath href="#od3"/></animateMotion></circle>

        <!-- GCS: bottom-right -->
        <path id="od4" d="M 434,210 C 500,210 540,300 630,340" fill="none" stroke="url(#int-right)" stroke-width="1" stroke-dasharray="4 5"/>
        <g><image href="https://img.logo.dev/cloud.google.com?token=pk_DJKjA6gBT_2eZzZT6CXz-w&size=48" x="591" y="326" width="28" height="28" clip-path="url(#i-c10)"/><text x="647" y="345" text-anchor="middle" fill="#D4D4D8" font-size="11" font-family="Inter,sans-serif">GCS</text></g>
        <circle r="3" fill="#8B5CF6" filter="url(#int-glow)"><animateMotion dur="2.6s" repeatCount="indefinite" begin="2.1s"><mpath href="#od4"/></animateMotion></circle>

        <!-- Labels -->
        <text x="88"  y="405" text-anchor="middle" fill="#71717A" font-size="9" font-family="Inter,sans-serif" font-weight="500" letter-spacing="0.5">SOURCES</text>
        <text x="380" y="405" text-anchor="middle" fill="#71717A" font-size="9" font-family="Inter,sans-serif" font-weight="500" letter-spacing="0.5">AI PROCESSING</text>
        <text x="660" y="405" text-anchor="middle" fill="#71717A" font-size="9" font-family="Inter,sans-serif" font-weight="500" letter-spacing="0.5">WAREHOUSES</text>
      </svg>
    </div>

    <div class="text-center">
      <a href="/integrations" class="btn-ghost text-sm">View all integrations →</a>
    </div>
  </div>
</section>
