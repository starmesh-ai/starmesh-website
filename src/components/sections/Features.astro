---
import WinProbabilityWindow from '../WinProbabilityWindow.astro';
import DealIntelligenceWindow from '../DealIntelligenceWindow.astro';
import InteractionTimelineWindow from '../InteractionTimelineWindow.astro';
import CRMSyncWindow from '../CRMSyncWindow.astro';
---
<section id="features" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Everything your team needs, <span class="gradient-text">nothing they won't use</span></h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">A ready-to-use UI on top of your warehouse — or pipe signals directly into your existing BI stack. Your choice.</p>
    </div>

    <!-- AI Outcomes: 2-per-row -->
    <div class="mb-28">
      <div class="mb-12"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-16 items-start">

        <!-- Deal Forecast — quarterly pipeline forecast from calls -->
        <div class="flex flex-col">
          <div class="min-h-[7.5rem]">
            <div class="flex items-center gap-2.5 mb-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
              <h3 class="font-semibold text-[#FAFAFA]">Deal Forecast</h3>
              <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Quarterly pipeline from your calls</span>
            </div>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Quarter forecast: target vs manual vs AI. See which deals are at risk — all driven by what's actually said in calls, not just stage.</p>
          </div>
          <WinProbabilityWindow
            title="Deal Forecast"
            variant="deal"
            compact
          />
        </div>

        <!-- Risk Alerts — same design system as Deal Forecast, intuitive at a glance -->
        <div class="flex flex-col">
          <div class="min-h-[7.5rem]">
            <div class="flex items-center gap-2.5 mb-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F87171" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
              <h3 class="font-semibold text-[#FAFAFA]">Risk Alerts</h3>
              <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Early warning from your calls</span>
            </div>
            <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Catch at-risk deals before they slip. Signals from every conversation — champion went quiet, pricing pushback, no next step — so you know who needs attention and why.</p>
          </div>
          <WinProbabilityWindow
            title="Risk Alerts"
            variant="risk"
            compact
          />
        </div>

        <!-- Deal Health -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Deal Health</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Deal-level health score</span>
          </div>
          <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">A live composite score of momentum, stakeholder engagement, MAP quality, and competitive exposure.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Deal Health</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Deals</p></div>
                {[
                  {deal:"D-2847",name:"Acme Corp", score:74,sc:"text-green-400", active:true },
                  {deal:"D-3104",name:"FinCo Ltd", score:88,sc:"text-green-400", active:false},
                  {deal:"D-2901",name:"Meridian",  score:34,sc:"text-red-400",   active:false},
                  {deal:"D-3198",name:"Brightwave",score:62,sc:"text-yellow-400",active:false},
                ].map(d=>(
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] flex items-center justify-between gap-1 ${d.active?'bg-green-500/[0.06] border-l-2 border-l-green-500/50':''}`}>
                    <div class="min-w-0 flex-1">
                      <p class={`text-[11px] truncate ${d.active?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{d.name}</p>
                      <p class="text-[10px] font-mono text-[#52525B]">{d.deal}</p>
                    </div>
                    <span class={`text-[10px] font-mono font-bold flex-shrink-0 ${d.sc}`}>{d.score}</span>
                  </div>
                ))}
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.05] flex-shrink-0" style="background:rgba(255,255,255,0.01);">
                  <span class="text-[12px] font-semibold text-[#FAFAFA]">Acme Corp</span>
                  <div class="flex items-center gap-1.5">
                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-green-500/10 border border-green-500/20 text-green-400 font-medium">Good</span>
                    <span class="text-[10px] text-green-400">↑ +3 this week</span>
                  </div>
                </div>
                <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.05] flex-shrink-0">
                  <div>
                    <p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold mb-0.5">Health score</p>
                    <div class="flex items-baseline gap-1"><span class="text-4xl font-bold text-green-400">74</span><span class="text-sm text-[#52525B]"> out of 100</span></div>
                  </div>
                  <svg viewBox="0 0 44 44" class="w-12 h-12 -rotate-90">
                    <circle cx="22" cy="22" r="17" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="4"/>
                    <circle cx="22" cy="22" r="17" fill="none" stroke="#4ade80" stroke-width="4" stroke-opacity="0.65" stroke-dasharray={`${74*106.8/100} 106.8`} stroke-linecap="round"/>
                  </svg>
                </div>
                <div class="flex-1 px-4 py-3 space-y-2 overflow-hidden">
                  {[
                    {label:"Momentum",    pct:78,color:"bg-green-500", delta:"+6%",dc:"text-green-400"},
                    {label:"Stakeholders",pct:55,color:"bg-yellow-500",delta:"—",  dc:"text-[#52525B]"},
                    {label:"MAP quality", pct:82,color:"bg-green-500", delta:"+4%",dc:"text-green-400"},
                    {label:"Competitive", pct:61,color:"bg-yellow-500",delta:"−2%",dc:"text-red-400"},
                    {label:"Sentiment",   pct:68,color:"bg-green-500", delta:"+3%",dc:"text-green-400"},
                  ].map(r=>(
                    <div class="flex items-center gap-2">
                      <span class="text-[10px] text-[#A1A1AA] w-20 flex-shrink-0">{r.label}</span>
                      <div class="flex-1 h-1.5 rounded-full bg-white/[0.06]"><div class={`h-1.5 rounded-full ${r.color} opacity-60`} style={`width:${r.pct}%`}></div></div>
                      <span class="text-[10px] font-mono text-[#A1A1AA] w-5 text-right flex-shrink-0">{r.pct}%</span>
                      <span class={`text-[10px] w-6 text-right flex-shrink-0 font-medium ${r.dc}`}>{r.delta}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Rep Performance — every number labeled so users don't have to think -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Rep Performance</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Conversation quality from calls</span>
          </div>
          <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Benchmark each rep on objection handling, next-step hygiene, talk ratio, and buyer engagement across their entire book.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Rep Performance</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Period</p></div>
                {["Q4 2024","Q1 2025","Q2 2025"].map((q,i)=>(
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] ${i===1?'bg-blue-500/10 border-l-2 border-l-blue-500/60':''}`}>
                    <p class={`text-[11px] ${i===1?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{q}</p>
                  </div>
                ))}
                <div class="px-3 pt-3 mt-auto border-t border-white/[0.04]">
                  <p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold mb-0.5">Team score (avg)</p>
                  <p class="text-xl font-bold text-blue-400">76</p>
                  <p class="text-[9px] text-[#3F3F46]">out of 100</p>
                </div>
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05] flex-shrink-0">
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-[#FAFAFA]">4</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Reps in team</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-blue-400">76</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Avg score out of 100</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-green-400">92</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Top score out of 100</p></div>
                </div>
                <div class="flex-1 flex flex-col overflow-hidden">
                  <div class="grid grid-cols-[1fr_auto_auto_auto] gap-2 px-3 py-1.5 border-b border-white/[0.04] flex-shrink-0 bg-white/[0.02]">
                    <span class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Rep</span>
                    <span class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold w-14 text-right">Quality score</span>
                    <span class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold w-5 text-center" title="Objection handling grade">Obj</span>
                    <span class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold w-5 text-center" title="Next-step hygiene grade">Steps</span>
                  </div>
                  <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
                    {[
                      {rank:"1",ini:"SK",name:"Sarah K.", score:92,obj:"A",steps:"A",sc:"text-green-400", ac:"bg-green-500/15 border-green-500/25"},
                      {rank:"2",ini:"JM",name:"Jordan M.",score:81,obj:"B",steps:"A",sc:"text-blue-400",  ac:"bg-blue-500/15 border-blue-500/25"},
                      {rank:"3",ini:"MT",name:"Mike T.",  score:74,obj:"B",steps:"C",sc:"text-yellow-400",ac:"bg-yellow-500/15 border-yellow-500/25"},
                      {rank:"4",ini:"AR",name:"Aiden R.", score:58,obj:"C",steps:"D",sc:"text-orange-400",ac:"bg-orange-500/15 border-orange-500/25"},
                    ].map(r=>(
                      <div class="flex items-center px-3 py-2 gap-2">
                        <span class="text-[10px] text-[#52525B] w-3 flex-shrink-0">{r.rank}</span>
                        <div class={`w-6 h-6 rounded-full border flex items-center justify-center flex-shrink-0 ${r.ac}`}><span class={`text-[10px] font-bold ${r.sc}`}>{r.ini}</span></div>
                        <span class="text-[12px] font-medium text-[#E4E4E7] flex-1 min-w-0 truncate">{r.name}</span>
                        <div class="flex items-center gap-1.5 flex-shrink-0 w-14 justify-end">
                          <div class="w-10 h-1.5 rounded-full bg-white/[0.06]"><div class={`h-1.5 rounded-full opacity-70 ${r.score>=80?'bg-green-500':r.score>=65?'bg-blue-500':r.score>=55?'bg-yellow-500':'bg-orange-500'}`} style={`width:${r.score}%`}></div></div>
                          <span class={`text-[11px] font-bold font-mono w-5 text-right ${r.sc}`} title="Conversation quality score out of 100">{r.score}</span>
                        </div>
                        <span class={`text-[10px] w-5 h-5 rounded flex items-center justify-center font-bold flex-shrink-0 ${r.obj==='A'?'bg-green-500/15 text-green-400':r.obj==='B'?'bg-blue-500/15 text-blue-400':r.obj==='C'?'bg-yellow-500/15 text-yellow-400':'bg-red-500/15 text-red-400'}`} title="Objection handling">{r.obj}</span>
                        <span class={`text-[10px] w-5 h-5 rounded flex items-center justify-center font-bold flex-shrink-0 ${r.steps==='A'?'bg-green-500/15 text-green-400':r.steps==='B'?'bg-blue-500/15 text-blue-400':r.steps==='C'?'bg-yellow-500/15 text-yellow-400':'bg-red-500/15 text-red-400'}`} title="Next-step hygiene">{r.steps}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>


    <!-- Core Platform Features: full-width feature rows -->
    <div class="mb-24">
      <div class="mb-16"></div>
      <div class="flex flex-col gap-28">

        <!-- 1. Deal Intelligence Chat -->
        <div class="flex flex-col lg:flex-row items-start gap-12">
          <!-- Left: description -->
          <div class="lg:w-[38%] flex-shrink-0 lg:pt-6">
            <div class="flex items-center gap-2.5 mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span class="text-xs text-[#818CF8] uppercase tracking-widest font-bold">Deal Intelligence Chat</span>
            </div>
            <h3 class="text-2xl font-bold text-[#FAFAFA] tracking-tight mb-4 leading-snug">Ask anything.<br/>Get answers from your actual calls.</h3>
            <p class="text-[#71717A] leading-relaxed mb-8">Every question you ask is answered from real call transcripts and emails — not summaries or gut feel. Every response links back to the exact source.</p>
            <ul class="space-y-3.5">
              {[
                "Natural language queries across all deals and reps",
                "Answers grounded in transcripts, emails, and CRM data",
                "Source citations with date, tool, and deal context",
                "Context-aware — knows stage, stakeholders, and history",
              ].map(b => (
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span class="text-sm text-[#A1A1AA]">{b}</span>
                </li>
              ))}
            </ul>
          </div>
          <!-- Right: Deal Copilot window (same as overview) -->
          <div class="flex-1 min-w-0">
            <DealIntelligenceWindow
              title="Deal Copilot"
              contextSummary="Stage: Negotiation · Risk: At risk · Deal value: $120K · Expected close: Mar 15"
              firstUserText="Tell me about this deal."
              firstAiText="Acme Corp is in Negotiation with legal and security in the loop. Champion is strong but there's a security objection and VP Eng just joined the committee. Next steps are still blank in Salesforce; close the blocker this week or it slips to Q1."
              userText="What do I need to do before Friday?"
              aiText="Send SOC2 docs to Sarah today. Get your SE on the security call — that's the only real blocker. Log next steps in Salesforce before EOD or this slips to Q1."
              nextQuestion="Who are the key stakeholders on the buying committee?"
            />
          </div>
        </div>

        <!-- 2. Interaction Timeline -->
        <div class="flex flex-col lg:flex-row-reverse items-start gap-16 lg:gap-20">
          <div class="lg:w-[38%] flex-shrink-0 lg:pt-6 lg:pl-10">
            <div class="flex items-center gap-2.5 mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2dd4bf" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v6h4m6-2a10 10 0 1 1-20 0 10 10 0 0 1 20 0Z"/></svg>
              <span class="text-xs text-[#2dd4bf] uppercase tracking-widest font-bold">Interaction Timeline</span>
            </div>
            <h3 class="text-2xl font-bold text-[#FAFAFA] tracking-tight mb-4 leading-snug">Every touchpoint.<br/>Every signal. One view.</h3>
            <p class="text-[#71717A] leading-relaxed mb-8">Every call, email, and meeting for every deal in one chronological view — with AI signals attached so nothing gets buried or missed.</p>
            <ul class="space-y-3.5">
              {[
                "Full interaction history from first touch to close",
                "AI risk and momentum signals on every event",
                "Filter by call, email, or CRM activity",
                "Pinpoint exactly when a deal shifted and why",
              ].map(b=>(
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-teal-400 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <span class="text-sm text-[#A1A1AA]">{b}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex-1 min-w-0 lg:pt-6">
            <InteractionTimelineWindow
              title="Deal Timeline"
              events={[
                { d: 'Mar 4', t: 'No contact for 7 days after security review' },
                { d: 'Feb 24', t: 'Security objection raised on Zoom call' },
                { d: 'Feb 10', t: 'VP Eng joined buying committee · asks about data residency and SOC2' },
                { d: 'Jan 28', t: 'Stage → Commit · next steps still blank in Salesforce' },
              ]}
            />
          </div>
        </div>

        <!-- 3. CRM Write-back -->
        <div class="flex flex-col lg:flex-row items-start gap-12">
          <div class="lg:w-[38%] flex-shrink-0 lg:pt-6">
            <div class="flex items-center gap-2.5 mb-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c084fc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.990"/></svg>
              <span class="text-xs text-[#c084fc] uppercase tracking-widest font-bold">CRM Write-back</span>
            </div>
            <h3 class="text-2xl font-bold text-[#FAFAFA] tracking-tight mb-4 leading-snug">Your CRM stays current.<br/>Without anyone touching it.</h3>
            <p class="text-[#71717A] leading-relaxed mb-8">PWin scores, EWI flags, and deal health signals automatically sync back to the right Salesforce or HubSpot fields after every call — zero manual entry.</p>
            <ul class="space-y-3.5">
              {[
                "Auto-populates fields in Salesforce & HubSpot after every call",
                "PWin, competitor mentions, risk flags, and next steps — all synced",
                "Audit trail of every field write with timestamp and source",
                "No workflow rules, triggers, or manual updates required",
              ].map(b=>(
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-violet-400 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
