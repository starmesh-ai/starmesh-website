---
---
<section id="features" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Capabilities</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Built for RevOps and data teams</h2>
      <p class="text-[#A1A1AA] text-lg">Everything you need to turn sales conversations into structured deal intelligence — in your warehouse.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- 1. Multi-source ingestion -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">Multi-source ingestion</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Connect Zoom, Teams, Gong, Gmail, Salesforce, HubSpot. One pipeline for all your conversation data.</p>
        <!-- Mini visual: source flow -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04]">
          <div class="flex items-center justify-between gap-1">
            <div class="flex flex-col gap-1.5">
              {["Zoom", "Teams", "Gmail"].map(s => <span class="px-2 py-0.5 rounded text-[9px] bg-indigo-500/10 text-indigo-400 border border-indigo-500/15 font-medium">{s}</span>)}
            </div>
            <svg width="20" height="30" viewBox="0 0 20 30"><path d="M2 5 L18 15 L2 25" fill="none" stroke="rgba(99,102,241,0.4)" stroke-width="1.5" stroke-linecap="round"/></svg>
            <div class="w-16 h-12 rounded-lg flex items-center justify-center border border-indigo-500/20 bg-indigo-500/5">
              <span class="text-[9px] text-indigo-400 font-semibold text-center leading-tight">Starmesh</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Deal Win Probability -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">Deal win probability</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Score the likelihood of every open deal closing — trained on pricing pressure, objection quality, buyer engagement, and CRM signals.</p>
        <!-- Mini visual: pwin scores -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04] space-y-2">
          {[
            { deal: "D-2847", pwin: 0.74, w: "74%" },
            { deal: "D-1920", pwin: 0.88, w: "88%" },
            { deal: "D-3012", pwin: 0.41, w: "41%" },
          ].map(r => (
            <div class="flex items-center gap-2">
              <span class="text-[9px] text-[#A1A1AA] font-mono w-10 flex-shrink-0">{r.deal}</span>
              <div class="flex-1 h-1.5 rounded-full bg-white/[0.05]">
                <div class={`h-1.5 rounded-full ${r.pwin >= 0.6 ? 'bg-green-500' : 'bg-red-500'}`} style={`width: ${r.w}; opacity: 0.7;`}></div>
              </div>
              <span class={`text-[9px] font-semibold w-6 text-right ${r.pwin >= 0.6 ? 'text-green-400' : 'text-red-400'}`}>{r.pwin}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Deal Risk Detection -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.068.157 2.148.279 3.238.364.466.037.893.281 1.153.671L12 21l2.652-3.978c.26-.39.687-.634 1.153-.67 1.09-.086 2.17-.208 3.238-.365 1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">Deal risk detection</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Detect slip risk, pricing pressure, and competitive threats from every conversation before they sink a deal.</p>
        <!-- Mini visual: risk signals -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04] space-y-2">
          {[
            { label: "slip_risk",       val: "elevated", color: "text-orange-400", bg: "bg-orange-500/10 border-orange-500/15" },
            { label: "pricing_pres.",   val: "moderate",  color: "text-yellow-400", bg: "bg-yellow-500/10 border-yellow-500/15" },
            { label: "competitor",      val: "Gong · 3×", color: "text-red-400",    bg: "bg-red-500/10 border-red-500/15" },
          ].map(r => (
            <div class="flex items-center justify-between">
              <span class="text-[9px] text-[#A1A1AA] font-mono">{r.label}</span>
              <span class={`px-1.5 py-0.5 rounded text-[9px] font-semibold border ${r.bg} ${r.color}`}>{r.val}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 4. Entity Extraction -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">Entity extraction</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Identify people, companies, and products mentioned in every conversation and link them back to CRM.</p>
        <!-- Mini visual: knowledge graph nodes -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04]">
          <svg viewBox="0 0 180 70" class="w-full">
            <circle cx="30"  cy="35" r="18" fill="rgba(99,102,241,0.08)" stroke="rgba(99,102,241,0.3)" stroke-width="1"/>
            <text x="30"  y="32" text-anchor="middle" fill="#818CF8" font-size="7" font-family="Inter,sans-serif">Person</text>
            <text x="30"  y="41" text-anchor="middle" fill="#D4D4D8" font-size="7.5" font-weight="600" font-family="Inter,sans-serif">J. Smith</text>
            <circle cx="90"  cy="20" r="15" fill="rgba(139,92,246,0.08)" stroke="rgba(139,92,246,0.3)" stroke-width="1"/>
            <text x="90"  y="17" text-anchor="middle" fill="#A78BFA" font-size="6.5" font-family="Inter,sans-serif">Company</text>
            <text x="90"  y="26" text-anchor="middle" fill="#D4D4D8" font-size="7" font-weight="600" font-family="Inter,sans-serif">Acme Corp</text>
            <circle cx="90"  cy="55" r="12" fill="rgba(59,130,246,0.08)" stroke="rgba(59,130,246,0.3)" stroke-width="1"/>
            <text x="90"  y="52" text-anchor="middle" fill="#60A5FA" font-size="6" font-family="Inter,sans-serif">Product</text>
            <text x="90"  y="60" text-anchor="middle" fill="#D4D4D8" font-size="7" font-weight="600" font-family="Inter,sans-serif">API Pro</text>
            <circle cx="152" cy="35" r="14" fill="rgba(16,185,129,0.08)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
            <text x="152" y="32" text-anchor="middle" fill="#34D399" font-size="6.5" font-family="Inter,sans-serif">Deal</text>
            <text x="152" y="41" text-anchor="middle" fill="#D4D4D8" font-size="7" font-weight="600" font-family="Inter,sans-serif">D-2847</text>
            <line x1="48" y1="28" x2="75" y2="22" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <line x1="48" y1="40" x2="78" y2="52" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <line x1="105" y1="22" x2="138" y2="30" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
            <line x1="105" y1="55" x2="138" y2="42" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
          </svg>
        </div>
      </div>

      <!-- 5. CRM Deal Linking -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">CRM deal linking</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Every analysis is automatically tied back to the right opportunity in Salesforce or HubSpot.</p>
        <!-- Mini visual: linked records -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04] space-y-2">
          {[
            { call: "Zoom · Mar 3", deal: "D-2847 · $120k", icon: "↗" },
            { call: "Teams · Mar 2", deal: "D-2901 · $84k",  icon: "↗" },
            { call: "Gmail · Mar 1", deal: "D-1920 · $200k", icon: "↗" },
          ].map(row => (
            <div class="flex items-center justify-between text-[10px]">
              <span class="text-[#A1A1AA]">{row.call}</span>
              <svg width="16" height="8" viewBox="0 0 16 8"><path d="M0 4 H14 M10 1 L14 4 L10 7" stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-linecap="round" fill="none"/></svg>
              <span class="text-indigo-400 font-medium">{row.deal} {row.icon}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 6. Warehouse Delivery -->
      <div class="card p-6 group cursor-default">
        <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-1.5">Warehouse-native delivery</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-4">Results land as structured tables in BigQuery or Snowflake. No new tools. Query with SQL you already know.</p>
        <!-- Mini visual: SQL snippet -->
        <div class="rounded-lg p-3 bg-[#0d0d10] border border-white/[0.04] font-mono text-[9px]">
          <p class="text-[#52525B] mb-1">-- starmesh.deal_intelligence</p>
          <p><span class="text-violet-400">SELECT</span> deal_id, pwin_score, slip_risk</p>
          <p><span class="text-violet-400">FROM</span> <span class="text-indigo-400">deal_intelligence</span></p>
          <p><span class="text-violet-400">WHERE</span> slip_risk = <span class="text-green-400">'elevated'</span></p>
          <p><span class="text-violet-400">ORDER BY</span> pwin_score <span class="text-violet-400">DESC</span></p>
        </div>
      </div>

    </div>
  </div>
</section>
