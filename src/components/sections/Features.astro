---
---
<section id="benefits" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Platform</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Everything your team needs, nothing they won't use</h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">A ready-to-use UI on top of your warehouse — or pipe signals directly into your existing BI stack. Your choice.</p>
    </div>

    <!-- AI Outcomes: 2-per-row -->
    <div class="mb-28">
      <p class="text-xs text-[#52525B] uppercase tracking-widest font-semibold mb-12">Outcomes</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-16">

        <!-- PWin -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">PWin</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Predicted Win Probability</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">AI-scored deal win probability driven by what's actually said — not just stage or activity.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Pipeline Intelligence</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Quarter</p></div>
                {["Q1 2025","Q2 2025","Q3 2025","Q4 2025"].map((q,i) => (
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] ${i===1?'bg-indigo-500/10 border-l-2 border-l-indigo-500/70':''}`}>
                    <p class={`text-[11px] ${i===1?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{q}</p>
                  </div>
                ))}
                <div class="px-3 pt-3 mt-auto border-t border-white/[0.04]">
                  <p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold mb-2">Filter</p>
                  {[{l:"All",active:true},{l:"At risk",active:false},{l:"Healthy",active:false}].map(f=>(
                    <p class={`text-[11px] py-0.5 ${f.active?'text-[#A1A1AA] font-semibold':'text-[#3F3F46]'}`}>{f.l}</p>
                  ))}
                </div>
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05] flex-shrink-0">
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-[#FAFAFA]">18</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Active</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-indigo-400">0.67</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Avg PWin</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-red-400">3</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">At risk</p></div>
                </div>
                <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
                  {[
                    {name:"Acme Corp",  stage:"Negotiation",pwin:74,risk:"medium"},
                    {name:"FinCo Ltd",  stage:"Closing",    pwin:88,risk:"low"   },
                    {name:"Meridian",   stage:"Discovery",  pwin:41,risk:"high"  },
                    {name:"Brightwave", stage:"Demo",       pwin:79,risk:"low"   },
                  ].map(r=>(
                    <div class="flex items-center px-3 py-2.5 gap-2">
                      <div class="flex-1 min-w-0"><p class="text-[12px] font-medium text-[#E4E4E7] truncate">{r.name}</p><p class="text-[10px] text-[#52525B]">{r.stage}</p></div>
                      <div class="flex items-center gap-1.5 flex-shrink-0">
                        <div class="w-12 h-1.5 rounded-full bg-white/[0.06]"><div class={`h-1.5 rounded-full ${r.pwin>=60?'bg-indigo-500':'bg-red-500'} opacity-70`} style={`width:${r.pwin}%`}></div></div>
                        <span class={`text-[11px] font-mono font-bold w-6 text-right ${r.pwin>=60?'text-indigo-400':'text-red-400'}`}>{r.pwin}%</span>
                      </div>
                      <span class={`text-[10px] px-1.5 py-0.5 rounded border font-medium w-12 text-center flex-shrink-0 ${r.risk==='high'?'text-red-400 bg-red-500/10 border-red-500/20':r.risk==='medium'?'text-yellow-400 bg-yellow-500/10 border-yellow-500/20':'text-green-400 bg-green-500/10 border-green-500/20'}`}>{r.risk}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- EWI -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F87171" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">EWI</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Early Warning Indicator</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">Catch at-risk deals weeks before they miss forecast using leading signals from every conversation.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Risk Alerts</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Severity</p></div>
                {[
                  {l:"All flagged",n:"4",tc:"text-[#A1A1AA]",active:true },
                  {l:"High",       n:"2",tc:"text-red-400",  active:false},
                  {l:"Medium",     n:"1",tc:"text-orange-400",active:false},
                  {l:"Low",        n:"1",tc:"text-yellow-400",active:false},
                ].map(f=>(
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] flex items-center justify-between ${f.active?'bg-red-500/[0.06] border-l-2 border-l-red-500/60':''}`}>
                    <p class={`text-[11px] ${f.active?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{f.l}</p>
                    <span class={`text-[10px] font-mono font-bold ${f.tc}`}>{f.n}</span>
                  </div>
                ))}
                <div class="px-3 py-2 mt-auto border-t border-white/[0.04] flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse flex-shrink-0"></span>
                  <p class="text-[10px] text-red-400 font-semibold">Live</p>
                </div>
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="flex items-center justify-between px-3 py-1.5 border-b border-white/[0.05] flex-shrink-0" style="background:rgba(255,255,255,0.01);">
                  <span class="text-[11px] text-[#A1A1AA] font-medium">Active alerts</span>
                  <span class="text-[10px] text-red-400 bg-red-500/10 border border-red-500/20 px-1.5 py-0.5 rounded-full font-semibold">4 flagged</span>
                </div>
                <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
                  {[
                    {deal:"D-2847",name:"Acme Corp", signals:["Momentum drop","Champion silent"], severity:"high",  time:"2h ago"},
                    {deal:"D-3104",name:"FinCo Ltd", signals:["Pricing pressure","No next step"], severity:"high",  time:"5h ago"},
                    {deal:"D-2901",name:"Meridian",  signals:["Competitor raised","Legal stalled"],severity:"medium",time:"1d ago"},
                    {deal:"D-3198",name:"Brightwave",signals:["Budget concern raised"],            severity:"low",   time:"2d ago"},
                  ].map(r=>(
                    <div class="px-3 py-2.5">
                      <div class="flex items-center justify-between mb-1.5">
                        <div class="flex items-center gap-1.5">
                          <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${r.severity==='high'?'bg-red-400':r.severity==='medium'?'bg-orange-400':'bg-yellow-400'}`}></span>
                          <span class="text-[12px] font-semibold text-[#FAFAFA]">{r.name}</span>
                          <span class="text-[10px] font-mono text-indigo-400/60">{r.deal}</span>
                        </div>
                        <span class="text-[10px] text-[#52525B]">{r.time}</span>
                      </div>
                      <div class="flex gap-1 flex-wrap pl-3">
                        {r.signals.map(s=>(<span class="text-[10px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.06] text-[#A1A1AA]">{s}</span>))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Deal Health -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Deal Health</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Deal-level health score</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">A live composite score of momentum, stakeholder engagement, MAP quality, and competitive exposure.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Deal Health</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Deals</p></div>
                {[
                  {name:"Acme Corp", score:71,sc:"text-green-400", active:true },
                  {name:"FinCo Ltd", score:88,sc:"text-green-400", active:false},
                  {name:"Meridian",  score:34,sc:"text-red-400",   active:false},
                  {name:"Brightwave",score:62,sc:"text-yellow-400",active:false},
                ].map(d=>(
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] flex items-center justify-between gap-1 ${d.active?'bg-green-500/[0.06] border-l-2 border-l-green-500/50':''}`}>
                    <p class={`text-[11px] truncate ${d.active?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{d.name}</p>
                    <span class={`text-[10px] font-mono font-bold flex-shrink-0 ${d.sc}`}>{d.score}</span>
                  </div>
                ))}
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.05] flex-shrink-0" style="background:rgba(255,255,255,0.01);">
                  <span class="text-[12px] font-semibold text-[#FAFAFA]">Acme Corp</span>
                  <div class="flex items-center gap-1.5">
                    <span class="text-[10px] px-1.5 py-0.5 rounded bg-green-500/10 border border-green-500/20 text-green-400 font-medium">Good</span>
                    <span class="text-[10px] text-green-400">↑ +3 this week</span>
                  </div>
                </div>
                <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.05] flex-shrink-0">
                  <div class="flex items-baseline gap-1"><span class="text-4xl font-bold text-green-400">71</span><span class="text-sm text-[#52525B]">/100</span></div>
                  <svg viewBox="0 0 44 44" class="w-12 h-12 -rotate-90">
                    <circle cx="22" cy="22" r="17" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="4"/>
                    <circle cx="22" cy="22" r="17" fill="none" stroke="#4ade80" stroke-width="4" stroke-opacity="0.65" stroke-dasharray={`${71*106.8/100} 106.8`} stroke-linecap="round"/>
                  </svg>
                </div>
                <div class="flex-1 px-4 py-3 space-y-2 overflow-hidden">
                  {[
                    {label:"Momentum",    pct:78,color:"bg-green-500", delta:"+6%",dc:"text-green-400"},
                    {label:"Stakeholders",pct:55,color:"bg-yellow-500",delta:"—",  dc:"text-[#52525B]"},
                    {label:"MAP quality", pct:82,color:"bg-green-500", delta:"+4%",dc:"text-green-400"},
                    {label:"Competitive", pct:61,color:"bg-yellow-500",delta:"−2%",dc:"text-red-400"},
                    {label:"Sentiment",   pct:68,color:"bg-green-500", delta:"+3%",dc:"text-green-400"},
                  ].map(r=>(
                    <div class="flex items-center gap-2">
                      <span class="text-[10px] text-[#A1A1AA] w-20 flex-shrink-0">{r.label}</span>
                      <div class="flex-1 h-1.5 rounded-full bg-white/[0.06]"><div class={`h-1.5 rounded-full ${r.color} opacity-60`} style={`width:${r.pct}%`}></div></div>
                      <span class="text-[10px] font-mono text-[#A1A1AA] w-5 text-right flex-shrink-0">{r.pct}%</span>
                      <span class={`text-[10px] w-6 text-right flex-shrink-0 font-medium ${r.dc}`}>{r.delta}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Rep Performance -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Rep Performance</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Conversation quality insights</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">Benchmark each rep on objection handling, next-step hygiene, talk ratio, and buyer engagement across their entire book.</p>
          <div class="rounded-xl overflow-hidden" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 8px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.03);">
            <div class="flex items-center px-4 py-2.5 border-b border-white/[0.06]" style="background:#111118;">
              <div class="flex gap-1.5 flex-shrink-0">
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F56;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#FFBD2E;"></span>
                <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F;"></span>
              </div>
              <span class="text-[11px] text-[#71717A] flex-1 text-center font-medium">Starmesh · Rep Performance</span>
              <div style="width:52px;" class="flex-shrink-0"></div>
            </div>
            <div class="flex" style="height:272px;">
              <div class="flex flex-col flex-shrink-0" style="width:110px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
                <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Period</p></div>
                {["Q4 2024","Q1 2025","Q2 2025"].map((q,i)=>(
                  <div class={`px-3 py-2.5 border-b border-white/[0.03] ${i===1?'bg-blue-500/10 border-l-2 border-l-blue-500/60':''}`}>
                    <p class={`text-[11px] ${i===1?'text-[#E4E4E7] font-semibold':'text-[#52525B]'}`}>{q}</p>
                  </div>
                ))}
                <div class="px-3 pt-3 mt-auto border-t border-white/[0.04]">
                  <p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold mb-1.5">Team avg</p>
                  <p class="text-xl font-bold text-blue-400">76</p>
                  <p class="text-[9px] text-[#3F3F46]">out of 100</p>
                </div>
              </div>
              <div class="flex-1 flex flex-col overflow-hidden">
                <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05] flex-shrink-0">
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-[#FAFAFA]">4</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Reps</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-blue-400">76</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Avg</p></div>
                  <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-green-400">92</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Top</p></div>
                </div>
                <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
                  {[
                    {rank:"1",ini:"SK",name:"Sarah K.", score:92,obj:"A",steps:"A",sc:"text-green-400", ac:"bg-green-500/15 border-green-500/25"},
                    {rank:"2",ini:"JM",name:"Jordan M.",score:81,obj:"B",steps:"A",sc:"text-blue-400",  ac:"bg-blue-500/15 border-blue-500/25"},
                    {rank:"3",ini:"MT",name:"Mike T.",  score:74,obj:"B",steps:"C",sc:"text-yellow-400",ac:"bg-yellow-500/15 border-yellow-500/25"},
                    {rank:"4",ini:"AR",name:"Aiden R.", score:58,obj:"C",steps:"D",sc:"text-orange-400",ac:"bg-orange-500/15 border-orange-500/25"},
                  ].map(r=>(
                    <div class="flex items-center px-3 py-2.5 gap-2">
                      <span class="text-[10px] text-[#52525B] w-3 flex-shrink-0">{r.rank}</span>
                      <div class={`w-6 h-6 rounded-full border flex items-center justify-center flex-shrink-0 ${r.ac}`}><span class={`text-[10px] font-bold ${r.sc}`}>{r.ini}</span></div>
                      <span class="text-[12px] font-medium text-[#E4E4E7] flex-1 min-w-0 truncate">{r.name}</span>
                      <div class="flex items-center gap-1.5 flex-shrink-0">
                        <div class="w-10 h-1.5 rounded-full bg-white/[0.06]"><div class={`h-1.5 rounded-full opacity-70 ${r.score>=80?'bg-green-500':r.score>=65?'bg-blue-500':r.score>=55?'bg-yellow-500':'bg-orange-500'}`} style={`width:${r.score}%`}></div></div>
                        <span class={`text-[11px] font-bold font-mono w-5 text-right ${r.sc}`}>{r.score}</span>
                      </div>
                      <div class="flex gap-1 flex-shrink-0">
                        {[r.obj,r.steps].map(g=>(<span class={`text-[10px] w-5 h-5 rounded flex items-center justify-center font-bold ${g==='A'?'bg-green-500/15 text-green-400':g==='B'?'bg-blue-500/15 text-blue-400':g==='C'?'bg-yellow-500/15 text-yellow-400':'bg-red-500/15 text-red-400'}`}>{g}</span>))}
                      </div>
