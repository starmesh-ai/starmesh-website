---
---
<section id="benefits" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Platform</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Everything your team needs, nothing they won't use</h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">A ready-to-use UI on top of your warehouse — or pipe signals directly into your existing BI stack. Your choice.</p>
    </div>

    <!-- AI Outcomes -->
    <div class="mb-24">
      <p class="text-xs text-[#52525B] uppercase tracking-widest font-semibold mb-12">Outcomes</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-16">

        <!-- PWin -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">PWin</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Predicted Win Probability</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">AI-scored deal win probability driven by what's actually said — not just stage or activity.</p>
          <div class="rounded-xl overflow-hidden" style="background: #0a0a0d; border: 1px solid rgba(255,255,255,0.07);">
            <!-- App header -->
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.06]">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
                <span class="text-[13px] font-medium text-[#FAFAFA]">Pipeline Intelligence</span>
              </div>
              <div class="flex items-center gap-1 text-[12px] text-[#71717A] border border-white/[0.07] rounded-md px-2 py-0.5">
                Q2 2025
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M2 3l2 2 2-2" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
              </div>
            </div>
            <!-- KPI bar -->
            <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05]">
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-[#FAFAFA]">18</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">Active deals</p>
              </div>
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-indigo-400">0.67</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">Avg PWin</p>
              </div>
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-red-400">3</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">At risk</p>
              </div>
            </div>
            <!-- Deal rows -->
            <div class="divide-y divide-white/[0.04]">
              {[
                { name: "Acme Corp",  stage: "Negotiation", pwin: 74, risk: "medium" },
                { name: "FinCo Ltd",  stage: "Closing",     pwin: 88, risk: "low" },
                { name: "Meridian",   stage: "Discovery",   pwin: 41, risk: "high" },
                { name: "Brightwave", stage: "Demo",        pwin: 79, risk: "low" },
              ].map(r => (
                <div class="flex items-center px-4 py-2.5 gap-3">
                  <div class="flex-1 min-w-0">
                    <p class="text-[13px] font-medium text-[#E4E4E7] truncate">{r.name}</p>
                    <p class="text-[11px] text-[#52525B]">{r.stage}</p>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <div class="w-14 h-1.5 rounded-full bg-white/[0.06]">
                      <div class={`h-1.5 rounded-full ${r.pwin >= 60 ? 'bg-indigo-500' : 'bg-red-500'}`} style={`width: ${r.pwin}%; opacity: 0.7`}></div>
                    </div>
                    <span class={`text-[12px] font-mono font-bold w-7 text-right flex-shrink-0 ${r.pwin >= 60 ? 'text-indigo-400' : 'text-red-400'}`}>{r.pwin}%</span>
                  </div>
                  <span class={`text-[11px] px-1.5 py-0.5 rounded-md border font-medium w-14 text-center flex-shrink-0 ${r.risk === 'high' ? 'text-red-400 bg-red-500/10 border-red-500/20' : r.risk === 'medium' ? 'text-yellow-400 bg-yellow-500/10 border-yellow-500/20' : 'text-green-400 bg-green-500/10 border-green-500/20'}`}>{r.risk}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- EWI -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#F87171" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">EWI</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Early Warning Indicator</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">Catch at-risk deals weeks before they miss forecast using leading signals from every conversation.</p>
          <div class="rounded-xl overflow-hidden" style="background: #0a0a0d; border: 1px solid rgba(255,255,255,0.07);">
            <!-- App header -->
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.06]">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
                <span class="text-[13px] font-medium text-[#FAFAFA]">Risk Alerts</span>
              </div>
              <span class="text-[12px] text-red-400 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded-full font-medium">4 flagged</span>
            </div>
            <!-- Alert items -->
            <div class="divide-y divide-white/[0.04]">
              {[
                { deal: "D-2847", name: "Acme Corp",  signals: ["Momentum drop", "Champion silent"], severity: "high",   time: "2h ago" },
                { deal: "D-3104", name: "FinCo Ltd",  signals: ["Pricing pressure", "No next step"], severity: "high",   time: "5h ago" },
                { deal: "D-2901", name: "Meridian",   signals: ["Competitor: Gong", "Legal stalled"],severity: "medium", time: "1d ago" },
                { deal: "D-3198", name: "Brightwave", signals: ["Budget concern raised"],             severity: "low",    time: "2d ago" },
              ].map(r => (
                <div class="px-4 py-3">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-2">
                      <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${r.severity === 'high' ? 'bg-red-400' : r.severity === 'medium' ? 'bg-orange-400' : 'bg-yellow-400'}`}></span>
                      <span class="text-[13px] font-semibold text-[#FAFAFA]">{r.name}</span>
                      <span class="text-[11px] font-mono text-indigo-400/70">{r.deal}</span>
                    </div>
                    <span class="text-[11px] text-[#52525B]">{r.time}</span>
                  </div>
                  <div class="flex gap-1.5 flex-wrap pl-3.5">
                    {r.signals.map(s => (
                      <span class="text-[11px] px-1.5 py-0.5 rounded-md bg-white/[0.04] border border-white/[0.07] text-[#A1A1AA]">{s}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Deal Health -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Deal Health</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Deal-level health score</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">A live composite score of momentum, stakeholder engagement, MAP quality, and competitive exposure.</p>
          <div class="rounded-xl overflow-hidden" style="background: #0a0a0d; border: 1px solid rgba(255,255,255,0.07);">
            <!-- App header with deal selector -->
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.06]">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                <span class="text-[13px] font-medium text-[#FAFAFA]">Deal Health</span>
              </div>
              <div class="flex items-center gap-1 text-[12px] text-[#71717A] border border-white/[0.07] rounded-md px-2 py-0.5">
                Acme Corp
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M2 3l2 2 2-2" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
              </div>
            </div>
            <!-- Big score with ring -->
            <div class="flex items-center justify-between px-5 py-4 border-b border-white/[0.05]">
              <div>
                <div class="flex items-baseline gap-1 mb-1">
                  <span class="text-4xl font-bold text-green-400">71</span>
                  <span class="text-base text-[#52525B] font-normal">/100</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="text-[11px] px-1.5 py-0.5 rounded-md bg-green-500/10 border border-green-500/20 text-green-400 font-medium">Good</span>
                  <span class="text-[11px] text-green-400">↑ +3 this week</span>
                </div>
              </div>
              <!-- SVG ring chart -->
              <svg viewBox="0 0 44 44" class="w-14 h-14 -rotate-90">
                <circle cx="22" cy="22" r="17" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="4"/>
                <circle cx="22" cy="22" r="17" fill="none" stroke="#4ade80" stroke-width="4" stroke-opacity="0.65"
                  stroke-dasharray={`${71 * 106.8 / 100} 106.8`} stroke-linecap="round"/>
              </svg>
            </div>
            <!-- Component bars -->
            <div class="p-4 space-y-2.5">
              {[
                { label: "Momentum",      pct: 78, color: "bg-green-500",  delta: "+6%",  dc: "text-green-400" },
                { label: "Stakeholders",  pct: 55, color: "bg-yellow-500", delta: "—",    dc: "text-[#52525B]" },
                { label: "MAP quality",   pct: 82, color: "bg-green-500",  delta: "+4%",  dc: "text-green-400" },
                { label: "Competitive",   pct: 61, color: "bg-yellow-500", delta: "−2%",  dc: "text-red-400" },
                { label: "Sentiment",     pct: 68, color: "bg-green-500",  delta: "+3%",  dc: "text-green-400" },
              ].map(r => (
                <div class="flex items-center gap-2.5">
                  <span class="text-[11px] text-[#A1A1AA] w-24 flex-shrink-0">{r.label}</span>
                  <div class="flex-1 h-1.5 rounded-full bg-white/[0.06]">
                    <div class={`h-1.5 rounded-full ${r.color} opacity-60`} style={`width: ${r.pct}%`}></div>
                  </div>
                  <span class="text-[11px] font-mono text-[#A1A1AA] w-6 text-right flex-shrink-0">{r.pct}%</span>
                  <span class={`text-[11px] w-7 text-right flex-shrink-0 font-medium ${r.dc}`}>{r.delta}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Rep Performance -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Rep Performance</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Conversation quality insights</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">Benchmark each rep on objection handling, next-step hygiene, talk ratio, and buyer engagement across their entire book.</p>
          <div class="rounded-xl overflow-hidden" style="background: #0a0a0d; border: 1px solid rgba(255,255,255,0.07);">
            <!-- App header -->
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.06]">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                <span class="text-[13px] font-medium text-[#FAFAFA]">Rep Performance</span>
              </div>
              <div class="flex items-center gap-1 text-[12px] text-[#71717A] border border-white/[0.07] rounded-md px-2 py-0.5">
                Q1 2025
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M2 3l2 2 2-2" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
              </div>
            </div>
            <!-- KPI bar -->
            <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05]">
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-[#FAFAFA]">4</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">Reps</p>
              </div>
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-blue-400">76</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">Avg score</p>
              </div>
              <div class="px-3 py-2.5 text-center">
                <p class="text-base font-bold text-green-400">92</p>
                <p class="text-[10px] text-[#52525B] uppercase tracking-wider mt-0.5">Top score</p>
              </div>
            </div>
            <!-- Rep rows -->
            <div class="divide-y divide-white/[0.04]">
              {[
                { rank: "1", ini: "SK", name: "Sarah K.",  score: 92, obj: "A", steps: "A", sc: "text-green-400",  ac: "bg-green-500/15 border-green-500/25" },
                { rank: "2", ini: "JM", name: "Jordan M.", score: 81, obj: "B", steps: "A", sc: "text-blue-400",   ac: "bg-blue-500/15 border-blue-500/25" },
                { rank: "3", ini: "MT", name: "Mike T.",   score: 74, obj: "B", steps: "C", sc: "text-yellow-400", ac: "bg-yellow-500/15 border-yellow-500/25" },
                { rank: "4", ini: "AR", name: "Aiden R.",  score: 58, obj: "C", steps: "D", sc: "text-orange-400", ac: "bg-orange-500/15 border-orange-500/25" },
              ].map(r => (
                <div class="flex items-center px-4 py-2.5 gap-3">
                  <span class="text-[11px] text-[#52525B] w-3 flex-shrink-0">{r.rank}</span>
                  <div class={`w-6 h-6 rounded-full border flex items-center justify-center flex-shrink-0 ${r.ac}`}>
                    <span class={`text-[10px] font-bold ${r.sc}`}>{r.ini}</span>
                  </div>
                  <span class="text-[13px] font-medium text-[#E4E4E7] flex-1 min-w-0 truncate">{r.name}</span>
                  <div class="flex items-center gap-1.5 flex-shrink-0">
                    <div class="w-12 h-1.5 rounded-full bg-white/[0.06]">
                      <div class={`h-1.5 rounded-full opacity-70 ${r.score >= 80 ? 'bg-green-500' : r.score >= 65 ? 'bg-blue-500' : r.score >= 55 ? 'bg-yellow-500' : 'bg-orange-500'}`} style={`width: ${r.score}%`}></div>
                    </div>
                    <span class={`text-[12px] font-bold font-mono w-5 text-right ${r.sc}`}>{r.score}</span>
                  </div>
                  <div class="flex gap-1 flex-shrink-0">
                    {[r.obj, r.steps].map(g => (
                      <span class={`text-[11px] w-5 h-5 rounded flex items-center justify-center font-bold ${g === 'A' ? 'bg-green-500/15 text-green-400' : g === 'B' ? 'bg-blue-500/15 text-blue-400' : g === 'C' ? 'bg-yellow-500/15 text-yellow-400' : 'bg-red-500/15 text-red-400'}`}>{g}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>


    <!-- Core Platform Capabilities -->
    <div class="mb-24">
      <p class="text-xs text-[#52525B] uppercase tracking-widest font-semibold mb-12">Features</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-16">

        <!-- 1. Chat UI -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <h3 class="font-semibold text-[#FAFAFA]">Deal Intelligence Chat</h3>
            <span class="text-[12px] text-[#52525B] uppercase tracking-wider">Natural language queries</span>
          </div>
          <p class="text-sm text-[#71717A] leading-relaxed mb-5">Ask anything about a deal, account, or rep in plain English. Every answer is grounded in actual conversation data — not summaries or gut feel.</p>
          <div class="rounded-xl overflow-hidden" style="background: #0a0a0d; border: 1px solid rgba(255,255,255,0.07);">
            <!-- App header with deal context -->
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/[0.06]">
              <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>
                <span class="text-[13px] font-medium text-[#FAFAFA]">Acme Corp</span>
                <span class="text-[11px] font-mono text-indigo-400/70">D-2847</span>
              </div>
              <div class="flex gap-1">
                <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.06] text-[#71717A]">Negotiation</span>
                <span class="text-[11px] px-1.5 py-0.5 rounded bg-yellow-500/10 border border-yellow-500/20 text-yellow-400">At risk</span>
              </div>
            </div>
            <!-- Chat messages -->
            <div class="p-4 space-y-3">
              <!-- User message (right-aligned) -->
              <div class="flex justify-end">
                <p class="text-[13px] text-[#A1A1AA] bg-white/[0.05] border border-white/[0.07] rounded-xl rounded-br-sm px-3 py-2 leading-relaxed max-w-[80%]">What's blocking the Acme deal?</p>
              </div>
              <!-- AI response -->
              <div class="flex gap-2">
                <div class="w-5 h-5 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M5 1l1.18 2.39 2.64.38-1.91 1.86.45 2.63L5 7l-2.36 1.26.45-2.63L1.18 3.77l2.64-.38L5 1z" fill="#818CF8"/></svg>
                </div>
                <div class="flex-1">
                  <p class="text-[13px] text-[#E4E4E7] bg-indigo-500/[0.07] border border-indigo-500/15 rounded-xl rounded-tl-sm px-3 py-2 leading-relaxed mb-1.5">Procurement is the main blocker — CFO sign-off flagged on Mar 3 call. Legal went silent after Feb 28.</p>
                  <div class="flex gap-1.5 flex-wrap">
                    {["Mar 3 · Zoom", "Feb 28 · Gmail"].map(s => (
                      <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-[#71717A]">↗ {s}</span>
                    ))}
                  </div>
                </div>
              </div>
              <!-- User message (right-aligned) -->
              <div class="flex justify-end">
                <p class="text-[13px] text-[#A1A1AA] bg-white/[0.05] border border-white/[0.07] rounded-xl rounded-br-sm px-3 py-2 leading-relaxed max-w-[80%]">Who's the internal champion?</p>
              </div>
              <!-- AI typing -->
              <div class="flex gap-2">
                <div class="w-5 h-5 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0">
                  <svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M5 1l1.18 2.39 2.64.38-1.91 1.86.45 2.63L5 7l-2.36 1.26.45-2.63L1.18 3.77l2.64-.38L5 1z" fill="#818CF8"/></svg>
                </div>
                <div class="bg-indigo-500/[0.07] border border-indigo-500/15 rounded-xl rounded-tl-sm px-3 py-2.5 flex items-center gap-1">
                  {[0, 0.2, 0.4].map((d) => (
                    <span class="w-1 h-1 rounded-full bg-indigo-400" style={`animation: pulse-dot 1.4s ${d}s ease-in-out infinite`}></span>
                  ))}
                </div>
              </div>
            </div>
            <!-- Input bar -->
            <div class="px-4 py-3 border-t border-white/[0.05] flex items-center gap-2">
              <div class="flex-1 text-[12px] text-[#52525B] bg-white/[0.03] border border-white/[0.05] rounded-lg px-3 py-2">Ask about any deal, rep, or account…</div>
              <div class="w-6 h-6 rounded-lg bg-indigo-500/20 border border-indigo-500/20 flex items-center justify-center flex-shrink-0">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 10L10 6L2 2V5.5L7 6L2 6.5V10Z" fill="#818CF8"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- 2. Timeline -->
        <div>
          <div class="flex items-center gap-2.5 mb-1">
