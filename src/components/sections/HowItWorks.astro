---
---
<section id="how-it-works" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-xs text-muted uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        From conversation to insight in <span class="gradient-text">four steps</span>
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">Connect sources, extract signals, see them where you work, and act on them — no new app to learn.</p>
    </div>

    <!-- ── STEP 1: CONNECT ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-24">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">01</span>
          </div>
          <span class="text-xs text-muted uppercase tracking-widest font-medium">Connect</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">Link your sources in minutes</h3>
        <p class="text-muted-foreground leading-relaxed mb-6">Connect Zoom, Salesforce, Gmail, and 10+ other sources with OAuth in minutes. Starmesh starts ingesting immediately — no engineering team required.</p>
        <ul class="space-y-2">
          {["OAuth-based, one-click auth", "Configurable sync frequency & lookback", "Automatic deduplication"].map(item => (
            <li class="flex items-center gap-2 text-sm text-muted-foreground">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="var(--color-primary)" stroke-opacity="0.4" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual: Source connections UI mockup -->
      <div class="rounded-xl border border-border overflow-hidden bg-card">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
          <span class="text-xs text-muted mx-auto">Data Sources</span>
        </div>
        <div class="p-4 space-y-2.5">
          {[
            { name: "Zoom", sub: "Video calls & recordings", status: "Connected", ago: "Syncing…", dot: "bg-success" },
            { name: "Salesforce", sub: "CRM & opportunities", status: "Connected", ago: "2 min ago", dot: "bg-success" },
            { name: "Microsoft Teams", sub: "Meetings & calls", status: "Connected", ago: "Just now", dot: "bg-success" },
            { name: "Gmail", sub: "Email threads", status: "Connected", ago: "8 min ago", dot: "bg-success" },
            { name: "Gong", sub: "Call recordings", status: "Connected", ago: "14 min ago", dot: "bg-success" },
            { name: "HubSpot", sub: "CRM & contacts", status: "Setup…", ago: "–", dot: "bg-warning" },
          ].map((s) => (
            <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-card border border-border">
              <div class="flex items-center gap-2.5">
                <span class={`w-2 h-2 rounded-full ${s.dot} flex-shrink-0`}></span>
                <div>
                  <p class="text-xs font-medium text-foreground">{s.name}</p>
                  <p class="text-[13px] text-muted">{s.sub}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-[13px] text-success font-medium">{s.status}</p>
                <p class="text-[12px] text-muted">{s.ago}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── STEP 2: ANALYZE ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-24">
      <!-- Visual: Transcript → Analysis -->
      <div class="rounded-xl border border-border overflow-hidden order-2 md:order-1 bg-card">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
          <span class="text-xs text-muted mx-auto">AI Analysis</span>
        </div>
        <div class="grid grid-cols-2 divide-x divide-border">
          <!-- Raw transcript -->
          <div class="p-5">
            <p class="text-[12px] text-muted-foreground uppercase tracking-widest mb-3">Raw Transcript</p>
            <div class="space-y-2.5">
              <p class="text-[13px] text-muted-foreground leading-relaxed p-2.5 rounded bg-white/5 border border-border">
                <span class="text-muted">Rep:</span> "…so the platform we're evaluating right now is about 40% cheaper than what you're proposing for Q3."
              </p>
              <p class="text-[13px] text-muted-foreground leading-relaxed p-2.5 rounded bg-white/5 border border-border">
                <span class="text-muted">Prospect:</span> "Budget sign-off for enterprise tools is pretty locked in right now — we'd need a champion internally."
              </p>
            </div>
            <!-- Processing indicator -->
            <div class="mt-4 flex items-center gap-2">
              <div class="flex gap-1">
                {[0, 0.2, 0.4].map((d) => (
                  <span class="w-1 h-1 rounded-full bg-primary" style={`animation: pulse-dot 1.4s ${d}s ease-in-out infinite`}></span>
                ))}
              </div>
              <span class="text-[12px] text-primary">Analyzing…</span>
            </div>
          </div>
          <!-- Structured output (per call) -->
          <div class="p-5">
            <p class="text-[12px] text-muted-foreground uppercase tracking-widest mb-1">Structured Output</p>
            <p class="text-[11px] text-muted-foreground/80 mb-3">From this call</p>
            <div class="space-y-2.5">
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-muted-foreground w-16 flex-shrink-0">pwin_score</span>
                <span class="text-[13px] font-medium text-success text-right">0.74</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-muted-foreground w-16 flex-shrink-0">slip_risk</span>
                <span class="text-[13px] font-medium text-danger text-right">elevated</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-muted-foreground w-16 flex-shrink-0">pricing_pres.</span>
                <span class="text-[13px] font-medium text-warning text-right">moderate</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-muted-foreground w-16 flex-shrink-0">competitor</span>
                <div class="flex flex-wrap gap-1 justify-end">
                  <span class="px-1.5 py-0.5 rounded text-[12px] bg-warning/10 text-warning border border-warning/20">Gong</span>
                  <span class="px-1.5 py-0.5 rounded text-[12px] bg-warning/10 text-warning border border-warning/20">3×</span>
                </div>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-muted-foreground w-16 flex-shrink-0">Deal</span>
                <span class="text-[13px] font-medium text-primary text-right">D-2847 ↗</span>
              </div>
              <div class="mt-2 pt-2 border-t border-border">
                <div class="flex items-center gap-1.5">
                  <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="3" stroke="var(--color-danger)" stroke-opacity="0.6" stroke-width="1"/><path d="M4 2v3" stroke="var(--color-danger)" stroke-width="1" stroke-linecap="round"/></svg>
                  <span class="text-[12px] text-danger font-medium">Deal at risk of slip</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 md:order-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">02</span>
          </div>
          <span class="text-xs text-muted uppercase tracking-widest font-medium">Analyze</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">Configurable templates extract signals from every interaction</h3>
        <p class="text-muted-foreground leading-relaxed mb-6">Starmesh runs configurable extraction templates across every call and email — covering deal momentum, MEDDICC qualification, MAP health analysis, stakeholder mapping, competitor mentions, pricing pressure, and more — all automatically linked to the right CRM opportunity.</p>
        <ul class="space-y-2">
          {["MEDDICC tracking & qualification coverage on every call", "MAP health, stakeholder analysis & champion engagement signals", "Every signal linked to the right Salesforce or HubSpot deal"].map(item => (
            <li class="flex items-center gap-2 text-sm text-muted-foreground">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="var(--color-primary)" stroke-opacity="0.4" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ── STEP 3: DELIVER ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-24">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">03</span>
          </div>
          <span class="text-xs text-muted uppercase tracking-widest font-medium">Deliver</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">See it in Salesforce, HubSpot, or your warehouse</h3>
        <p class="text-muted-foreground leading-relaxed mb-6">Starmesh pushes win score, slip risk, and call signals onto the deal record in Salesforce or HubSpot. No new app to check. RevOps get the same data in BigQuery, Snowflake, or Databricks for dashboards and forecasts.</p>
        <ul class="space-y-2">
          {["Win score & risk on every opportunity in your CRM", "Pipeline and forecast views that update after every call", "Same data in your warehouse for RevOps and BI"].map(item => (
            <li class="flex items-center gap-2 text-sm text-muted-foreground">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="var(--color-primary)" stroke-opacity="0.4" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual: Salesforce opportunity with Starmesh fields -->
      <div class="rounded-xl border border-border overflow-hidden bg-card">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border bg-muted/30">
          <span class="text-[10px] text-muted-foreground uppercase tracking-wider font-medium">Salesforce · Opportunity</span>
        </div>
        <div class="p-4 space-y-4">
          <div class="flex items-baseline justify-between gap-4">
            <div>
              <p class="text-[11px] text-muted-foreground uppercase tracking-wider mb-0.5">Opportunity Name</p>
              <p class="text-sm font-semibold text-foreground">Acme Corp — Enterprise Platform</p>
            </div>
            <div class="text-right">
              <p class="text-[11px] text-muted-foreground uppercase tracking-wider mb-0.5">Amount</p>
              <p class="text-sm font-semibold text-foreground">$124,000</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <p class="text-[11px] text-muted-foreground uppercase tracking-wider mb-0.5">Stage</p>
              <p class="text-[13px] text-foreground">Negotiation</p>
            </div>
            <div>
              <p class="text-[11px] text-muted-foreground uppercase tracking-wider mb-0.5">Close Date</p>
              <p class="text-[13px] text-foreground">Mar 28, 2025</p>
            </div>
          </div>
          <div class="pt-3 border-t border-border rounded-lg bg-primary/5 border border-primary/20 p-3">
            <p class="text-[11px] text-primary uppercase tracking-wider font-medium mb-2">Starmesh · Deal intelligence</p>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2">
              <div class="flex justify-between">
                <span class="text-[12px] text-muted-foreground">Win score</span>
                <span class="text-[13px] font-semibold text-success">0.74</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[12px] text-muted-foreground">Slip risk</span>
                <span class="text-[13px] font-semibold text-danger">Elevated</span>
              </div>
              <div class="col-span-2 flex justify-between items-center">
                <span class="text-[12px] text-muted-foreground">Last call</span>
                <span class="text-[12px] text-warning">Pricing pressure · Competitor (Gong) 3×</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── STEP 4: ACT ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
            <span class="text-xs font-bold text-primary">04</span>
          </div>
          <span class="text-xs text-muted uppercase tracking-widest font-medium">Act</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">From signal to action — without the busywork</h3>
        <p class="text-muted-foreground leading-relaxed mb-6">Use deal intelligence where it matters: prep 1:1s with at-risk deals front and center, adjust forecast before the board meeting, or coach reps on competitor and pricing mentions — no spreadsheets, no manual rollups.</p>
        <ul class="space-y-2">
          {["Prep 1:1s with a clear view of which deals need attention", "Forecast and pipeline reviews that stay current automatically", "Coach reps on competitor mentions and pricing pressure from calls"].map(item => (
            <li class="flex items-center gap-2 text-sm text-muted-foreground">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="var(--color-primary)" stroke-opacity="0.4" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual: Use-case cards (same style weight as other step visuals) -->
      <div class="rounded-xl border border-border overflow-hidden bg-card p-5">
        <p class="text-[11px] text-muted-foreground uppercase tracking-wider font-medium mb-4">Where deal intelligence shows up</p>
        <div class="space-y-4">
          {[
            { step: "1", title: "Prep 1:1s", desc: "At-risk and slipping deals surfaced before the meeting — no digging through CRM.", label: "Manager" },
            { step: "2", title: "Forecast review", desc: "Win scores and risk updated after every call. Board-ready pipeline view.", label: "RevOps / Leadership" },
            { step: "3", title: "Competitor & pricing coaching", desc: "See which deals mentioned Gong or pricing pressure. Coach reps with call-backed signals.", label: "Sales enablement" },
          ].map((u) => (
            <div class="flex gap-4 p-4 rounded-lg bg-muted/20 border border-border">
              <div class="w-8 h-8 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center flex-shrink-0 text-xs font-bold text-primary">{u.step}</div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-1">
                  <h4 class="text-sm font-semibold text-foreground">{u.title}</h4>
                  <span class="text-[11px] text-muted-foreground px-1.5 py-0.5 rounded bg-muted/50">{u.label}</span>
                </div>
                <p class="text-[13px] text-muted-foreground leading-relaxed">{u.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
