---
---
<section id="how-it-works" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        From conversation to insight in <span class="gradient-text">three steps</span>
      </h2>
      <p class="text-[#A1A1AA] max-w-xl mx-auto">No custom pipelines. No new tools. Just signal — in your warehouse.</p>
    </div>

    <!-- ── STEP 1: CONNECT ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-24">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center">
            <span class="text-xs font-bold text-indigo-400">01</span>
          </div>
          <span class="text-xs text-[#71717A] uppercase tracking-widest font-medium">Connect</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">Link your sources in minutes</h3>
        <p class="text-[#A1A1AA] leading-relaxed mb-6">Connect Zoom, Salesforce, Gmail, and 10+ other sources with OAuth in minutes. Starmesh starts ingesting immediately — no engineering team required.</p>
        <ul class="space-y-2">
          {["OAuth-based, one-click auth", "Configurable sync frequency & lookback", "Automatic deduplication"].map(item => (
            <li class="flex items-center gap-2 text-sm text-[#A1A1AA]">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="rgba(99,102,241,0.4)" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual: Source connections UI mockup -->
      <div class="rounded-xl border border-white/[0.07] overflow-hidden" style="background: #0a0a0d;">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.06]">
          <span class="text-xs text-[#71717A] mx-auto">Data Sources</span>
        </div>
        <div class="p-4 space-y-2.5">
          {[
            { name: "Zoom", sub: "Video calls & recordings", status: "Connected", ago: "Syncing…", dot: "bg-green-400" },
            { name: "Salesforce", sub: "CRM & opportunities", status: "Connected", ago: "2 min ago", dot: "bg-green-400" },
            { name: "Microsoft Teams", sub: "Meetings & calls", status: "Connected", ago: "Just now", dot: "bg-green-400" },
            { name: "Gmail", sub: "Email threads", status: "Connected", ago: "8 min ago", dot: "bg-green-400" },
            { name: "Gong", sub: "Call recordings", status: "Connected", ago: "14 min ago", dot: "bg-green-400" },
            { name: "HubSpot", sub: "CRM & contacts", status: "Setup…", ago: "–", dot: "bg-yellow-400" },
          ].map((s) => (
            <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-[#111114] border border-white/[0.05]">
              <div class="flex items-center gap-2.5">
                <span class={`w-2 h-2 rounded-full ${s.dot} flex-shrink-0`}></span>
                <div>
                  <p class="text-xs font-medium text-[#FAFAFA]">{s.name}</p>
                  <p class="text-[13px] text-[#52525B]">{s.sub}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-[13px] text-green-400 font-medium">{s.status}</p>
                <p class="text-[12px] text-[#52525B]">{s.ago}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── STEP 2: ANALYZE ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-24">
      <!-- Visual: Transcript → Analysis -->
      <div class="rounded-xl border border-white/[0.07] overflow-hidden order-2 md:order-1" style="background: #0a0a0d;">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.06]">
          <span class="text-xs text-[#71717A] mx-auto">AI Analysis</span>
        </div>
        <div class="grid grid-cols-2 divide-x divide-white/[0.05]">
          <!-- Raw transcript -->
          <div class="p-5">
            <p class="text-[12px] text-[#A1A1AA] uppercase tracking-widest mb-3">Raw Transcript</p>
            <div class="space-y-2.5">
              <p class="text-[13px] text-[#A1A1AA] leading-relaxed p-2.5 rounded bg-white/[0.03] border border-white/[0.04]">
                <span class="text-[#52525B]">Rep:</span> "…so the platform we're evaluating right now is about 40% cheaper than what you're proposing for Q3."
              </p>
              <p class="text-[13px] text-[#A1A1AA] leading-relaxed p-2.5 rounded bg-white/[0.03] border border-white/[0.04]">
                <span class="text-[#52525B]">Prospect:</span> "Budget sign-off for enterprise tools is pretty locked in right now — we'd need a champion internally."
              </p>
            </div>
            <!-- Processing indicator -->
            <div class="mt-4 flex items-center gap-2">
              <div class="flex gap-1">
                {[0, 0.2, 0.4].map((d) => (
                  <span class="w-1 h-1 rounded-full bg-indigo-400" style={`animation: pulse-dot 1.4s ${d}s ease-in-out infinite`}></span>
                ))}
              </div>
              <span class="text-[12px] text-indigo-400">Analyzing…</span>
            </div>
          </div>
          <!-- Structured output -->
          <div class="p-5">
            <p class="text-[12px] text-[#A1A1AA] uppercase tracking-widest mb-3">Structured Output</p>
            <div class="space-y-2.5">
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-[#A1A1AA] w-16 flex-shrink-0">pwin_score</span>
                <span class="text-[13px] font-medium text-green-400 text-right">0.74</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-[#A1A1AA] w-16 flex-shrink-0">slip_risk</span>
                <span class="text-[13px] font-medium text-red-400 text-right">elevated</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-[#A1A1AA] w-16 flex-shrink-0">pricing_pres.</span>
                <span class="text-[13px] font-medium text-yellow-400 text-right">moderate</span>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-[#A1A1AA] w-16 flex-shrink-0">competitor</span>
                <div class="flex flex-wrap gap-1 justify-end">
                  <span class="px-1.5 py-0.5 rounded text-[12px] bg-orange-500/10 text-orange-400 border border-orange-500/20">Gong</span>
                  <span class="px-1.5 py-0.5 rounded text-[12px] bg-orange-500/10 text-orange-400 border border-orange-500/20">3×</span>
                </div>
              </div>
              <div class="flex items-start justify-between gap-2">
                <span class="text-[12px] text-[#A1A1AA] w-16 flex-shrink-0">Deal</span>
                <span class="text-[13px] font-medium text-indigo-400 text-right">D-2847 ↗</span>
              </div>
              <div class="mt-2 pt-2 border-t border-white/[0.04]">
                <div class="flex items-center gap-1.5">
                  <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="3" stroke="rgba(239,68,68,0.6)" stroke-width="1"/><path d="M4 2v3" stroke="#F87171" stroke-width="1" stroke-linecap="round"/></svg>
                  <span class="text-[12px] text-red-400 font-medium">Deal at risk of slip</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 md:order-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center">
            <span class="text-xs font-bold text-indigo-400">02</span>
          </div>
          <span class="text-xs text-[#71717A] uppercase tracking-widest font-medium">Analyze</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">Specialized AI models extract signals from every interaction</h3>
        <p class="text-[#A1A1AA] leading-relaxed mb-6">Starmesh runs purpose-built AI models across every call and email — covering deal momentum, MEDDICC qualification, MAP health analysis, stakeholder mapping, competitor mentions, pricing pressure, and more — all automatically linked to the right CRM opportunity.</p>
        <ul class="space-y-2">
          {["MEDDICC tracking & qualification coverage on every call", "MAP health, stakeholder analysis & champion engagement signals", "Every signal linked to the right Salesforce or HubSpot deal"].map(item => (
            <li class="flex items-center gap-2 text-sm text-[#A1A1AA]">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="rgba(99,102,241,0.4)" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ── STEP 3: DELIVER ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center">
            <span class="text-xs font-bold text-indigo-400">03</span>
          </div>
          <span class="text-xs text-[#71717A] uppercase tracking-widest font-medium">Deliver</span>
        </div>
        <h3 class="text-2xl font-bold mb-4">Deal intelligence tables in your warehouse</h3>
        <p class="text-[#A1A1AA] leading-relaxed mb-6">Win probabilities, risk signals, and competitive insights land as structured tables in BigQuery or Snowflake — ready for your RevOps dashboards, dbt models, and forecast workflows.</p>
        <ul class="space-y-2">
          {["BigQuery, Snowflake, and Databricks supported", "Deal-level tables updated on every new call", "Query pwin, risk, and signals with SQL you already know"].map(item => (
            <li class="flex items-center gap-2 text-sm text-[#A1A1AA]">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="rgba(99,102,241,0.4)" stroke-width="1"/><path d="M5 8l2 2 4-4" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual: BigQuery table preview -->
      <div class="rounded-xl border border-white/[0.07] overflow-hidden" style="background: #0a0a0d;">
        <div class="flex items-center justify-between px-4 py-3 border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-indigo-400 flex-shrink-0"></span>
            <span class="text-xs font-mono text-[#A1A1AA]">starmesh.<span class="text-[#FAFAFA]">deal_intelligence</span></span>
          </div>
          <span class="text-[13px] text-green-400 border border-green-500/20 bg-green-500/5 px-2 py-0.5 rounded-full">BigQuery</span>
        </div>
        <!-- Column headers -->
        <div class="grid grid-cols-4 gap-0 border-b border-white/[0.05] px-4 py-2.5 bg-[#111114]">
          {["deal_id", "pwin_score", "slip_risk", "stage"].map(h => (
            <span class="text-[13px] text-[#A1A1AA] font-mono uppercase tracking-wider">{h}</span>
          ))}
        </div>
        <!-- Table rows -->
        {[
          ["D-2847", "0.74", "elevated",  "negotiation"],
          ["D-2901", "0.62", "low",        "demo"],
          ["D-1920", "0.88", "low",        "closing"],
          ["D-3012", "0.41", "high",       "discovery"],
          ["D-2955", "0.79", "low",        "negotiation"],
          ["D-3104", "0.23", "critical",   "prospecting"],
        ].map(([deal, pwin, slip, stage], i) => (
          <div class={`grid grid-cols-4 gap-0 px-4 py-2.5 border-b border-white/[0.03] ${i % 2 === 0 ? '' : 'bg-white/[0.01]'}`}>
            <span class="text-[13px] font-mono text-indigo-400">{deal}</span>
            <span class={`text-[13px] font-mono font-semibold ${parseFloat(pwin) >= 0.6 ? 'text-green-400' : 'text-red-400'}`}>{pwin}</span>
            <span class={`text-[13px] font-mono font-semibold ${slip === 'low' ? 'text-green-400' : slip === 'critical' ? 'text-red-500' : 'text-orange-400'}`}>{slip}</span>
            <span class="text-[13px] font-mono text-[#A1A1AA]">{stage}</span>
          </div>
        ))}
        <div class="px-4 py-3 flex items-center justify-between">
          <span class="text-[13px] text-[#A1A1AA]">124 deals · refreshed 2 min ago</span>
          <span class="text-[12px] text-indigo-400 font-mono">SELECT * FROM deal_intelligence...</span>
        </div>
      </div>
    </div>
  </div>
</section>
