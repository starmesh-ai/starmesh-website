---
const testimonials = [
  {
    quote: "Managing 150+ SMB accounts means I can't listen to every call. Starmesh automatically flags which conversations show disengagement or frustration — I only step in where it matters. My retention numbers have never been cleaner.",
    name: "Shabib",
    role: "CSM",
    company: "BirdEye",
    initial: "S",
  },
  {
    quote: "We were guessing which messages actually resonated with enterprise buyers. Starmesh gives us a structured view of what comes up in every discovery call — objections by segment, competitor mentions, themes that land. It's changed how we brief campaigns.",
    name: "Steve",
    role: "Head of Marketing",
    company: "Open Text Corp",
    initial: "S",
  },
  {
    quote: "Rep notes are inconsistent and CRM hygiene was a constant battle. Starmesh standardized our call data automatically — now our pipeline reports actually reflect what's happening in deals, not just what reps remembered to log.",
    name: "Richard",
    role: "Sales Operations",
    company: "Eltropy",
    initial: "R",
  },
];
---
<section id="testimonials" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">What teams are saying</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Trusted by revenue and data teams
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="card p-6 flex flex-col">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {[...Array(5)].map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#6366F1">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-sm text-[#A1A1AA] leading-relaxed flex-1 mb-6">
            "{t.quote}"
          </blockquote>

          <!-- Attribution -->
          <div class="flex items-center gap-3 pt-4 border-t border-white/[0.06]">
            <div class="w-9 h-9 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0">
              <span class="text-xs font-bold text-indigo-400">{t.initial}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#FAFAFA]">{t.name}</p>
              <p class="text-xs text-[#A1A1AA]">{t.role} · {t.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
