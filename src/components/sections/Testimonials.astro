---
const testimonials = [
  {
    quote: "Starmesh flags disengagement across my 150+ accounts so I only step in where it matters.",
    role: "CSM",
    company: "BirdEye",
  },
  {
    quote: "Starmesh standardized our call data so pipeline reports finally reflect reality.",
    role: "Sales Operations",
    company: "Eltropy",
  },
  {
    quote: "Starmesh surfaces pricing pressure and champion silence weeks before we'd normally catch it.",
    role: "VP of Sales",
    company: "Vectra",
  },
  {
    quote: "Starmesh surfaced the signals we missed — win rate improved within two quarters.",
    role: "Director of Revenue Operations",
    company: "CommerceIQ",
  },
  {
    quote: "We have a structured view of every objection and competitor mention across discovery calls.",
    role: "Head of Marketing",
    company: "OpenText",
  },
];
---
<section id="testimonials" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">What teams are saying</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Trusted by revenue teams at
      </h2>
      <!-- Company name pills -->
      <div class="flex items-center justify-center gap-3 flex-wrap mt-4">
        {["BirdEye", "Eltropy", "Vectra", "CommerceIQ", "OpenText"].map(c => (
          <span class="px-3 py-1 rounded-full border border-white/[0.08] bg-white/[0.03] text-sm text-[#A1A1AA] font-medium">{c}</span>
        ))}
      </div>
    </div>

    <div class="testimonials-scroll flex gap-4 overflow-x-auto overflow-y-hidden pb-2 snap-x snap-mandatory">
      {testimonials.map((t) => (
        <div class="card p-4 flex flex-col flex-none w-64 snap-start min-w-0">

          <!-- Quote -->
          <blockquote class="text-sm text-[#A1A1AA] leading-snug flex-1 mb-3">
            "{t.quote}"
          </blockquote>

          <!-- Attribution: role + company only (anonymous) -->
          <div class="flex items-center gap-2.5 pt-3 border-t border-white/[0.06]">
            <div class="w-7 h-7 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <span class="text-[10px] font-bold text-indigo-400">{t.role.charAt(0)}</span>
            </div>
            <div class="min-w-0">
              <p class="text-[11px] text-[#71717A]">{t.role} · {t.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Hide horizontal scrollbar; content still scrolls via wheel, touch, drag */
  .testimonials-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .testimonials-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
