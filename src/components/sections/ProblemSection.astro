---
---
<section id="problem" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">The problem</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Revenue conversations happen constantly.<br class="hidden md:block"/>
        <span class="text-[#A1A1AA]">Almost none of it is usable.</span>
      </h2>
      <p class="text-[#A1A1AA] text-lg">Without Starmesh, your team drowns in unstructured data.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Pain 1: No structure -->
      <div class="rounded-xl border border-red-500/10 bg-[#0f0f13] p-6 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(239,68,68,0.3), transparent);"></div>
        <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/15 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F87171" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-2">No structure</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Call recordings and transcripts sit in silos. There's no way to query what was actually discussed.</p>
        <!-- Mini visual: disconnected files -->
        <div class="rounded-lg p-3 bg-[#0a0a0d] border border-white/[0.04]">
          <div class="flex gap-2 flex-wrap">
            {["call_mar3.mp4", "notes.docx", "transcript.txt", "crm_export.csv"].map(f => (
              <div class="flex items-center gap-1.5 px-2 py-1 rounded bg-red-500/5 border border-red-500/10">
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><rect x="1" y="1" width="6" height="6" rx="1" stroke="rgba(239,68,68,0.4)" stroke-width="0.75"/></svg>
                <span class="text-[9px] text-red-400/70 font-mono">{f}</span>
              </div>
            ))}
          </div>
          <p class="text-[9px] text-[#A1A1AA] mt-2 text-center">Unstructured · Unqueried · Unused</p>
        </div>
      </div>

      <!-- Pain 2: Manual effort -->
      <div class="rounded-xl border border-orange-500/10 bg-[#0f0f13] p-6 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);"></div>
        <div class="w-10 h-10 rounded-lg bg-orange-500/10 border border-orange-500/15 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FB923C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 6v6h4"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-2">Manual effort doesn't scale</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Tagging calls by hand is slow, inconsistent, and always behind. Your team can't keep up with the volume.</p>
        <!-- Mini visual: backlog counter -->
        <div class="rounded-lg p-3 bg-[#0a0a0d] border border-white/[0.04]">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[9px] text-[#A1A1AA]">Calls to review manually</span>
            <span class="text-sm font-bold text-orange-400">648</span>
          </div>
          <div class="h-1.5 rounded-full bg-white/[0.05] mb-2">
            <div class="h-1.5 rounded-full bg-orange-500/50 min-w-[2px]" style={`width: ${(92 / 648) * 100}%`}></div>
          </div>
          <div class="flex justify-between">
            <span class="text-[9px] text-[#A1A1AA]">Reviewed this week</span>
            <span class="text-[9px] text-orange-400">92 / 648</span>
          </div>
        </div>
      </div>

      <!-- Pain 3: Siloed -->
      <div class="rounded-xl border border-yellow-500/10 bg-[#0f0f13] p-6 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(234,179,8,0.3), transparent);"></div>
        <div class="w-10 h-10 rounded-lg bg-yellow-500/10 border border-yellow-500/15 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FACC15" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#FAFAFA] mb-2">Insights stay siloed</h3>
        <p class="text-sm text-[#A1A1AA] leading-relaxed mb-5">Analysts can't join call data with CRM or product data. Every team is working from a different partial picture.</p>
        <!-- Mini visual: failed SQL join -->
        <div class="rounded-lg p-3 bg-[#0a0a0d] border border-white/[0.04] font-mono text-[9px]">
          <p class="text-[#A1A1AA]">SELECT * FROM calls</p>
          <p class="text-[#A1A1AA]">JOIN crm ON calls.deal_id</p>
          <p class="text-[#A1A1AA]">= crm.opportunity_id</p>
          <div class="mt-2 flex items-center gap-1.5 text-red-400">
            <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><circle cx="4" cy="4" r="3" stroke="currentColor" stroke-width="0.75"/><path d="M2.5 2.5l3 3M5.5 2.5l-3 3" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/></svg>
            <span>No table: calls</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
