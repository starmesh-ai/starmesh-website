---
const reasons = [
  {
    title: "Not Locked in a Sales App",
    body: "Signals land in your warehouse and flow into your existing tools. No new dashboards your team won't adopt.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/>`,
  },
  {
    title: "Define Signals Your Way",
    body: "Customize scoring, definitions, and models to match your sales motion — not a vendor's default playbook.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>`,
  },
  {
    title: "Unify Every Customer System",
    body: "CRM, calls, email, support — one consistent signal layer across your entire customer data stack.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/>`,
  },
  {
    title: "AI That Scales with Your Data",
    body: "Extract insights across millions of interactions automatically — without adding headcount to your data team.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>`,
  },
  {
    title: "Shared Intelligence Across Teams",
    body: "Sales, CS, and Support operate on the same customer signals — eliminating blind spots and finger-pointing.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>`,
  },
];
---
<section id="why-starmesh" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Why choose Starmesh</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Intelligence that lives in <span class="gradient-text">your infrastructure</span>
      </h2>
    </div>

    <!-- ── Before / After Architecture Diagram ── -->
    <div class="rounded-2xl border border-white/[0.07] overflow-hidden mb-12" style="background: #0a0a0d;">
      <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-white/[0.06]">

        <!-- Before -->
        <div class="p-6">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <span class="text-xs font-semibold text-red-400 uppercase tracking-widest">Without Starmesh</span>
          </div>
          <svg viewBox="0 0 320 160" class="w-full mb-4">
            <!-- Scattered, disconnected nodes with X marks -->
            <rect x="10"  y="20" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="50"  y="39" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">Zoom calls</text>
            <rect x="120" y="10" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="160" y="29" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">CRM data</text>
            <rect x="230" y="20" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="270" y="39" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">Emails</text>
            <rect x="10"  y="90" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="50"  y="109" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">Support tix</text>
            <rect x="120" y="100" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="160" y="119" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">Gong recs</text>
            <rect x="230" y="90" width="80" height="30" rx="6" fill="#0f0f13" stroke="rgba(239,68,68,0.2)" stroke-width="1"/>
            <text x="270" y="109" text-anchor="middle" fill="#71717A" font-size="10" font-family="Inter,sans-serif">Spreadsheets</text>
            <!-- X marks between nodes showing no connection -->
            <text x="100" y="42" fill="rgba(239,68,68,0.5)" font-size="14" font-family="sans-serif">✕</text>
            <text x="207" y="42" fill="rgba(239,68,68,0.5)" font-size="14" font-family="sans-serif">✕</text>
            <text x="100" y="112" fill="rgba(239,68,68,0.5)" font-size="14" font-family="sans-serif">✕</text>
            <text x="207" y="112" fill="rgba(239,68,68,0.5)" font-size="14" font-family="sans-serif">✕</text>
            <!-- Broken diagonal lines -->
            <line x1="90" y1="40" x2="120" y2="40" stroke="rgba(239,68,68,0.15)" stroke-width="1" stroke-dasharray="3 3"/>
            <line x1="90" y1="110" x2="120" y2="110" stroke="rgba(239,68,68,0.15)" stroke-width="1" stroke-dasharray="3 3"/>
            <line x1="50" y1="50" x2="50" y2="90" stroke="rgba(239,68,68,0.15)" stroke-width="1" stroke-dasharray="3 3"/>
            <text x="160" y="152" text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Siloed · Unstructured · Manual</text>
          </svg>
          <ul class="space-y-1.5">
            {["No structured data from conversations", "Manual tagging is slow & inconsistent", "Can't join call data with CRM"].map(p => (
              <li class="flex items-center gap-2 text-xs text-[#A1A1AA]">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="rgba(239,68,68,0.4)" stroke-width="1"/><path d="M4 4l4 4M8 4l-4 4" stroke="#F87171" stroke-width="1" stroke-linecap="round"/></svg>
                {p}
              </li>
            ))}
          </ul>
        </div>

        <!-- After -->
        <div class="p-6">
          <div class="flex items-center gap-2 mb-5">
            <span class="w-2 h-2 rounded-full bg-green-400"></span>
            <span class="text-xs font-semibold text-green-400 uppercase tracking-widest">With Starmesh</span>
          </div>
          <svg viewBox="0 0 320 160" class="w-full mb-4">
            <!-- Sources on left -->
            <rect x="10"  y="25"  width="70" height="26" rx="5" fill="#0f0f13" stroke="rgba(99,102,241,0.3)" stroke-width="1"/>
            <text x="45"  y="42"  text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Zoom</text>
            <rect x="10"  y="65"  width="70" height="26" rx="5" fill="#0f0f13" stroke="rgba(99,102,241,0.3)" stroke-width="1"/>
            <text x="45"  y="82"  text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Salesforce</text>
            <rect x="10"  y="105" width="70" height="26" rx="5" fill="#0f0f13" stroke="rgba(99,102,241,0.3)" stroke-width="1"/>
            <text x="45"  y="122" text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Gmail</text>
            <!-- Flowing lines to center -->
            <path d="M 80,38  C 120,38  120,80 140,80"  fill="none" stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <path d="M 80,78  C 120,78  120,80 140,80"  fill="none" stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <path d="M 80,118 C 120,118 120,80 140,80" fill="none" stroke="rgba(99,102,241,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <!-- Center Starmesh -->
            <circle cx="160" cy="80" r="26" fill="#111114" stroke="rgba(99,102,241,0.5)" stroke-width="1.5"/>
            <circle cx="160" cy="80" r="26" fill="none" stroke="rgba(99,102,241,0.12)" stroke-width="1" stroke-dasharray="3 5"/>
            <text x="160" y="82" text-anchor="middle" fill="#818CF8" font-size="8" font-weight="700" font-family="Inter,sans-serif">Starmesh</text>
            <!-- Lines to destinations -->
            <path d="M 180,80 C 210,80 210,45 240,45"  fill="none" stroke="rgba(139,92,246,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <path d="M 180,80 C 210,80 210,80 240,80"  fill="none" stroke="rgba(139,92,246,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <path d="M 180,80 C 210,80 210,115 240,115" fill="none" stroke="rgba(139,92,246,0.4)" stroke-width="1" stroke-dasharray="3 3"/>
            <!-- Destinations -->
            <rect x="240" y="32"  width="72" height="26" rx="5" fill="#0f0f13" stroke="rgba(139,92,246,0.3)" stroke-width="1"/>
            <text x="276" y="49"  text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">BigQuery</text>
            <rect x="240" y="67"  width="72" height="26" rx="5" fill="#0f0f13" stroke="rgba(139,92,246,0.3)" stroke-width="1"/>
            <text x="276" y="84"  text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Snowflake</text>
            <rect x="240" y="102" width="72" height="26" rx="5" fill="#0f0f13" stroke="rgba(139,92,246,0.3)" stroke-width="1"/>
            <text x="276" y="119" text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Databricks</text>
           
            <text x="160" y="152" text-anchor="middle" fill="#A1A1AA" font-size="9" font-family="Inter,sans-serif">Unified · Structured · Automated</text>
          </svg>
          <ul class="space-y-1.5">
            {["Structured tables in your warehouse", "Automatic tagging across every call", "Join conversations with any CRM data"].map(p => (
              <li class="flex items-center gap-2 text-xs text-[#A1A1AA]">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="rgba(52,211,153,0.4)" stroke-width="1"/><path d="M3.5 6l2 2 3-3" stroke="#34D399" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
                {p}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Reason cards 3-col grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-5">
      {reasons.slice(0, 3).map((r) => (
        <div class="card p-6 cursor-default">
          <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><Fragment set:html={r.icon} /></svg>
          </div>
          <h3 class="font-semibold text-[#FAFAFA] mb-2">{r.title}</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-2xl mx-auto">
      {reasons.slice(3).map((r) => (
        <div class="card p-6 cursor-default">
          <div class="w-10 h-10 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><Fragment set:html={r.icon} /></svg>
          </div>
          <h3 class="font-semibold text-[#FAFAFA] mb-2">{r.title}</h3>
          <p class="text-sm text-[#A1A1AA] leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
