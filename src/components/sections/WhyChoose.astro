---
---
<section id="why-starmesh" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#A1A1AA] uppercase tracking-widest mb-3">Why choose Starmesh</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Intelligence that lives in <span class="gradient-text">your infrastructure</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-12">

      <!-- 1. Not Locked in a Sales App -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Not Locked in a Sales App</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">Your data isn't trapped in a vendor's platform.</p>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(239,68,68,0.4)" stroke-width="1"/><path d="M3 3l4 4M7 3L3 7" stroke="#F87171" stroke-width="1" stroke-linecap="round"/></svg>
            <span class="text-[11px] text-[#A1A1AA] line-through decoration-red-500/30">Gong · Clari · Chorus</span>
            <span class="text-[11px] text-[#A1A1AA]">lock data in their UI</span>
          </div>
          <div class="flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(74,222,128,0.4)" stroke-width="1"/><path d="M2.5 5l2 2 3-3" stroke="#4ade80" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="text-[11px] text-green-400 font-medium">Starmesh</span>
            <svg width="10" height="6" viewBox="0 0 10 6"><path d="M0 3H8M6 1l2 2-2 2" stroke="rgba(255,255,255,0.2)" stroke-width="1" fill="none" stroke-linecap="round"/></svg>
            <span class="text-[11px] px-1.5 py-0.5 rounded border border-blue-500/20 bg-blue-500/10 text-blue-400">BigQuery</span>
            <span class="text-[11px] px-1.5 py-0.5 rounded border border-sky-500/20 bg-sky-500/10 text-sky-400">Snowflake</span>
          </div>
        </div>
      </div>

      <!-- 2. Your Data Stays With You -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Your Data Stays With You</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">Your warehouse, your schema, your compute.</p>
        <div class="space-y-1.5">
          {[
            { name: "BigQuery",   color: "text-blue-400",   bg: "bg-blue-500/10 border-blue-500/20" },
            { name: "Snowflake",  color: "text-sky-400",    bg: "bg-sky-500/10 border-sky-500/20" },
            { name: "Databricks", color: "text-orange-400", bg: "bg-orange-500/10 border-orange-500/20" },
          ].map(w => (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
              <span class={`text-[11px] px-2 py-0.5 rounded border font-medium ${w.color} ${w.bg}`}>{w.name}</span>
              <span class="text-[11px] text-[#A1A1AA]">Connected</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Define Signals Your Way -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Define Signals Your Way</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">Scoring and models built around your sales motion.</p>
        <div class="rounded-lg p-3 bg-white/[0.02] border border-white/[0.05] space-y-1.5">
          {[
            { label: "PWin model",       value: "Custom ML",  vc: "text-indigo-400" },
            { label: "Risk threshold",   value: "< 0.45",     vc: "text-orange-400" },
            { label: "MEDDICC tracking", value: "Enabled ✓",  vc: "text-green-400" },
          ].map(r => (
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-[#A1A1AA]">{r.label}</span>
              <span class={`text-[11px] font-mono font-medium ${r.vc}`}>{r.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- 4. Unify Every Customer System -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Unify Every Customer System</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">One consistent signal layer, every source connected.</p>
        <div class="flex items-center gap-3">
          <div class="flex flex-col gap-1">
            {["CRM", "Calls", "Email", "Support"].map(s => (
              <span class="text-[11px] px-2 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-[#A1A1AA]">{s}</span>
            ))}
          </div>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 10H17M13 6l4 4-4 4" stroke="rgba(255,255,255,0.18)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div class="flex flex-col items-center justify-center px-3 py-3 rounded-lg bg-indigo-500/10 border border-indigo-500/20">
            <span class="text-[10px] text-indigo-400 font-medium text-center leading-relaxed">Unified<br/>signal<br/>layer</span>
          </div>
        </div>
      </div>

      <!-- 5. AI That Scales -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">AI That Scales with Your Data</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">Millions of interactions analyzed. Zero extra headcount.</p>
        <div class="flex items-end gap-6">
          <div>
            <p class="text-2xl font-bold text-[#FAFAFA] leading-none">10M+</p>
            <p class="text-[11px] text-[#A1A1AA] mt-1">interactions analyzed</p>
          </div>
          <div>
            <p class="text-xl font-bold text-green-400 leading-none">+0</p>
            <p class="text-[11px] text-[#A1A1AA] mt-1">headcount needed</p>
          </div>
        </div>
      </div>

      <!-- 6. Shared Intelligence Across Teams -->
      <div>
        <div class="w-9 h-9 rounded-lg mb-4 flex items-center justify-center" style="background: rgba(99,102,241,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Shared Intelligence Across Teams</h3>
        <p class="text-xs text-[#A1A1AA] mb-4">One source of truth for Sales, CS, and Support.</p>
        <div class="space-y-1.5">
          {[
            { team: "Sales",   signals: "PWin · Competitor mentions · Risk flags",    color: "text-indigo-400", bg: "bg-indigo-500/10 border-indigo-500/20" },
            { team: "CS",      signals: "Churn risk · Sentiment · Expansion signals", color: "text-teal-400",   bg: "bg-teal-500/10 border-teal-500/20" },
            { team: "Support", signals: "Escalation trends · Friction patterns",      color: "text-violet-400", bg: "bg-violet-500/10 border-violet-500/20" },
          ].map(t => (
            <div class="flex items-center gap-2">
              <span class={`text-[11px] px-1.5 py-0.5 rounded border font-medium flex-shrink-0 ${t.color} ${t.bg}`}>{t.team}</span>
              <span class="text-[10px] text-[#A1A1AA] truncate">{t.signals}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
