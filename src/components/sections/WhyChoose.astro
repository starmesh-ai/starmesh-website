---
---
<section id="why-starmesh" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#A1A1AA] uppercase tracking-widest mb-3">Why Starmesh</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Intelligence that lives in <span class="gradient-text">your infrastructure</span>
      </h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">
        Connect every customer system, keep your data in your warehouse, and define signals your way—without vendor lock-in.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-10">
      <!-- Your data stays with you -->
      <div class="border-l-2 border-blue-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-blue-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Your data stays with you</h3>
        <p class="text-xs text-[#A1A1AA] leading-relaxed mb-3">Your warehouse, your schema, your compute.</p>
        <div class="rounded-lg p-2 bg-[#0a0a0d] border border-white/[0.04] space-y-1.5 mt-auto">
          {[
            { name: "BigQuery", color: "text-blue-400", bg: "bg-blue-500/10 border-blue-500/20" },
            { name: "Snowflake", color: "text-sky-400", bg: "bg-sky-500/10 border-sky-500/20" },
            { name: "Databricks", color: "text-orange-400", bg: "bg-orange-500/10 border-orange-500/20" },
          ].map(w => (
            <div class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
              <span class={`text-[11px] px-2 py-0.5 rounded border font-medium ${w.color} ${w.bg}`}>{w.name}</span>
              <span class="text-[11px] text-[#A1A1AA]">Connected</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Shared intelligence across teams -->
      <div class="border-l-2 border-teal-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-teal-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2DD4BF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Shared intelligence across teams</h3>
        <p class="text-xs text-[#A1A1AA] leading-relaxed mb-3">One source of truth for Sales, CS, and Support.</p>
        <div class="rounded-lg p-2 bg-[#0a0a0d] border border-white/[0.04] space-y-1.5 mt-auto">
          {[
            { team: "Sales", signals: "PWin · Risk flags", color: "text-indigo-400", bg: "bg-indigo-500/10 border-indigo-500/20" },
            { team: "CS", signals: "Churn risk · Expansion", color: "text-teal-400", bg: "bg-teal-500/10 border-teal-500/20" },
            { team: "Support", signals: "Escalation · Friction", color: "text-violet-400", bg: "bg-violet-500/10 border-violet-500/20" },
          ].map(t => (
            <div class="flex items-center gap-2">
              <span class={`text-[11px] px-1.5 py-0.5 rounded border font-medium flex-shrink-0 ${t.color} ${t.bg}`}>{t.team}</span>
              <span class="text-[10px] text-[#A1A1AA] truncate">{t.signals}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Define signals your way -->
      <div class="border-l-2 border-violet-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-violet-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z"/>
            <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Define signals your way</h3>
        <p class="text-xs text-[#A1A1AA] leading-relaxed mb-3">Customize AI analysis based on how your teams operate.</p>
        <div class="rounded-lg p-2 bg-[#0a0a0d] border border-white/[0.04] space-y-1 mt-auto">
          {[
            { label: "PWin model", value: "Custom", vc: "text-indigo-400" },
            { label: "Risk threshold", value: "Your rules", vc: "text-orange-400" },
            { label: "MEDDICC", value: "Enabled ✓", vc: "text-green-400" },
          ].map(r => (
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-[#A1A1AA]">{r.label}</span>
              <span class={`text-[11px] font-mono font-medium ${r.vc}`}>{r.value}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Ingest from every customer system -->
      <div class="border-l-2 border-indigo-500/30 pl-6">
        <div class="w-9 h-9 rounded-lg bg-indigo-500/8 flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Ingest from every customer system</h3>
        <p class="text-xs text-[#A1A1AA] leading-relaxed mb-3">Connect CRM, support, product, and video apps—no blind spots.</p>
        <div class="rounded-lg p-2 bg-[#0a0a0d] border border-white/[0.04] flex flex-wrap gap-1.5">
          {["CRM", "Support", "Product", "Video"].map(s => (
            <span class="text-[11px] px-2 py-0.5 rounded bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 font-medium">{s}</span>
          ))}
        </div>
      </div>

      <!-- Usage-based pricing -->
      <div class="border-l-2 border-emerald-500/30 pl-6">
        <div class="w-9 h-9 rounded-lg bg-emerald-500/8 flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-1">Usage-based pricing</h3>
        <p class="text-xs text-[#A1A1AA] leading-relaxed mb-3">Pay for data processed, not seats.</p>
        <div class="rounded-lg p-2 bg-[#0a0a0d] border border-white/[0.04] space-y-1.5">
          <div class="flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(239,68,68,0.4)" stroke-width="1"/><path d="M3 3l4 4M7 3L3 7" stroke="#F87171" stroke-width="1" stroke-linecap="round"/></svg>
            <span class="text-[11px] text-[#A1A1AA] line-through decoration-red-500/30">Per-seat pricing</span>
          </div>
          <div class="flex items-center gap-2">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="rgba(74,222,128,0.4)" stroke-width="1"/><path d="M2.5 5l2 2 3-3" stroke="#4ade80" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="text-[11px] text-green-400 font-medium">Charged by data processed</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

