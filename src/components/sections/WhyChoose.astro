---
---
<section id="why-starmesh" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs text-[#A1A1AA] uppercase tracking-widest mb-3">Why Starmesh</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Intelligence that lives in <span class="gradient-text">your infrastructure</span>
      </h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">
        Connect every customer system, keep your data in your warehouse, and define signals your way—without vendor lock-in.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-10 md:pl-16">
      <!-- Your data stays with you -->
      <div class="border-l-2 border-blue-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-blue-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-2">Your data stays with you</h3>
        <p class="text-sm text-[#E4E4E7]/90 leading-relaxed max-w-[44ch]">Your warehouse, your schema, your compute.</p>
      </div>

      <!-- Shared intelligence across teams -->
      <div class="border-l-2 border-teal-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-teal-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2DD4BF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-2">Shared intelligence across teams</h3>
        <p class="text-sm text-[#E4E4E7]/90 leading-relaxed max-w-[44ch]">One source of truth for Sales, CS, and Support.</p>
      </div>

      <!-- Define signals your way -->
      <div class="border-l-2 border-violet-500/30 pl-6 flex flex-col">
        <div class="w-9 h-9 rounded-lg bg-violet-500/8 flex items-center justify-center mb-3 flex-shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z"/>
            <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-2">Define signals your way</h3>
        <p class="text-sm text-[#E4E4E7]/90 leading-relaxed max-w-[44ch]">Customize AI analysis based on how your teams operate.</p>
      </div>
      <!-- Ingest from every customer system -->
      <div class="border-l-2 border-indigo-500/30 pl-6">
        <div class="w-9 h-9 rounded-lg bg-indigo-500/8 flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <!-- network/integrations icon -->
            <path d="M12 3v6m0 6v6M3 12h6m6 0h6"/>
            <circle cx="12" cy="12" r="2.25"/>
            <circle cx="12" cy="4.5" r="1.75"/>
            <circle cx="12" cy="19.5" r="1.75"/>
            <circle cx="4.5" cy="12" r="1.75"/>
            <circle cx="19.5" cy="12" r="1.75"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-2">Ingest from every customer system</h3>
        <p class="text-sm text-[#E4E4E7]/90 leading-relaxed max-w-[44ch]">Connect CRM, support, product, and video apps—no blind spots.</p>
      </div>

      <!-- Usage-based pricing -->
      <div class="border-l-2 border-emerald-500/30 pl-6">
        <div class="w-9 h-9 rounded-lg bg-emerald-500/8 flex items-center justify-center mb-3">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3 class="font-semibold text-[#E4E4E7] mb-2">Usage-based pricing</h3>
        <p class="text-sm text-[#E4E4E7]/90 leading-relaxed max-w-[44ch]">Pay for data processed, not seats.</p>
      </div>
    </div>
  </div>
</section>

