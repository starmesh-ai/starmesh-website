const teams = teamsRaw.map(team => {
  const srcPhaseMap: Record<number, string> = {};
  const outPhaseMap: Record<number, string> = {};
  team.phases.forEach(p => {
    p.srcIdx.forEach(i => { srcPhaseMap[i] = p.id; });
    p.outIdx.forEach(i => { outPhaseMap[i] = p.id; });
  });
  return { ...team, srcPhaseMap, outPhaseMap };
});

const phaseStepLabel: Record<string, string> = {
  calls:'Calls', email:'Email', crm:'CRM',
  support:'Tickets', transcripts:'Transcripts', usage:'Usage', issues:'Issues',
};
---

<section id="overview" class="py-24 px-6">
  <div class="max-w-[1200px] mx-auto">

    <div class="text-center mb-12">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Overview</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        One platform for every <span class="gradient-text">customer-facing team</span>
      </h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">See how Starmesh ingests raw conversations, synthesizes intelligence, and delivers structured results to every tool in your stack.</p>
    </div>

    <div class="ov-pills" role="tablist">
      {teams.map((team, i) => (
        <button class={`ov-tab ${i === 0 ? 'active' : ''}`} data-tab={team.id}>{team.label}</button>
      ))}
    </div>

    <div class="ov-board" id="ov-board">
      <div class="ov-dotgrid"></div>

      <svg class="ov-svg" id="ov-svg" xmlns="http://www.w3.org/2000/svg" overflow="visible">
        <defs>
          <linearGradient id="ovLgIn" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#6366F1" stop-opacity="0.15"/>
            <stop offset="100%" stop-color="#6366F1" stop-opacity="0.7"/>
          </linearGradient>
          <linearGradient id="ovLgOut" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#8B5CF6" stop-opacity="0.7"/>
            <stop offset="100%" stop-color="#8B5CF6" stop-opacity="0.15"/>
          </linearGradient>
        </defs>
      </svg>

      {teams.map((team, ti) => (
        <div class={`ov-panel ${ti === 0 ? 'active' : ''}`} data-panel={team.id}>
          <div class="ov-grid">

            <!-- ── LEFT: source cards ── -->
            <div class="ov-src-col">
              {team.sources.map((src, si) => (
                <div class="ov-src-card" data-src-team={team.id} data-src-phase={team.srcPhaseMap[si]}>
                  <div class="ov-src-layout">
                    <div class="ov-src-meta">
                      <span class="ov-logo">
                        <img src={`https://www.google.com/s2/favicons?sz=64&domain=${src.logo}`} alt={src.app} loading="lazy"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
                        <span class="ov-logo-fb">{src.app.slice(0,2).toUpperCase()}</span>
                      </span>
                      <p class="ov-src-type">{src.title}</p>
                    </div>
                    <p class="ov-src-sample">{src.sample}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- ── CENTER: two-stage AI card ── -->
            <div class="ov-ai-col">
              <div class="ov-ai-card">
                <div class="ov-ai-head">
                  <span class="ov-ai-dot"></span>
                  <span class="ov-ai-title">Starmesh AI</span>
                  <span class="ov-ai-badge" id={`badge-${team.id}`}>Waiting</span>
                </div>

                <!-- Stage 1: Ingestion log -->
                <div class="ov-ingest-stage">
                  {team.phases.map((phase) => (
                    <div class="ov-ingest-step" data-team={team.id} data-phase-id={phase.id}>
                      <div class="ov-ingest-head">
                        <span class="ov-ingest-icon"></span>
                        <span class="ov-ingest-src">{phase.srcLabel}</span>
                      </div>
                      <p class="ov-ingest-finding">{phase.finding}</p>
                    </div>
                  ))}
                </div>

                <!-- Stage 2: Synthesized output -->
                <div class="ov-synth-divider" data-team={team.id}>
                  <span class="ov-synth-label">Synthesized insights</span>
                </div>
                <div class="ov-synth-stage">
                  {team.phases.map((phase) => (
                    <div class="ov-synth-group" data-team={team.id} data-phase-id={phase.id}>
                      {phase.rows.map((r, ri) => (
                        <div class="ov-row" data-team={team.id} data-phase={phase.id} data-ri={ri}>
                          <span class="ov-rk">{r.key}</span>
                          <span class={`ov-rv ov-${r.color}`}>{r.val}</span>
                        </div>
                      ))}
                    </div>
                  ))}
                  <div class="ov-conclusion" data-concl-team={team.id}>
                    <span class="ov-concl-icon">✦</span>
                    <p class="ov-concl-text">{team.conclusion}</p>
                  </div>
                </div>

                <div class="ov-ai-alert">
                  <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
                    <circle cx="4" cy="4" r="3" stroke="#F87171" stroke-opacity=".7" stroke-width="1"/>
                    <path d="M4 2v2.5" stroke="#F87171" stroke-width="1" stroke-linecap="round"/>
                  </svg>
                  {team.alert}
                </div>
              </div>
            </div>

            <!-- ── RIGHT: outcome cards (start hidden, revealed per phase) ── -->
            <div class="ov-out-col">
              {team.outcomes.map((out, oi) => (
                <div class="ov-out-card" data-out-team={team.id} data-out-phase={team.outPhaseMap[oi]}>
                  <div class="ov-out-head">
                    <span class="ov-out-icon">{out.icon}</span>
                    <span class="ov-out-name">{out.title}</span>
                    {out.meta && <span class="ov-out-meta">{out.meta}</span>}
                  </div>
                  {out.chart && (
                    <div class="ov-spark">
                      <svg viewBox={`0 0 ${(out.chart.length-1)*20} 48`} preserveAspectRatio="none">
                        <polyline points={out.chart.map((v,i)=>`${i*20},${v}`).join(' ')}/>
                      </svg>
                    </div>
                  )}
                  {out.body && <p class="ov-out-body">{out.body}</p>}
                  {out.chat && (
                    <>
                      <div class="ov-bbl-u">{out.chat.user}</div>
                      <div class="ov-bbl-a">{out.chat.ai}</div>
                    </>
                  )}
                  {out.tl && out.tl.map(row => (
                    <div class="ov-tl">
                      <span class="ov-tl-dot"></span>
                      <span class="ov-tl-d">{row.d}</span>
                      <span class="ov-tl-t">{row.t}</span>
                    </div>
                  ))}
                </div>
              ))}
            </div>

          </div>

          <!-- ── Controls bar ── -->
          <div class="ov-controls" data-ctrl={team.id}>
            <button class="ov-playpause" data-ctrl-team={team.id} aria-label="Toggle animation">
              <svg class="ov-icon-pause" width="9" height="11" viewBox="0 0 9 11" fill="currentColor">
                <rect x="0" y="0" width="3" height="11" rx="1"/>
                <rect x="6" y="0" width="3" height="11" rx="1"/>
              </svg>
              <svg class="ov-icon-play" width="10" height="11" viewBox="0 0 10 11" fill="currentColor">
                <path d="M1 1.2l8 4.3-8 4.3V1.2z"/>
              </svg>
            </button>
            <button class="ov-restart" data-restart-team={team.id} aria-label="Restart animation">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                <path d="M3 3v5h5"/>
              </svg>
            </button>

            <div class="ov-stepper">
              {team.phases.map((phase, pi) => (
                <>
                  <div class="ov-step-item" data-step-team={team.id} data-step-idx={pi}>
                    <div class="ov-step-node">
                      <div class="ov-step-ring"></div>
                      <div class="ov-step-dot"></div>
                    </div>
                    <span class="ov-step-lbl">{phaseStepLabel[phase.id] ?? phase.id}</span>
                  </div>
                  {pi < team.phases.length - 1 && (
                    <div class="ov-step-track" data-track-team={team.id} data-track-idx={pi}></div>
                  )}
                </>
              ))}
            </div>

            <span class="ov-ctrl-status" data-ctrl-status={team.id}>Ready</span>
          </div>

        </div>
      ))}

    </div>

  </div>
</section>

<script>
  // ── Shared state ──
  interface ScheduledTimer { id: ReturnType<typeof setTimeout>; fireAt: number; callback: () => void; }
  const timers:   Record<string, ScheduledTimer[]> = {};
  const isPaused: Record<string, boolean> = {};
  const pausedAt: Record<string, number>  = {};

  function addTimer(teamId: string, cb: () => void, delay: number) {
    const fireAt = Date.now() + delay;
    const id = setTimeout(cb, delay);
    if (!timers[teamId]) timers[teamId] = [];
    timers[teamId].push({ id, fireAt, callback: cb });
  }

  function clearTimers(teamId: string) {
    (timers[teamId] || []).forEach(t => clearTimeout(t.id));
    timers[teamId] = [];
  }

  // ── Tabs ──
  const tabs   = document.querySelectorAll<HTMLElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  function activateTab(id: string) {
    tabs.forEach(t   => t.classList.toggle('active', t.getAttribute('data-tab')   === id));
    panels.forEach(p => p.classList.toggle('active', p.getAttribute('data-panel') === id));
    // Set SVG dimensions for the board
    const board = document.getElementById('ov-board');
    if (board && svg) {
      const br = board.getBoundingClientRect();
      svg.setAttribute('width', String(br.width));
      svg.setAttribute('height', String(br.height));
    }
    // Reset pause state when switching tabs
    isPaused[id] = false;
    document.querySelector<HTMLElement>(`[data-ctrl-team="${id}"]`)?.classList.remove('is-paused');
    restartAnimation(id);
  }

  tabs.forEach(tab => tab.addEventListener('click', () => activateTab(tab.getAttribute('data-tab')!)));

  function applyTeamParam() {
    const teamParam = new URLSearchParams(window.location.search).get('team');
    if (teamParam && Array.from(tabs).some(t => t.getAttribute('data-tab') === teamParam)) {
      activateTab(teamParam);
      requestAnimationFrame(() => {
        const pills = document.querySelector('.ov-pills');
        if (pills) {
          const y = pills.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top: y, behavior: 'smooth' });
        }
      });
    }
  }
  window.addEventListener('popstate', applyTeamParam);

  // ── Timing constants ──
  const INGEST_ACTIVE   = 1200; // ms source stays lit during ingestion
  const FINDING_DELAY   = 700;  // ms after step appears before finding shows
  const STEP_DONE_AFTER = 4000; // ms after step appears before checkmark
  const GAP_STEPS       = 800;  // ms gap between ingestion steps
  const SYNTH_GAP       = 1500; // ms after last ingest step before synthesis begins
  const ROW_DELAY       = 800;  // ms between result rows in synthesis
  const OUT_DELAY       = 900;  // ms after last row before outcome card appears
  const OUT_STAGGER     = 500;  // ms between multiple outcome cards from same phase
  const BETWEEN_GROUPS  = 1200; // ms between synthesis groups
  const CYCLE_PAUSE     = 6000; // ms after all done before reset

  function resetTeamState(teamId: string) {
    // Ingest steps
    document.querySelectorAll<HTMLElement>(`.ov-ingest-step[data-team="${teamId}"]`).forEach(s => {
      s.classList.remove('ingest-active', 'ingest-done');
    });
    document.querySelectorAll<HTMLElement>(`.ov-ingest-finding`).forEach(f => {
      f.classList.remove('finding-vis');
    });
    // Synth divider + groups
    document.querySelectorAll<HTMLElement>(`.ov-synth-divider[data-team="${teamId}"]`).forEach(d => {
      d.classList.remove('synth-vis');
    });
    document.querySelectorAll<HTMLElement>(`.ov-row[data-team="${teamId}"]`).forEach(r => {
      r.classList.remove('vis');
    });
    document.querySelectorAll<HTMLElement>(`.ov-conclusion[data-concl-team="${teamId}"]`).forEach(c => {
      c.classList.remove('concl-vis');
    });
    // Source cards — reset to dim
    document.querySelectorAll<HTMLElement>(`[data-src-team="${teamId}"]`).forEach(c => {
      c.classList.remove('src-active', 'src-done');
      c.classList.add('src-dim');
    });
    // Outcome cards
    document.querySelectorAll<HTMLElement>(`[data-out-team="${teamId}"]`).forEach(c => {
      c.classList.remove('out-lit');
      c.removeAttribute('data-line-drawn');
    });
    // Badge
    const badge = document.getElementById(`badge-${teamId}`);
    if (badge) { badge.textContent = 'Waiting'; badge.className = 'ov-ai-badge'; }
    // Remove all SVG paths
    const svg_ = document.getElementById('ov-svg');
    svg_?.querySelectorAll('.ov-in-path').forEach(el => el.remove());
    svg_?.querySelectorAll('.ov-out-path').forEach(el => el.remove());
    // Step dots + tracks
    document.querySelectorAll<HTMLElement>(`[data-step-team="${teamId}"]`).forEach(s => {
      s.classList.remove('step-active', 'step-done');
    });
    document.querySelectorAll<HTMLElement>(`[data-track-team="${teamId}"]`).forEach(t => {
      t.classList.remove('track-done');
    });
    setCtrlStatus(teamId, 'Starting…');
  }

  function restartAnimation(teamId: string) {
    clearTimers(teamId);
    resetTeamState(teamId);

    const badge = document.getElementById(`badge-${teamId}`);

    const ingestSteps = Array.from(
      document.querySelectorAll<HTMLElement>(`.ov-ingest-step[data-team="${teamId}"]`)
    );

    let t = 400;

    // ── Stage 1: Sequential ingestion ──
    if (badge) addTimer(teamId, () => {
      badge.textContent = 'Processing'; badge.className = 'ov-ai-badge badge-processing';
    }, t);

    ingestSteps.forEach((step, phaseIdx) => {
      const phaseId = step.getAttribute('data-phase-id')!;
      const finding = step.querySelector<HTMLElement>('.ov-ingest-finding');

      // Activate step + source cards + draw input lines for this phase
      addTimer(teamId, () => {
        step.classList.add('ingest-active');
        setStepState(teamId, phaseIdx, 'active');
        setCtrlStatus(teamId, phaseStatusText[phaseId] ?? 'Processing…', 'status-active');
        document.querySelectorAll<HTMLElement>(
          `[data-src-team="${teamId}"][data-src-phase="${phaseId}"]`
        ).forEach(c => { c.classList.remove('src-dim'); c.classList.add('src-active'); });
        drawPhaseInputConnections(teamId, phaseId, step);
      }, t);

      // Show finding text
      addTimer(teamId, () => {
        finding?.classList.add('finding-vis');
      }, t + FINDING_DELAY);

      t += STEP_DONE_AFTER;

      // Mark done + transition sources to done state
      addTimer(teamId, () => {
        step.classList.remove('ingest-active');
        step.classList.add('ingest-done');
        setStepState(teamId, phaseIdx, 'done');
        document.querySelectorAll<HTMLElement>(
          `[data-src-team="${teamId}"][data-src-phase="${phaseId}"]`
        ).forEach(c => { c.classList.remove('src-active'); c.classList.add('src-done'); });
      }, t);

      t += GAP_STEPS;
    });

    // ── Stage 2: Synthesis ──
    t += SYNTH_GAP;

    if (badge) addTimer(teamId, () => {
      badge.textContent = 'Synthesizing'; badge.className = 'ov-ai-badge badge-synth';
      setCtrlStatus(teamId, 'Synthesizing insights…', 'status-synth');
    }, t);

    addTimer(teamId, () => {
      document.querySelector<HTMLElement>(`.ov-synth-divider[data-team="${teamId}"]`)?.classList.add('synth-vis');
    }, t);

    const synthGroups = Array.from(
      document.querySelectorAll<HTMLElement>(`.ov-synth-group[data-team="${teamId}"]`)
    );

    synthGroups.forEach((group) => {
      const phaseId = group.getAttribute('data-phase-id')!;
      const rows    = Array.from(group.querySelectorAll<HTMLElement>('.ov-row'));

      t += 300;

      // Rows appear one by one
      rows.forEach((row, ri) => {
        addTimer(teamId, () => row.classList.add('vis'), t + ri * ROW_DELAY);
      });

      t += rows.length * ROW_DELAY + OUT_DELAY;

      // Outcome cards appear + output connections drawn
      const outCards = Array.from(
        document.querySelectorAll<HTMLElement>(
          `[data-out-team="${teamId}"][data-out-phase="${phaseId}"]`
        )
      );
      outCards.forEach((card, oi) => {
        addTimer(teamId, () => {
          card.classList.add('out-lit');
          drawOutputConnection(card, group);
        }, t + oi * OUT_STAGGER);
      });

      t += outCards.length * OUT_STAGGER + BETWEEN_GROUPS;
    });

    addTimer(teamId, () => {
      document.querySelector<HTMLElement>(`.ov-conclusion[data-concl-team="${teamId}"]`)?.classList.add('concl-vis');
    }, t);

    t += 600;

    addTimer(teamId, () => {
      if (badge) { badge.textContent = 'Live'; badge.className = 'ov-ai-badge'; }
      setCtrlStatus(teamId, 'Analysis complete ✓', 'status-done');
    }, t);

    addTimer(teamId, () => {
      if (!isPaused[teamId]) restartAnimation(teamId);
    }, t + CYCLE_PAUSE);
  }

  // ── SVG connections ──
  const svg = document.getElementById('ov-svg') as SVGSVGElement | null;
  let uid = 0;

  // Input connections: drawn per-phase when that phase activates
  function drawPhaseInputConnections(teamId: string, phaseId: string, step: HTMLElement) {
    if (!svg) return;

    // Skip if already drawn for this phase (prevents duplicates on resume)
    if (svg.querySelector(`[data-in-phase="${teamId}-${phaseId}"]`)) return;

    const board = document.getElementById('ov-board');
    if (!board) return;
    const br  = board.getBoundingClientRect();
    svg.setAttribute('width',  String(br.width));
    svg.setAttribute('height', String(br.height));

    const panel = document.querySelector<HTMLElement>('.ov-panel.active');
    if (!panel) return;

    const aiCard = panel.querySelector<HTMLElement>('.ov-ai-card');
    if (!aiCard) return;
    const ar  = aiCard.getBoundingClientRect();
    const aLX = ar.left - br.left;

    const ir  = step.getBoundingClientRect();
    const y2  = ir.top + ir.height / 2 - br.top;

    const srcs = Array.from(panel.querySelectorAll<HTMLElement>(
      `[data-src-team="${teamId}"][data-src-phase="${phaseId}"]`
    ));
    srcs.forEach((src, i) => {
      const sr = src.getBoundingClientRect();
      const x1 = sr.right - br.left - 4;
      const y1 = sr.top + sr.height / 2 - br.top;
      addPath(x1, y1, aLX + 4, y2, 'ovLgIn', '#6366F1', i * 0.18, 'ov-in-path');
      // Tag so we can guard against redrawing on resume
      svg!.lastElementChild?.setAttribute('data-in-phase', `${teamId}-${phaseId}`);
    });
  }

  // Output connections: AI synth group → outcome card (drawn on demand)
  function drawOutputConnection(outCard: HTMLElement, synthGroup: HTMLElement) {
    // Skip if this card's line was already drawn (prevents duplicates on resume)
    if (outCard.hasAttribute('data-line-drawn')) return;
    outCard.setAttribute('data-line-drawn', '1');

    if (!svg) return;
    const board = document.getElementById('ov-board');
    if (!board) return;
    const br  = board.getBoundingClientRect();

    const panel = document.querySelector<HTMLElement>('.ov-panel.active');
    if (!panel) return;

    const aiCard = panel.querySelector<HTMLElement>('.ov-ai-card');
    if (!aiCard) return;
    const ar  = aiCard.getBoundingClientRect();
    const aRX = ar.right - br.left;

    // Y from synth group center
    const gr  = synthGroup.getBoundingClientRect();
    const y1  = gr.top + gr.height / 2 - br.top;

    const or_ = outCard.getBoundingClientRect();
    const x2  = or_.left  - br.left;
    const y2  = or_.top + or_.height / 2 - br.top;

    addPath(aRX + 4, y1, x2 - 4, y2, 'ovLgOut', '#8B5CF6', Math.random() * 0.3, 'ov-out-path');
  }

  function addPath(x1:number, y1:number, x2:number, y2:number, grad:string, _dotColor:string, _delay:number, cls:string) {
    const mid = (x1 + x2) / 2;
    const d   = `M${x1},${y1} C${mid},${y1} ${mid},${y2} ${x2},${y2}`;
    const g   = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.classList.add('ov-dyn', cls);

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', d);
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke', `url(#${grad})`);
    path.setAttribute('stroke-width', '1.5');
    path.setAttribute('stroke-dasharray', '4 4');
    g.appendChild(path);

    svg!.appendChild(g);
  }

  // ── Play / Pause ──

  const phaseStatusText: Record<string, string> = {
    calls:       'Analyzing calls…',
    email:       'Reading emails…',
    crm:         'Checking CRM records…',
    support:     'Scanning support tickets…',
    transcripts: 'Analyzing transcripts…',
    usage:       'Checking usage data…',
    issues:      'Scanning issue backlog…',
  };

  function setStepState(teamId: string, idx: number, state: 'active' | 'done') {
    const item = document.querySelector<HTMLElement>(
      `[data-step-team="${teamId}"][data-step-idx="${idx}"]`
    );
    if (!item) return;
    item.classList.remove('step-active', 'step-done');
    item.classList.add(`step-${state}`);
    // Light up the connecting track when a step activates or completes
    if (idx > 0) {
      document.querySelector<HTMLElement>(
        `[data-track-team="${teamId}"][data-track-idx="${idx - 1}"]`
      )?.classList.add('track-done');
    }
  }

  function setCtrlStatus(teamId: string, text: string, cls?: string) {
    const el = document.querySelector<HTMLElement>(`[data-ctrl-status="${teamId}"]`);
    if (!el) return;
    el.textContent = text;
    el.className = 'ov-ctrl-status' + (cls ? ` ${cls}` : '');
  }

  function togglePause(teamId: string) {
    const btn = document.querySelector<HTMLElement>(`[data-ctrl-team="${teamId}"]`);
    if (isPaused[teamId]) {
      // ── Resume: re-schedule each remaining callback with its original remaining delay ──
      isPaused[teamId] = false;
      btn?.classList.remove('is-paused');
      const pAt    = pausedAt[teamId] ?? Date.now();
      const entries = [...(timers[teamId] || [])];
      timers[teamId] = [];
      entries.forEach(entry => {
        addTimer(teamId, entry.callback, Math.max(0, entry.fireAt - pAt));
      });
    } else {
      // ── Pause: cancel pending timers but keep their entries so resume can reschedule ──
      isPaused[teamId] = true;
      pausedAt[teamId] = Date.now();
      btn?.classList.add('is-paused');
      (timers[teamId] || []).forEach(t => clearTimeout(t.id));
      // intentionally NOT clearing timers[teamId] — entries are needed for resume
      setCtrlStatus(teamId, 'Paused', 'status-paused');
    }
  }

  document.querySelectorAll<HTMLElement>('[data-ctrl-team]').forEach(btn => {
    btn.addEventListener('click', () => togglePause(btn.getAttribute('data-ctrl-team')!));
  });

  document.querySelectorAll<HTMLElement>('[data-restart-team]').forEach(btn => {
    btn.addEventListener('click', () => {
      const teamId = btn.getAttribute('data-restart-team')!;
      isPaused[teamId] = false;
      document.querySelector<HTMLElement>(`[data-ctrl-team="${teamId}"]`)?.classList.remove('is-paused');
      restartAnimation(teamId);
    });
  });

  window.addEventListener('load', () => {
    const teamParam = new URLSearchParams(window.location.search).get('team');
    const validTeam = teamParam && Array.from(tabs).some(t => t.getAttribute('data-tab') === teamParam);
    if (validTeam) applyTeamParam();
    const initial = document.querySelector<HTMLElement>('.ov-tab.active')?.getAttribute('data-tab') || 'sales';
    setTimeout(() => { activateTab(initial); }, 250);
  });
</script>

