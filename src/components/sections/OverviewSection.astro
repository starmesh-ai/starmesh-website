---
import DealIntelligenceWindow from '../DealIntelligenceWindow.astro';
import WinProbabilityWindow from '../WinProbabilityWindow.astro';
import InteractionTimelineWindow from '../InteractionTimelineWindow.astro';
import CRMSyncWindow from '../CRMSyncWindow.astro';
import DestinationsWindow from '../DestinationsWindow.astro';
const teams = [
  {
    id: 'sales', label: 'Sales',
    aiExplain: {
      extract: 'decision makers, intent, timeline, next steps, risks',
      link: 'signals to the right deal, stakeholders, and pipeline stage',
    },
    aiTip: [
      'Surfaces next steps, risks, and who matters for the deal',
      'Ties every signal to the right opportunity and stage',
      'Explainable so you can trust and defend the output',
    ],
    sources: [
      { app:'Zoom',       logo:'zoom.us',        title:'Call recording',     sample:'Budget is approved but procurement pushed the timeline — new VP Eng needs to sign off first.' },
      { app:'Gong',       logo:'gong.io',         title:'Deal call notes',    sample:'Champion is strong. Security review is the only real blocker right now.' },
      { app:'Gmail',      logo:'mail.google.com', title:'Email thread',       sample:'Before we go to signature, can you confirm your SOC2 controls and migration support?' },
      { app:'Salesforce', logo:'salesforce.com',  title:'Opportunity update', sample:'Stage changed to Commit. Buying committee expanded to include VP Engineering.' },
      // { app:'HubSpot',    logo:'hubspot.com',     title:'Contact activity',   sample:"VP of Engineering added to deal — first question was about data residency." }, // (hidden for spacing)
    ],
    outcomes: [
      { title:'Deal Copilot',     subtitle:'Unlimited deal Q&A and next-best actions', meta:null,                  chat:{user:'What do I need to do before Friday?', ai:"Send SOC2 docs to Sarah today. Get your SE on the security call — that's the only real blocker. Log next steps in Salesforce before EOD or this slips to Q1."} },
      { title:'Deal Forecast',     subtitle:'Predict close likelihood and trend',      meta:'74% · trending down', chart:[20,23,27,31,35,39,42,45], body:'Down 12pts in 2 weeks. Security review still open and next steps are missing. Close the blocker this week or this deal moves to Q1.' },
      { title:'Deal Timeline',    subtitle:'Key moments, blockers, and momentum',     meta:null,                  tl:[
        {d:'Mar 4',t:'No contact for 7 days after security review'},
        {d:'Feb 24',t:'Security objection raised on Zoom call'},
        {d:'Feb 10',t:'VP Eng joined buying committee · asks about data residency and SOC2'},
        {d:'Jan 28',t:'Stage → Commit · next steps still blank in Salesforce'}
      ] },
      { title:'CRM Auto-update',  subtitle:'Auto-log signals and risks to your CRM',  meta:null,                  body:'Win probability, slip risk, security blocker and missing next steps auto-logged to Salesforce & HubSpot.' },
    ],
  },
  {
    id: 'cx', label: 'CX',
    aiExplain: {
      extract: 'sentiment, product issues, escalation severity, renewal risk',
      link: 'signals to the right account, ticket cluster, and renewal window',
    },
    aiTip: [
      'Surfaces churn risk, health signals, and what to do before renewal',
      'Ties every signal to the right account and renewal window',
      'Explainable so you can trust and defend the output',
    ],
    sources: [
      { app:'Intercom', logo:'intercom.com',    title:'Support tickets',  sample:'Export issue repeats after every billing cycle close — third time this quarter.' },
      { app:'Zendesk',  logo:'zendesk.com',     title:'Escalation case',  sample:'P1 raised by enterprise account — webhook retries failing since last deploy.' },
      { app:'Zoom',     logo:'zoom.us',          title:'QBR recording',    sample:'Team is generally happy but onboarding still felt slow and confusing.' },
      { app:'Gmail',    logo:'mail.google.com',  title:'Renewal email',    sample:'We need better visibility into our account health before we can commit to renewal.' },
      // { app:'Slack',    logo:'slack.com',        title:'Customer channel', sample:"Any ETA on the permission bug? It's blocking three of our admin users right now." }, // (hidden for spacing)
    ],
    outcomes: [
      { title:'CSM Copilot',      subtitle:'Unlimited account Q&A and renewal guidance', meta:null,                     chat:{user:'What should I do before this renewal?', ai:"Book an exec call this week — your champion has been cold for 6 weeks. Get engineering to commit on the webhook fix, then lead the renewal with a health roadmap showing what's being fixed."} },
      { title:'Account Health',   subtitle:'Health score and churn risk signals',        meta:'44/100 · falling fast',  chart:[20,22,25,30,38,44,50,54], body:'Down 18pts in 30 days. Two P1s open, champion gone cold, renewal in 47 days. Without intervention this account is on a fast track to churn.' },
      { title:'Account Timeline', subtitle:'Escalations, sentiment, and renewal events', meta:null,                     tl:[
        {d:'Mar 1',t:'No response from champion for 12 days · renewal in 47 days'},
        {d:'Feb 18',t:'P1 opened · webhook failing since deploy · still open'},
        {d:'Feb 4',t:'QBR: NPS down 18pts · onboarding cited as main pain'},
        {d:'Jan 22',t:'Champion Sarah Lee changed roles · new stakeholder not engaged yet'}
      ] },
      { title:'CRM Auto-update',  subtitle:'Sync health and churn risk to your systems', meta:null,                     body:'Health score, open escalations, champion status and churn risk synced to Salesforce & Gainsight.' },
    ],
  },
  {
    id: 'product', label: 'Product',
    aiExplain: {
      extract: 'themes, demand, revenue impact, retention + drop-off drivers',
      link: 'signals to the right feature, segment, and time period',
    },
    aiTip: [
      'Surfaces top themes, revenue impact, and retention drivers',
      'Ties every signal to the right feature and segment',
      'Explainable so you can trust and defend the output',
    ],
    sources: [
      { app:'Gong',     logo:'gong.io',         title:'Call transcripts', sample:'Cohort-level analytics keeps coming up on enterprise calls — heard it three times this week alone.' },
      { app:'Zoom',     logo:'zoom.us',          title:'Customer calls',   sample:'Dashboard clarity was the top pain point in every PM discovery session this quarter.' },
      { app:'Pendo',    logo:'pendo.io',         title:'Usage events',     sample:'Drop-off spikes every time users hit the integration settings screen at step 3.' },
      { app:'Mixpanel', logo:'mixpanel.com',     title:'Behavior cohorts', sample:'Users with two data sources connected retain 2.1× better at 30 days. Single-source users churn fast.' },
      // { app:'Jira',     logo:'atlassian.com',    title:'Issue backlog',    sample:'Permission-related tickets jumped 40% in the two weeks after the last release.' }, // (hidden for spacing)
    ],
    outcomes: [
      { title:'PM Copilot',      subtitle:'Unlimited discovery Q&A and prioritization', meta:null,                          chat:{user:'What should we prioritize this quarter?', ai:"Ship cohort analytics first — #1 requested, \$180K blocked, confirmed by both calls and usage data. Then fix the step 3 drop-off, it's killing retention. Permission bugs are noise compared to those two."} },
      { title:'Feature Demand',  subtitle:'Themes, momentum, and revenue impact',       meta:'8 themes · 3 accelerating',  chart:[44,40,36,31,25,20,16,12], body:'Cohort analytics up 3× in 60 days — 12 enterprise mentions, $180K in deals blocked. Highest-ROI item in your backlog right now.' },
      { title:'Signal Timeline', subtitle:'Voice-of-customer + usage signals over time', meta:null,                         tl:[
        {d:'Mar 3',t:'Cohort analytics on 5 enterprise calls this week · demand accelerating'},
        {d:'Feb 18',t:'34% exit rate at step 3 confirmed in Pendo · no change in 3 weeks'},
        {d:'Feb 2',t:'Permission tickets up 40% after last release'},
        {d:'Jan 20',t:'First spike in "dashboard clarity" mentions in discovery calls'}
      ] },
      { title:'Data Write-back', subtitle:'Export structured insights to your tools',    meta:null,                         body:'Feature scores and revenue impact auto-exported to Snowflake, Jira, and Productboard.' },
    ],
  },
];
---
<section id="overview" class="py-16 md:py-20 px-6">
  <div class="max-w-[1320px] mx-auto">

    <div class="ov-head">
      <div class="ov-head-copy">
        <p class="text-xs text-muted uppercase tracking-widest mb-3">Overview</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
          One platform for every <span class="gradient-text">customer-facing team</span>
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl">
          Conversations in — intelligence out, everywhere you work.
        </p>
      </div>

      <div class="ov-head-tabs">
        <div class="ov-pills" role="tablist" aria-label="Overview teams">
          {teams.map((team, i) => (
            <button class={`ov-tab ${i === 0 ? 'active' : ''}`} data-tab={team.id}>{team.label}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="ov-board" id="ov-board">
      <div class="ov-dotgrid"></div>

      {teams.map((team, ti) => (
        <div class={`ov-panel ${ti === 0 ? 'active' : ''}`} data-panel={team.id}>
          <div class="ov-grid">

            <!-- LEFT: source cards -->
            <div class="ov-src-col">
              <div class="ov-col-head">Sources</div>
              <div class="ov-col-body">
                {team.sources.map((src) => (
                  <div class="ov-src-card">
                    <div class="ov-src-layout">
                      <div class="ov-src-meta">
                        <span class="ov-logo">
                          <img src={`https://www.google.com/s2/favicons?sz=64&domain=${src.logo}`} alt={src.app} loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
                          <span class="ov-logo-fb">{src.app.slice(0,2).toUpperCase()}</span>
                        </span>
                        <p class="ov-src-type">{src.title}</p>
                      </div>
                      <p class="ov-src-sample">{src.sample}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- CENTER: How it works (clear pipeline, benefit-led) -->
            <div class="ov-ai-col">
              <div class="ov-col-head ov-col-head-center">What Starmesh Does</div>
              <div class="ov-engine" data-engine>
                <div class="ov-engine-step ov-engine-step-ingest" data-engine-in>
                  <div class="ov-engine-tip" aria-hidden="true">
                    <p class="ov-tip-title">Ingest</p>
                    <ul>
                      <li>Unify multiple sources into one chronological stream</li>
                      <li>Security &amp; compliance by design</li>
                      <li>Privacy-preserving; you control your data</li>
                    </ul>
                  </div>
                  <div class="ov-engine-step-top">
                    <span class="ov-engine-step-name">Ingest</span>
                    <div class="ov-engine-icons" aria-hidden="true">
                      {team.sources.slice(0, 4).map((src) => (
                        <span class="ov-engine-ico" title={src.app}>
                          <img src={`https://www.google.com/s2/favicons?sz=64&domain=${src.logo}`} alt="" loading="lazy"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
                          <span class="ov-engine-ico-fb">{src.app.slice(0,1).toUpperCase()}</span>
                        </span>
                      ))}
                    </div>
                  </div>
                  <p class="ov-engine-step-desc">All your conversations and CRM activity in one place — secure and under your control.</p>
                </div>
                <div class="ov-engine-connector" aria-hidden="true"><span class="ov-engine-connector-arrow"></span></div>

                <div class="ov-engine-step ov-engine-step-ai" data-engine-in>
                  <div class="ov-engine-tip" aria-hidden="true">
                    <p class="ov-tip-title">Understand</p>
                    <ul>
                      {(team.aiTip ?? ['Extract and link signals to the right record.']).map((line) => (<li>{line}</li>))}
                    </ul>
                  </div>
                  <div class="ov-engine-step-top">
                    <span class="ov-engine-step-name">Understand</span>
                    <span class="ov-engine-step-tag">what matters for you</span>
                  </div>
                  <div class="ov-ai-read" aria-label="AI reading examples">
                    <div class="ov-ai-ind" aria-hidden="true">
                      <span class="ov-ai-dot"></span>
                      AI is reading…
                    </div>
                    {team.sources.slice(0, 4).map((src) => (
                      <div class="ov-ai-snippet" data-full={src.sample}>
                        <div class="ov-ai-sn-head">
                          <span class="ov-ai-sn-app">{src.app}</span>
                          <span class="ov-ai-sn-type">{src.title}</span>
                        </div>
                        <div class="ov-ai-sn-body"></div>
                      </div>
                    ))}
                  </div>
                  <p class="ov-ai-explain-label">For {team.label}:</p>
                  <div class="ov-ai-explain" aria-label="What we extract and link for this team">
                    <div class="ov-ai-ex-row">
                      <span class="ov-ai-ex-k">We find</span>
                      <span class="ov-ai-ex-v">{team.aiExplain?.extract ?? 'key signals and intent'}</span>
                    </div>
                    <div class="ov-ai-ex-row">
                      <span class="ov-ai-ex-k">We tie to</span>
                      <span class="ov-ai-ex-v">{team.aiExplain?.link ?? 'signals to the right record and timeline moment'}</span>
                    </div>
                  </div>
                </div>
                <div class="ov-engine-connector" aria-hidden="true"><span class="ov-engine-connector-arrow"></span></div>

                <div class="ov-engine-step ov-engine-step-out" data-engine-out>
                  <div class="ov-engine-tip" aria-hidden="true">
                    <p class="ov-tip-title">Deliver</p>
                    <ul>
                      <li>Guidance, scores, and timelines in one place</li>
                      <li>Syncs to your CRM and tools automatically</li>
                      <li>No manual logging or copy-paste</li>
                    </ul>
                  </div>
                  <div class="ov-engine-step-top">
                    <span class="ov-engine-step-name">Deliver</span>
                    <span class="ov-engine-step-tag">into your tools</span>
                  </div>
                  <p class="ov-engine-step-desc">Guidance, scores, and timelines — synced to your CRM and stack so you don’t log it yourself.</p>
                </div>
              </div>
            </div>

            <!-- RIGHT: outcome cards -->
            <div class="ov-out-col">
              <div class="ov-col-head ov-col-head-right">Outcomes</div>
              <div class="ov-col-body">
                {team.outcomes.map((out) => (
                  <div class="ov-out-card"
                    data-has-chat={out.chat ? 'true' : undefined}
                    data-window-title={out.chat ? out.title : undefined}
                    data-has-chart={out.chart ? 'true' : undefined}
                    data-has-tl={out.tl ? 'true' : undefined}
                    data-has-crm={out.title === 'CRM Auto-update' ? 'true' : undefined}
                    data-has-dest={out.title === 'Data Write-back' ? 'true' : undefined}>
                    <div class="ov-out-head">
                      <div class="ov-out-titles">
                        <div class="ov-out-titleline">
                          <span class="ov-out-name">{out.title}</span>
                          {out.subtitle && <span class="ov-out-sub">{out.subtitle}</span>}
                        </div>
                      </div>
                      {out.meta && <span class="ov-out-meta">{out.meta}</span>}
                    </div>
                    {out.body && <p class="ov-out-body">{out.body}</p>}
                    {out.chat && (
                      <>
                        <div class="ov-bbl-u">{out.chat.user}</div>
                        <div class="ov-bbl-a">{out.chat.ai}</div>
                      </>
                    )}
                    {out.tl && out.tl.map(row => (
                      <div class="ov-tl">
                        <span class="ov-tl-dot"></span>
                        <span class="ov-tl-d">{row.d}</span>
                        <span class="ov-tl-t">{row.t}</span>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            </div>

          </div>
        </div>
      ))}

      <!-- SVG overlay for connection lines -->
      <svg class="ov-lines" id="ov-lines" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Same gradient/stroke design as Hero.astro -->
          <linearGradient id="ovGin" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#0D9488" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#0D9488" stop-opacity="0.7"/>
          </linearGradient>
          <linearGradient id="ovGout" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#06B6D4" stop-opacity="0.7"/>
            <stop offset="100%" stop-color="#06B6D4" stop-opacity="0.3"/>
          </linearGradient>
          <filter id="ovGlow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="3" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
      </svg>
    </div>

  </div>
</section>

<!-- Tooltip portal: rendered in body, above everything -->
<div id="ov-tooltip-portal" class="ov-tooltip-portal" aria-hidden="true"></div>
<!-- Blur overlay: covers everything except the right section (ov-out-col) -->
<div id="ov-blur-overlay" class="ov-blur-overlay" aria-hidden="true">
  <div id="ov-blur-top" class="ov-blur-panel"></div>
  <div id="ov-blur-left" class="ov-blur-panel"></div>
  <div id="ov-blur-bottom" class="ov-blur-panel"></div>
  <div id="ov-blur-right" class="ov-blur-panel"></div>
</div>
<!-- Copilot window portal: exact Features.astro Deal Intelligence screenshot design -->
<div id="ov-copilot-window-portal" class="ov-copilot-window-portal" aria-hidden="true">
  <div class="ov-copilot-window-item" data-panel="sales">
    <DealIntelligenceWindow
      title="Deal Copilot"
      contextSummary="Stage: Negotiation · Risk: At risk · Deal value: $120K · Expected close: Mar 15"
      firstUserText="Tell me about this deal."
      firstAiText="Acme Corp is in Negotiation with legal and security in the loop. Champion is strong but there's a security objection and VP Eng just joined the committee. Next steps are still blank in Salesforce; close the blocker this week or it slips to Q1."
      userText="What do I need to do before Friday?"
      aiText="Send SOC2 docs to Sarah today. Get your SE on the security call — that's the only real blocker. Log next steps in Salesforce before EOD or this slips to Q1."
      nextQuestion="Who are the key stakeholders on the buying committee?"
    />
  </div>
  <div class="ov-copilot-window-item" data-panel="cx">
    <DealIntelligenceWindow
      title="CSM Copilot"
      contextSummary="Risk: At risk · Renewal in: 47 days · ARR: $85K · Health score: 44/100"
      firstUserText="Tell me about this account."
      firstAiText="Health is falling — two P1s open, champion has been cold for 6 weeks. Renewal in 47 days. Webhook fix and exec re-engagement are the priorities."
      userText="What should I do before this renewal?"
      aiText="Book an exec call this week — your champion has been cold for 6 weeks. Get engineering to commit on the webhook fix, then lead the renewal with a health roadmap showing what's being fixed."
      nextQuestion="What's driving the drop in health score?"
    />
  </div>
  <div class="ov-copilot-window-item" data-panel="product">
    <DealIntelligenceWindow
      title="PM Copilot"
      contextSummary="Quarter: Q1 · Themes: 8 (3 accelerating) · Top ask: cohort analytics"
      firstUserText="Tell me about demand this quarter."
      firstAiText="Cohort analytics is the top theme — $180K blocked, confirmed in calls and usage. Step 3 drop-off is hurting retention; permission bugs are secondary."
      userText="What should we prioritize this quarter?"
      aiText="Ship cohort analytics first — #1 requested, $180K blocked, confirmed by both calls and usage data. Then fix the step 3 drop-off, it's killing retention. Permission bugs are noise compared to those two."
      nextQuestion="Which segment is asking most for cohort analytics?"
    />
  </div>
</div>
<!-- Deal Forecast / Account Health / Feature Demand windows -->
<div id="ov-winprob-portal" class="ov-copilot-window-portal" aria-hidden="true">
  <div class="ov-copilot-window-item" data-panel="sales"><WinProbabilityWindow title="Deal Forecast" variant="deal" /></div>
  <div class="ov-copilot-window-item" data-panel="cx"><WinProbabilityWindow title="Account Health" variant="account" /></div>
  <div class="ov-copilot-window-item" data-panel="product"><WinProbabilityWindow title="Feature Demand" variant="feature" /></div>
</div>
<!-- Deal / Account / Signal Timeline windows -->
<div id="ov-timeline-portal" class="ov-copilot-window-portal" aria-hidden="true">
  <div class="ov-copilot-window-item" data-panel="sales">
    <InteractionTimelineWindow title="Deal Timeline" events={teams[0].outcomes.find(o=>o.tl)?.tl ?? []} />
  </div>
  <div class="ov-copilot-window-item" data-panel="cx">
    <InteractionTimelineWindow title="Account Timeline" events={teams[1].outcomes.find(o=>o.tl)?.tl ?? []} />
  </div>
  <div class="ov-copilot-window-item" data-panel="product">
    <InteractionTimelineWindow title="Signal Timeline" events={teams[2].outcomes.find(o=>o.tl)?.tl ?? []} />
  </div>
</div>
<!-- CRM Auto-update / Salesforce Sync windows (Sales, CX) -->
<div id="ov-crm-portal" class="ov-copilot-window-portal" aria-hidden="true">
  <div class="ov-copilot-window-item" data-panel="sales"><CRMSyncWindow title="CRM Auto-update" /></div>
  <div class="ov-copilot-window-item" data-panel="cx"><CRMSyncWindow title="CRM Auto-update" /></div>
</div>
<!-- Data Write-back / Destinations window (Product) -->
<div id="ov-dest-portal" class="ov-copilot-window-portal" aria-hidden="true">
  <div class="ov-copilot-window-item" data-panel="product"><DestinationsWindow title="Data Write-back" /></div>
</div>

<script>
  const tabs    = document.querySelectorAll<HTMLElement>('[data-tab]');
  const panels  = document.querySelectorAll<HTMLElement>('[data-panel]');
  const svgEl   = document.getElementById('ov-lines') as SVGSVGElement | null;
  const parser  = new DOMParser();

  function drawLines() {
    if (!svgEl) return;
    svgEl.querySelectorAll('.ov-dyn').forEach(el => el.remove());

    const board = document.getElementById('ov-board');
    if (!board) return;
    const br = board.getBoundingClientRect();
    svgEl.setAttribute('width',  String(br.width));
    svgEl.setAttribute('height', String(br.height));

    const panel = document.querySelector<HTMLElement>('.ov-panel.active');
    if (!panel) return;

    const engineIn = panel.querySelector<HTMLElement>('[data-engine-in]');
    const engineOut = panel.querySelector<HTMLElement>('[data-engine-out]');
    if (!engineIn || !engineOut) return;

    const inR = engineIn.getBoundingClientRect();
    const outR = engineOut.getBoundingClientRect();
    const inLX = inR.left - br.left;
    const inCY = inR.top + inR.height / 2 - br.top;
    const outRX = outR.right - br.left;
    const outCY = outR.top + outR.height / 2 - br.top;

    Array.from(panel.querySelectorAll<HTMLElement>('.ov-src-card')).forEach((card, i) => {
      const cr = card.getBoundingClientRect();
      injectLine(
        cr.right - br.left, cr.top + cr.height / 2 - br.top,
        inLX, inCY,
        'url(#ovGin)', '#0D9488', '#2DD4BF', i * 0.4
      );
    });

    Array.from(panel.querySelectorAll<HTMLElement>('.ov-out-card')).forEach((card, i) => {
      const cr = card.getBoundingClientRect();
      injectLine(
        outRX, outCY,
        cr.left - br.left, cr.top + cr.height / 2 - br.top,
        'url(#ovGout)', '#06B6D4', '#22D3EE', i * 0.5
      );
    });
  }

  // Same line design as Hero.astro: dashed path with gradient stroke + animated flow dots with glow
  function injectLine(x1: number, y1: number, x2: number, y2: number,
                      stroke: string, c1: string, c2: string, delay: number) {
    if (!svgEl) return;
    const mid = ((x1 + x2) / 2).toFixed(1);
    const X1 = x1.toFixed(1), Y1 = y1.toFixed(1);
    const X2 = x2.toFixed(1), Y2 = y2.toFixed(1);
    const d  = `M${X1},${Y1} C${mid},${Y1} ${mid},${Y2} ${X2},${Y2}`;
    const b1 = delay.toFixed(2);
    const b2 = (delay + 0.3).toFixed(2);

    const doc = parser.parseFromString(`<svg xmlns="http://www.w3.org/2000/svg">
      <g class="ov-dyn">
        <path d="${d}" fill="none" stroke="${stroke}" stroke-width="1.5" stroke-dasharray="5 5"/>
        <circle r="3.5" fill="${c1}" filter="url(#ovGlow)">
          <animateMotion dur="3.6s" repeatCount="indefinite" begin="${b1}s" path="${d}"/>
        </circle>
        <circle r="2.5" fill="${c2}" opacity="0.6">
          <animateMotion dur="3.6s" repeatCount="indefinite" begin="${b2}s" path="${d}"/>
        </circle>
      </g>
    </svg>`, 'image/svg+xml');

    const g = doc.documentElement.firstElementChild;
    if (g) svgEl.appendChild(document.adoptNode(g));
  }

  function injectVerticalLine(x: number, y1: number, y2: number,
                              stroke: string, c1: string, c2: string, delay: number) {
    if (!svgEl) return;
    const X = x.toFixed(1);
    const Y1 = y1.toFixed(1);
    const Y2 = y2.toFixed(1);
    const d = `M${X},${Y1} L${X},${Y2}`;
    const b1 = delay.toFixed(2);
    const b2 = (delay + 0.3).toFixed(2);

    const doc = parser.parseFromString(`<svg xmlns="http://www.w3.org/2000/svg">
      <g class="ov-dyn">
        <path d="${d}" fill="none" stroke="${stroke}" stroke-width="1.5" stroke-dasharray="5 5"/>
        <circle r="3.5" fill="${c1}" filter="url(#ovGlow)">
          <animateMotion dur="3.6s" repeatCount="indefinite" begin="${b1}s" path="${d}"/>
        </circle>
        <circle r="2.5" fill="${c2}" opacity="0.6">
          <animateMotion dur="3.6s" repeatCount="indefinite" begin="${b2}s" path="${d}"/>
        </circle>
      </g>
    </svg>`, 'image/svg+xml');

    const g = doc.documentElement.firstElementChild;
    if (g) svgEl.appendChild(document.adoptNode(g));
  }

  function activateTab(id: string) {
    tabs.forEach(t   => t.classList.toggle('active', t.dataset.tab   === id));
    panels.forEach(p => p.classList.toggle('active', p.dataset.panel === id));
    setTimeout(drawLines, 20);
    setTimeout(() => startAiTypingForActivePanel(), 40);
  }

  tabs.forEach(tab => tab.addEventListener('click', () => activateTab(tab.dataset.tab!)));
  window.addEventListener('resize', drawLines);
  setTimeout(drawLines, 100);
  setTimeout(() => startAiTypingForActivePanel(), 120);

  let aiTypingAbort: AbortController | null = null;

  function sleep(ms: number) {
    return new Promise<void>(resolve => setTimeout(resolve, ms));
  }

  function prefersReducedMotion() {
    return window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  async function typeInto(el: HTMLElement, text: string, signal: AbortSignal, cps = 26) {
    el.textContent = '';
    const step = Math.max(8, Math.floor(1000 / cps));
    for (let i = 0; i < text.length; i++) {
      if (signal.aborted) return;
      el.textContent += text[i];
      // slight jitter so it feels organic but restrained
      if (i % 1 === 0) await sleep(step);
    }
  }

  async function runAiTyping(panel: HTMLElement, signal: AbortSignal) {
    const readBox = panel.querySelector<HTMLElement>('.ov-ai-read');
    if (!readBox) return;
    const snippets = Array.from(readBox.querySelectorAll<HTMLElement>('.ov-ai-snippet'));
    if (!snippets.length) return;

    // Ensure we always have some text if JS runs after Astro hydration.
    snippets.forEach(s => {
      const body = s.querySelector<HTMLElement>('.ov-ai-sn-body');
      if (body && !body.dataset.full) {
        body.dataset.full = s.getAttribute('data-full') || '';
      }
    });

    let idx = 0;
    while (!signal.aborted) {
      const sn = snippets[idx % snippets.length];
      snippets.forEach(x => x.classList.remove('ov-ai-active', 'ov-ai-typing'));
      sn.classList.add('ov-ai-active', 'ov-ai-typing');

      const body = sn.querySelector<HTMLElement>('.ov-ai-sn-body');
      const full = (sn.getAttribute('data-full') || '').trim();
      if (body) {
        await typeInto(body, full, signal, 26);
      }
      if (signal.aborted) return;

      sn.classList.remove('ov-ai-typing');
      await sleep(520);

      await sleep(1400);
      idx++;
    }
  }

  function escapeHtml(s: string) {
    return s.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#039;');
  }

  function startAiTypingForActivePanel() {
    if (prefersReducedMotion()) return;
    const panel = document.querySelector<HTMLElement>('.ov-panel.active');
    if (!panel) return;
    const readBox = panel.querySelector('.ov-ai-read');
    if (!readBox) return;

    aiTypingAbort?.abort();
    aiTypingAbort = new AbortController();
    runAiTyping(panel, aiTypingAbort.signal).catch(() => {});
  }

  // Tooltip portal: move to body so it renders above SVG/bubbles
  const portal = document.getElementById('ov-tooltip-portal');
  if (portal && portal.parentElement !== document.body) {
    document.body.appendChild(portal);
  }

  // Copilot window portal: move to body, show Starmesh · Deal Intelligence style on hover
  const copilotPortal = document.getElementById('ov-copilot-window-portal');
  if (copilotPortal && copilotPortal.parentElement !== document.body) {
    document.body.appendChild(copilotPortal);
  }
  const winprobPortal = document.getElementById('ov-winprob-portal');
  if (winprobPortal && winprobPortal.parentElement !== document.body) {
    document.body.appendChild(winprobPortal);
  }
  const timelinePortal = document.getElementById('ov-timeline-portal');
  if (timelinePortal && timelinePortal.parentElement !== document.body) {
    document.body.appendChild(timelinePortal);
  }
  const crmPortal = document.getElementById('ov-crm-portal');
  if (crmPortal && crmPortal.parentElement !== document.body) {
    document.body.appendChild(crmPortal);
  }
  const destPortal = document.getElementById('ov-dest-portal');
  if (destPortal && destPortal.parentElement !== document.body) {
    document.body.appendChild(destPortal);
  }
  const blurOverlay = document.getElementById('ov-blur-overlay');
  if (blurOverlay && blurOverlay.parentElement !== document.body) {
    document.body.appendChild(blurOverlay);
  }

  function showWindowForCard(card: HTMLElement, portal: HTMLElement | null) {
    if (!portal) return;
    const panel = card.closest<HTMLElement>('[data-panel]');
    const panelId = panel?.getAttribute('data-panel') || 'sales';
    const windowItem = portal.querySelector<HTMLElement>(`[data-panel="${panelId}"]`);
    if (!windowItem) return;
    // Blur overlay: set panel positions then show (sync, no rAF — avoids lag)
    if (blurOverlay) {
      const outCol = panel?.querySelector<HTMLElement>('.ov-out-col');
      if (outCol) {
        const r = outCol.getBoundingClientRect();
        const topEl = document.getElementById('ov-blur-top');
        const leftEl = document.getElementById('ov-blur-left');
        const bottomEl = document.getElementById('ov-blur-bottom');
        const rightEl = document.getElementById('ov-blur-right');
        if (topEl) { topEl.style.top = '0'; topEl.style.left = '0'; topEl.style.right = '0'; topEl.style.height = `${r.top}px`; }
        if (leftEl) { leftEl.style.top = `${r.top}px`; leftEl.style.left = '0'; leftEl.style.width = `${r.left}px`; leftEl.style.height = `${r.height}px`; }
        if (bottomEl) { bottomEl.style.top = `${r.bottom}px`; bottomEl.style.left = '0'; bottomEl.style.right = '0'; bottomEl.style.bottom = '0'; }
        if (rightEl) { rightEl.style.top = `${r.top}px`; rightEl.style.left = `${r.right}px`; rightEl.style.right = '0'; rightEl.style.height = `${r.height}px`; }
      }
      blurOverlay.classList.add('ov-blur-overlay-visible');
      blurOverlay.setAttribute('aria-hidden', 'false');
    }
    portal.classList.add('ov-copilot-window-visible');
    portal.setAttribute('aria-hidden', 'false');
    windowItem.classList.add('ov-copilot-window-active');
    requestAnimationFrame(() => {
      const cr = card.getBoundingClientRect();
      const wr = windowItem.getBoundingClientRect();
      const gap = 12;
      let left = cr.right + gap;
      if (left + wr.width > window.innerWidth - 16) left = cr.left - wr.width - gap;
      if (left < 16) left = 16;
      let top = cr.top + cr.height / 2 - wr.height / 2;
      if (top < 16) top = 16;
      if (top + wr.height > window.innerHeight - 16) top = window.innerHeight - wr.height - 16;
      windowItem.style.left = `${left}px`;
      windowItem.style.top = `${top}px`;
    });
  }

  function hideWindow(portal: HTMLElement | null) {
    if (!portal) return;
    portal.querySelectorAll('.ov-copilot-window-active').forEach(el => el.classList.remove('ov-copilot-window-active'));
    portal.classList.remove('ov-copilot-window-visible');
    portal.setAttribute('aria-hidden', 'true');
    blurOverlay?.classList.remove('ov-blur-overlay-visible');
    blurOverlay?.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll<HTMLElement>('.ov-out-card[data-has-chat="true"]').forEach((card) => {
    card.addEventListener('mouseenter', () => showWindowForCard(card, copilotPortal));
    card.addEventListener('mouseleave', () => hideWindow(copilotPortal));
  });

  document.querySelectorAll<HTMLElement>('.ov-out-card[data-has-chart="true"]').forEach((card) => {
    card.addEventListener('mouseenter', () => showWindowForCard(card, winprobPortal));
    card.addEventListener('mouseleave', () => hideWindow(winprobPortal));
  });

  document.querySelectorAll<HTMLElement>('.ov-out-card[data-has-tl="true"]').forEach((card) => {
    card.addEventListener('mouseenter', () => showWindowForCard(card, timelinePortal));
    card.addEventListener('mouseleave', () => hideWindow(timelinePortal));
  });

  document.querySelectorAll<HTMLElement>('.ov-out-card[data-has-crm="true"]').forEach((card) => {
    card.addEventListener('mouseenter', () => showWindowForCard(card, crmPortal));
    card.addEventListener('mouseleave', () => hideWindow(crmPortal));
  });

  document.querySelectorAll<HTMLElement>('.ov-out-card[data-has-dest="true"]').forEach((card) => {
    card.addEventListener('mouseenter', () => showWindowForCard(card, destPortal));
    card.addEventListener('mouseleave', () => hideWindow(destPortal));
  });

  document.querySelectorAll<HTMLElement>('.ov-engine-step').forEach((step) => {
    const tip = step.querySelector<HTMLElement>('.ov-engine-tip');
    if (!tip || !portal) return;

    step.addEventListener('mouseenter', () => {
      portal.innerHTML = tip.innerHTML;
      portal.classList.remove('ov-tip-right');
      portal.classList.add('ov-tooltip-portal-visible');
      portal.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        const sr = step.getBoundingClientRect();
        const pr = portal.getBoundingClientRect();
        const gap = 14;
        let left = sr.right + gap;
        if (left + pr.width > window.innerWidth - 16) left = sr.left - pr.width - gap;
        if (left < 16) left = 16;
        portal.style.left = `${left}px`;
        portal.style.right = 'auto';
        let top = sr.top + sr.height / 2 - pr.height / 2;
        if (top < 16) top = 16;
        if (top + pr.height > window.innerHeight - 16) top = window.innerHeight - pr.height - 16;
        portal.style.top = `${top}px`;
      });
    });

    step.addEventListener('mouseleave', () => {
      portal.classList.remove('ov-tooltip-portal-visible');
      portal.setAttribute('aria-hidden', 'true');
    });
  });

  const teamParam = new URLSearchParams(window.location.search).get('team');
  if (teamParam && [...tabs].some(t => t.dataset.tab === teamParam)) {
    activateTab(teamParam);
    requestAnimationFrame(() => {
      const pills = document.querySelector('.ov-pills');
      if (pills) window.scrollTo({ top: pills.getBoundingClientRect().top + scrollY - 80, behavior: 'smooth' });
    });
  }
</script>

