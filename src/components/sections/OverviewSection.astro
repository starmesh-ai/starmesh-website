---

<section id="overview" class="py-24 px-6">
  <div class="max-w-[1200px] mx-auto">

    <div class="text-center mb-12">
      <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Overview</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        One platform for every <span class="gradient-text">customer-facing team</span>
      </h2>
      <p class="text-[#A1A1AA] text-lg max-w-2xl mx-auto">See how Starmesh turns raw conversations into structured intelligence — for Sales, RevOps, CX, and leadership.</p>
    </div>

    <div class="ov-pills" role="tablist">
      {teams.map((team, i) => (
        <button class={`ov-tab ${i === 0 ? 'active' : ''}`} data-tab={team.id}>{team.label}</button>
      ))}
    </div>

    <div class="ov-board" id="ov-board">
      <div class="ov-dotgrid"></div>

      <!-- SVG overlay for animated connection lines -->
      <svg class="ov-svg" id="ov-svg" xmlns="http://www.w3.org/2000/svg" overflow="visible">
        <defs>
          <linearGradient id="ovLgIn" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#6366F1" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#6366F1" stop-opacity="0.75"/>
          </linearGradient>
          <linearGradient id="ovLgOut" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#8B5CF6" stop-opacity="0.75"/>
            <stop offset="100%" stop-color="#8B5CF6" stop-opacity="0.18"/>
          </linearGradient>
          <filter id="ovGlow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="2.5" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
      </svg>

      {teams.map((team, ti) => (
        <div class={`ov-panel ${ti === 0 ? 'active' : ''}`} data-panel={team.id}>
          <div class="ov-grid">

            <!-- ── LEFT: source cards ── -->
            <div class="ov-src-col">
              {team.sources.map(src => (
                <div class="ov-src-card">
                  <div class="ov-src-layout">
                    <div class="ov-src-meta">
                      <span class="ov-logo">
                        <img src={`https://www.google.com/s2/favicons?sz=64&domain=${src.logo}`} alt={src.app} loading="lazy"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"/>
                        <span class="ov-logo-fb">{src.app.slice(0,2).toUpperCase()}</span>
                      </span>
                      <p class="ov-src-type">{src.title}</p>
                    </div>
                    <p class="ov-src-sample">{src.sample}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- ── CENTER: real-time AI analysis card ── -->
            <div class="ov-ai-col">
              <div class="ov-ai-card">
                <div class="ov-ai-head">
                  <span class="ov-ai-dot"></span>
                  <span class="ov-ai-title">Starmesh AI · Analyzing</span>
                  <span class="ov-ai-badge">Live</span>
                </div>

                <!-- Analysis steps -->
                <div class="ov-steps-area">
                  {team.steps.map((step, si) => (
                    <div class="ov-step" data-team={team.id} data-si={si}>
                      <span class="ov-step-icon"></span>
                      <span class="ov-step-lbl">{step}</span>
                    </div>
                  ))}
                </div>

                <!-- Result rows -->
                <div class="ov-rows-area">
                  <div class="ov-rows-label">Results</div>
                  {team.rows.map((r, ri) => (
                    <div class="ov-row" data-team={team.id} data-ri={ri}>
                      <span class="ov-rk">{r.key}</span>
                      <span class={`ov-rv ov-${r.color}`}>{r.val}</span>
                    </div>
                  ))}
                </div>

                <!-- Alert -->
                <div class="ov-ai-alert">
                  <svg width="8" height="8" viewBox="0 0 8 8" fill="none">
                    <circle cx="4" cy="4" r="3" stroke="#F87171" stroke-opacity=".7" stroke-width="1"/>
                    <path d="M4 2v2.5" stroke="#F87171" stroke-width="1" stroke-linecap="round"/>
                  </svg>
                  {team.alert}
                </div>
              </div>
            </div>

            <!-- ── RIGHT: outcome cards ── -->
            <div class="ov-out-col">
              {team.outcomes.map(out => (
                <div class="ov-out-card">
                  <div class="ov-out-head">
                    <span class="ov-out-icon">{out.icon}</span>
                    <span class="ov-out-name">{out.title}</span>
                    {out.meta && <span class="ov-out-meta">{out.meta}</span>}
                  </div>
                  {out.chart && (
                    <div class="ov-spark">
                      <svg viewBox={`0 0 ${(out.chart.length-1)*20} 48`} preserveAspectRatio="none">
                        <polyline points={out.chart.map((v,i)=>`${i*20},${v}`).join(' ')}/>
                      </svg>
                    </div>
                  )}
                  {out.body && <p class="ov-out-body">{out.body}</p>}
                  {out.chat && (
                    <>
                      <div class="ov-bbl-u">{out.chat.user}</div>
                      <div class="ov-bbl-a">{out.chat.ai}</div>
                    </>
                  )}
                  {out.tl && out.tl.map(row => (
                    <div class="ov-tl">
                      <span class="ov-tl-dot"></span>
                      <span class="ov-tl-d">{row.d}</span>
                      <span class="ov-tl-t">{row.t}</span>
                    </div>
                  ))}
                </div>
              ))}
            </div>

          </div>
        </div>
      ))}

      <!-- Bottom status bar -->
      <div class="ov-statusbar">
        <span class="ov-status-live">
          <span class="ov-status-dot"></span>
          Pipeline active
        </span>
        <span class="ov-status-sep">|</span>
        <span>2,841 conversations processed today</span>
        <span class="ov-status-right">Salesforce · HubSpot · Snowflake · BigQuery</span>
      </div>
    </div>

  </div>
</section>

<script>
  // ── Tab switching ──
  const tabs   = document.querySelectorAll<HTMLElement>('[data-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  function activateTab(id: string) {
    tabs.forEach(t   => t.classList.toggle('active', t.getAttribute('data-tab')   === id));
    panels.forEach(p => p.classList.toggle('active', p.getAttribute('data-panel') === id));
    restartAnimation(id);
    requestAnimationFrame(() => requestAnimationFrame(drawConnections));
  }

  tabs.forEach(tab => tab.addEventListener('click', () => activateTab(tab.getAttribute('data-tab')!)));

  // Handle ?team= URL param (from navbar links like /?team=sales#overview)
  function applyTeamParam() {
    const teamParam = new URLSearchParams(window.location.search).get('team');
    if (teamParam && Array.from(tabs).some(t => t.getAttribute('data-tab') === teamParam)) {
      activateTab(teamParam);
      requestAnimationFrame(() =>
        document.getElementById('overview')?.scrollIntoView({ behavior: 'smooth', block: 'start' })
      );
    }
  }

  // Also handle navbar clicks on the same page (popstate / same-origin navigation)
  window.addEventListener('popstate', applyTeamParam);

  // ── Real-time step animation ──
  const STEP_DUR    = 920;   // ms each step stays "active"
  const ROW_DELAY   = 270;   // ms between result rows
  const CYCLE_PAUSE = 2400;  // ms pause after all rows shown before reset
  const timers: Record<string, ReturnType<typeof setTimeout>[]> = {};

  function restartAnimation(teamId: string) {
    (timers[teamId] || []).forEach(t => clearTimeout(t));
    timers[teamId] = [];

    document.querySelectorAll<HTMLElement>(`.ov-step[data-team="${teamId}"]`).forEach(s => {
      s.classList.remove('step-active', 'step-done');
    });
    document.querySelectorAll<HTMLElement>(`.ov-row[data-team="${teamId}"]`).forEach(r => {
      r.classList.remove('vis');
    });

    const steps = Array.from(document.querySelectorAll<HTMLElement>(`.ov-step[data-team="${teamId}"]`));
    const rows  = Array.from(document.querySelectorAll<HTMLElement>(`.ov-row[data-team="${teamId}"]`));

    let t = 300;

    // Animate steps sequentially
    steps.forEach((step) => {
      timers[teamId].push(setTimeout(() => step.classList.add('step-active'), t));
      t += STEP_DUR;
      timers[teamId].push(setTimeout(() => {
        step.classList.remove('step-active');
        step.classList.add('step-done');
      }, t));
    });

    // Animate result rows after all steps complete
    rows.forEach((row, ri) => {
      timers[teamId].push(setTimeout(() => row.classList.add('vis'), t + ri * ROW_DELAY));
    });

    // Schedule loop
    const total = t + rows.length * ROW_DELAY + CYCLE_PAUSE;
    timers[teamId].push(setTimeout(() => restartAnimation(teamId), total));
  }

  // ── SVG connection paths (Hero-style fan-in / fan-out) ──
  const svg = document.getElementById('ov-svg') as SVGSVGElement | null;
  let uid = 0;

  function drawConnections() {
    if (!svg) return;
    svg.querySelectorAll('.ov-dyn').forEach(el => el.remove());

    const board = document.getElementById('ov-board');
    if (!board) return;
    const br = board.getBoundingClientRect();
    svg.setAttribute('width',  String(br.width));
    svg.setAttribute('height', String(br.height));

    const panel = document.querySelector<HTMLElement>('.ov-panel.active');
    if (!panel) return;

    const aiCard = panel.querySelector<HTMLElement>('.ov-ai-card');
    if (!aiCard) return;
    const ar = aiCard.getBoundingClientRect();
    const aiLeft  = ar.left  - br.left;
    const aiRight = ar.right - br.left;
    const aiTop   = ar.top   - br.top;
    const aiH     = ar.height;

    const sources  = Array.from(panel.querySelectorAll<HTMLElement>('.ov-src-card'));
    const outcomes = Array.from(panel.querySelectorAll<HTMLElement>('.ov-out-card'));

    // Source card right edge → AI card left edge (fan in)
    sources.forEach((src, i) => {
      const sr = src.getBoundingClientRect();
      const x1 = sr.right - br.left;
      const y1 = sr.top + sr.height / 2 - br.top;
      const frac = (i + 0.5) / sources.length;
      const y2 = aiTop + aiH * frac;
      addPath(x1, y1, aiLeft, y2, 'ovLgIn', '#6366F1', i * 0.18);
    });

    // AI card right edge → outcome card left edge (fan out)
    outcomes.forEach((out, i) => {
      const or_ = out.getBoundingClientRect();
      const x2  = or_.left  - br.left;
      const y2  = or_.top + or_.height / 2 - br.top;
      const frac = (i + 0.5) / outcomes.length;
      const y1  = aiTop + aiH * frac;
      addPath(aiRight, y1, x2, y2, 'ovLgOut', '#8B5CF6', i * 0.18 + 0.35);
    });
  }

  function addPath(x1:number, y1:number, x2:number, y2:number, grad:string, dotColor:string, delay:number) {
    const mid = (x1 + x2) / 2;
    const d   = `M${x1},${y1} C${mid},${y1} ${mid},${y2} ${x2},${y2}`;
    const g   = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.classList.add('ov-dyn');

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', d);
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke', `url(#${grad})`);
    path.setAttribute('stroke-width', '1.5');
    path.setAttribute('stroke-dasharray', '5 5');
    const pid = `ovp${uid++}`;
    path.setAttribute('id', pid);
    g.appendChild(path);

    // Two waves of animated dots per path
    [0, 1.15].forEach((extra, wi) => {
      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('r', wi === 0 ? '3.5' : '2.5');
      dot.setAttribute('fill', dotColor);
      dot.setAttribute('filter', 'url(#ovGlow)');
      dot.setAttribute('opacity', wi === 0 ? '0.9' : '0.5');
      const am = document.createElementNS('http://www.w3.org/2000/svg', 'animateMotion');
      am.setAttribute('dur', '2.2s');
      am.setAttribute('repeatCount', 'indefinite');
      am.setAttribute('begin', `${delay + extra}s`);
      const mp = document.createElementNS('http://www.w3.org/2000/svg', 'mpath');
      mp.setAttributeNS('http://www.w3.org/1999/xlink', 'href', `#${pid}`);
      am.appendChild(mp);
      dot.appendChild(am);
      g.appendChild(dot);
    });

    svg!.appendChild(g);
  }

  // Init on load
  window.addEventListener('load', () => {
    // Check for ?team= param first, then fall back to default active tab
    const teamParam = new URLSearchParams(window.location.search).get('team');
    const validTeam = teamParam && Array.from(tabs).some(t => t.getAttribute('data-tab') === teamParam);
    if (validTeam) {
      applyTeamParam();
    }
    const initial = document.querySelector<HTMLElement>('.ov-tab.active')?.getAttribute('data-tab') || 'sales';
    setTimeout(() => {
      restartAnimation(initial);
      drawConnections();
    }, 250);
  });
  window.addEventListener('resize', drawConnections);
</script>

<style>
  /* ── Pills / tabs ── */
  .ov-pills { display:flex; gap:.25rem; background:rgba(255,255,255,.03); border-radius:.7rem; padding:.2rem; width:fit-content; margin:0 auto 1.75rem; }
  .ov-tab { border-radius:.5rem; border:1px solid transparent; padding:.35rem 1.1rem; background:transparent; color:#A1A1AA; font-weight:600; font-size:.875rem; cursor:pointer; transition:all .18s ease; }
  .ov-tab.active { background:rgba(139,92,246,.22); color:#f4f2ff; box-shadow:0 4px 14px rgba(139,92,246,.25); border-color:rgba(139,92,246,.25); }
  .ov-tab:hover:not(.active) { background:rgba(139,92,246,.08); color:#E4E4E7; }

  /* ── Board ── */
  .ov-board { position:relative; border-radius:1.25rem; border:1px solid rgba(255,255,255,.07); background:#0a0a0d; overflow:hidden; box-shadow:0 0 80px rgba(99,102,241,.06), inset 0 1px 0 rgba(255,255,255,.04); }
  .ov-dotgrid { position:absolute; inset:0; pointer-events:none; background-image:radial-gradient(rgba(255,255,255,.022) 1px,transparent 1px); background-size:22px 22px; }
  .ov-svg { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; overflow:visible; }

  /* ── Panel ── */
  .ov-panel { display:none; }
  .ov-panel.active { display:block; animation:ovFade .22s ease; }
  @keyframes ovFade { from{opacity:0} to{opacity:1} }

  /* ── 3-column grid ── */
  .ov-grid { display:grid; grid-template-columns:1fr 0.85fr 0.85fr; position:relative; z-index:1; min-height:490px; }

  /* ── LEFT: source cards ── */
  .ov-src-col { padding:18px 8px 18px 18px; display:flex; flex-direction:column; gap:6px; }
  .ov-src-card {
    padding:9px 10px; border-radius:9px;
    border:1px solid rgba(255,255,255,.08); background:rgba(255,255,255,.025);
  }
  .ov-src-layout { display:grid; grid-template-columns:28% 72%; gap:8px; align-items:center; }
  .ov-src-meta { display:flex; flex-direction:column; align-items:flex-start; gap:4px; }
  .ov-logo { width:34px; height:34px; border-radius:6px; background:#fff; overflow:hidden; flex-shrink:0; display:flex; align-items:center; justify-content:center; padding:3px; box-sizing:border-box; }
  .ov-logo img { width:100%; height:100%; object-fit:contain; display:block; }
  .ov-logo-fb { display:none; font-size:.6rem; font-weight:800; color:#fff; background:#7c3aed; width:100%; height:100%; align-items:center; justify-content:center; border-radius:4px; }
  .ov-src-type { font-size:.65rem; color:#a8a2d8; margin:0; line-height:1.25; }
  .ov-src-sample { font-size:.71rem; color:#d4cef5; line-height:1.45; margin:0; }

  /* ── CENTER: AI analysis card ── */
  .ov-ai-col { padding:18px 28px; display:flex; align-items:stretch; }
  .ov-ai-card {
    flex:1; border-radius:9px; background:#0f0f12;
    border:1px solid rgba(99,102,241,.45);
    box-shadow:0 0 28px rgba(99,102,241,.12), inset 0 1px 0 rgba(255,255,255,.04);
    display:flex; flex-direction:column; overflow:hidden;
  }
  .ov-ai-head {
    display:flex; align-items:center; gap:6px; padding:8px 10px;
    background:#111118; border-bottom:1px solid rgba(99,102,241,.2); flex-shrink:0;
  }
  .ov-ai-dot { width:6px; height:6px; border-radius:50%; background:#34D399; flex-shrink:0; animation:aiPulse 2s ease-in-out infinite; }
  @keyframes aiPulse { 0%,100%{box-shadow:0 0 0 0 rgba(52,211,153,.4)} 50%{box-shadow:0 0 0 4px rgba(52,211,153,0)} }
  .ov-ai-title { font-size:.68rem; font-weight:600; color:#A1A1AA; flex:1; }
