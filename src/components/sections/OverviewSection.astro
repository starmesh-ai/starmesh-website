    width:28px;
    height:28px;
    border-radius:6px;
    background:#fff;
    border:1px solid rgba(15,23,42,.12);
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }
  .ov-src-more-ico img {
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
  }
  .ov-src-more-fb {
    display:none;
    font-size:.55rem;
    font-weight:700;
    color:#fff;
  }
  .ov-src-more-link {
    display:flex;
    align-items:center;
    gap:4px;
    font-size:.7rem;
    font-weight:600;
    color:rgba(165,180,252,.9);
    text-decoration:none;
    white-space:nowrap;
    transition:color .2s ease;
  }
  .ov-src-more-link:hover {
    color:#fff;
  }
  .ov-src-more-link svg {
    transition:transform .2s ease;
  }
  .ov-src-more-link:hover svg {
    transform:translateX(2px);
  }

  /* CENTER */
  .ov-ai-col { padding:0; display:flex; flex-direction:column; align-items:stretch; }
  .ov-ai-col > .ov-col-head,
  .ov-ai-col > .ov-engine {
    width:min(360px, 100%);
    margin-left:auto;
    margin-right:auto;
  }
  .ov-engine { flex:1; display:flex; flex-direction:column; justify-content:center; gap:16px; padding:8px 10px 16px; }
  /* Signals middle section (What Starmesh Does) */
  .ov-engine-signals { gap:20px; padding:12px 14px 16px; align-items:center; }
  /* 1. Signals — stars image at centre, Signals + list to the right; pushed down slightly */
  .ov-signals {
    display:grid;
    /* Slight left bias so the centered logo + signals feel optically centered */
    grid-template-columns: 0.88fr auto 1.12fr;
    align-items:center;
    column-gap:20px;
    padding:0;
    width:100%;
    margin-top:12px;
    justify-content:center;
  }
  .ov-signals-left {
    display:block;
    min-width:0;
  }
  .ov-signals-logo-wrapper {
    position:relative;
    flex-shrink:0;
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:2;
    padding:12px 10px;
    width: clamp(88px, 9vw, 100px);
  }
  .ov-signals-logo-inner {
    display:flex;
    flex-direction:column;
    align-items:center;
    position:relative;
    z-index:2;
    width: 100%;
    transform: translateX(-10px);
  }
  .ov-signals-logo {
    width:100%;
    max-width:100px;
    height:auto;
    object-fit:contain;
    filter:drop-shadow(0 0 24px rgba(99,102,241,.6)) drop-shadow(0 0 12px rgba(255,255,255,.2));
  }
  .ov-signals-stars {
    position:absolute;
    top:-18px;
    right:-4px;
    width:42px;
    height:42px;
    object-fit:contain;
    /* Match the logo color (white) */
    filter: brightness(0) invert(1) drop-shadow(0 0 10px rgba(255,255,255,.22));
    opacity:1;
    z-index:3;
    animation:none;
  }
  .ov-signals-content {
    grid-column:3;
    min-width:0;
    display:flex;
    flex-direction:column;
    gap:10px;
    justify-self:start;
  }
  .ov-signals-label {
    font-weight:800;
    font-size:1.05rem;
    letter-spacing:-.03em;
    color:rgba(255,255,255,.96);
    line-height:1.2;
  }
  .ov-signal-list {
    list-style:none;
    margin:0;
    padding:0;
    display:flex;
    flex-direction:column;
    gap:6px;
  }
  .ov-signal-item {
    font-size:.8rem;
    font-weight:500;
    letter-spacing:.02em;
    color:rgba(255,255,255,.75);
    padding:0;
    line-height:1.35;
    position:relative;
    padding-left:16px;
  }
  .ov-signal-item::before {
    content:'';
    position:absolute;
    left:0;
    top:50%;
    transform:translateY(-50%);
    width:4px;
    height:4px;
    border-radius:50%;
    background:linear-gradient(135deg, rgba(99,102,241,.9), rgba(129,140,248,.9));
    box-shadow:0 0 8px rgba(99,102,241,.4);
  }

  /* 2. Cylinder — unified look with subtle purple tint to match section */
  .ov-cylinder-wrapper {
    margin-top:32px;
    margin-left:auto;
    margin-right:auto;
    position:relative;
    width:100%;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:20px;
    padding-left: 56px; /* Shift the entire wrapper right to align cylinder with logo */
  }
  .ov-cylinder {
    position:relative;
    width:160px;
    flex-shrink:0;
    filter:drop-shadow(0 0 20px rgba(99,102,241,.08));
  }
  .ov-cylinder-top {
    width:100%;
    height:28px;
    border-radius:50%;
    background:linear-gradient(180deg,
      rgba(255,255,255,.22) 0%,
      rgba(129,140,248,.12) 40%,
      rgba(99,102,241,.06) 100%);
    border:1px solid rgba(129,140,248,.35);
    box-shadow:inset 0 1px 2px rgba(255,255,255,.2), 0 2px 10px rgba(0,0,0,.25);
    margin-bottom:-14px;
    z-index:1;
    position:relative;
  }
  .ov-cylinder-body {
    position:relative;
    border-radius:0 0 80px 80px / 0 0 20px 20px;
    border:1px solid rgba(129,140,248,.28);
    border-top:none;
    background:linear-gradient(180deg,
      rgba(129,140,248,.08) 0%,
      rgba(99,102,241,.06) 8%,
      rgba(255,255,255,.06) 25%,
      rgba(255,255,255,.10) 50%,
      rgba(255,255,255,.06) 75%,
      rgba(99,102,241,.05) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.06),
      inset 0 0 28px rgba(0,0,0,.12),
      inset 2px 0 10px rgba(0,0,0,.06),
      inset -2px 0 10px rgba(0,0,0,.06),
      0 0 0 1px rgba(99,102,241,.06);
    padding:28px 12px 24px;
    min-height:90px;
    display:flex;
    align-items:center;
    justify-content:center;
  }
  .ov-cylinder-inner {
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:8px 10px;
    align-items:center;
    max-width:108px;
  }
  .ov-cylinder-ico {
    width:22px;
    height:22px;
    border-radius:7px;
    background:linear-gradient(145deg, rgba(255,255,255,.98), rgba(241,245,255,.95));
    overflow:hidden;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:2px;
    box-sizing:border-box;
    border:1px solid rgba(129,140,248,.2);
    box-shadow:0 1px 3px rgba(0,0,0,.15), inset 0 1px 0 rgba(255,255,255,.6);
  }
  /* Keep the original tile look, just smaller tiles */
  .ov-cylinder-ico img { width:90%; height:90%; object-fit:contain; display:block; }
  .ov-cylinder-ico-fb { display:none; font-size:.6rem; font-weight:900; color:#fff; background:var(--color-primary); width:100%; height:100%; align-items:center; justify-content:center; border-radius:5px; }
  
  .ov-cylinder-text {
    flex:1;
    min-width:0;
    display:flex;
    flex-direction:column;
    justify-content:center;
  }
  .ov-cylinder-list {
    list-style:none;
    margin:0;
    padding:0;
    display:flex;
    flex-direction:column;
    gap:6px;
  }
  .ov-cylinder-list li {
    font-size:.75rem;
    font-weight:600;
    letter-spacing:.02em;
    color:rgba(255,255,255,.75);
    padding:0;
    line-height:1.35;
    position:relative;
    padding-left:16px;
  }
  .ov-cylinder-list li::before {
    content:'';
    position:absolute;
    left:0;
    top:50%;
    transform:translateY(-50%);
    width:4px;
    height:4px;
    border-radius:50%;
    background:linear-gradient(135deg, rgba(99,102,241,.9), rgba(129,140,248,.9));
    box-shadow:0 0 8px rgba(99,102,241,.4);
  }
  .ov-engine-step-ingest .ov-engine-step-desc,
  .ov-engine-step-out .ov-engine-step-desc { margin-top:5px; }
  .ov-engine-step {
    border-radius:14px;
    border:1px solid rgba(255,255,255,.10);
    background:linear-gradient(180deg, rgba(255,255,255,.035), rgba(255,255,255,.02));
    box-shadow:inset 0 1px 0 rgba(255,255,255,.04);
    padding:9px 11px;
  }
  .ov-engine-step-top { display:flex; align-items:baseline; justify-content:space-between; gap:10px; }
  .ov-engine-step-name { font-weight:800; font-size:.84rem; letter-spacing:-.01em; color:rgba(255,255,255,.92); }
  .ov-engine-step-tag { font-size:.72rem; color:rgba(255,255,255,.62); white-space:nowrap; }
  .ov-engine-step-desc { margin:5px 0 0; font-size:.75rem; color:rgba(255,255,255,.68); line-height:1.45; }

  .ov-engine-icons { display:flex; align-items:center; gap:6px; }
  .ov-engine-ico { width:18px; height:18px; border-radius:6px; background:#fff; overflow:hidden; display:flex; align-items:center; justify-content:center; padding:2px; box-sizing:border-box; opacity:.92; }
  .ov-engine-ico img { width:100%; height:100%; object-fit:contain; display:block; }
  .ov-engine-ico-fb { display:none; font-size:.55rem; font-weight:900; color:#fff; background:var(--color-primary); width:100%; height:100%; align-items:center; justify-content:center; border-radius:4px; }
  .ov-engine-more { font-size:.7rem; color:rgba(255,255,255,.55); font-weight:700; letter-spacing:-.01em; }

  .ov-engine-connector {
    flex-shrink:0;
    height:12px;
    display:flex;
    align-items:flex-end;
    justify-content:center;
    position:relative;
  }
  .ov-engine-connector::before {
    content:'';
    position:absolute;
    left:50%;
    top:0;
    bottom:6px;
    width:2px;
    border-radius:2px;
    background:linear-gradient(180deg, rgba(13,148,136,.75), rgba(6,182,212,.75));
    transform:translateX(-50%);
    box-shadow:0 0 12px rgba(13,148,136,.25), 0 0 6px rgba(6,182,212,.2);
  }
  .ov-engine-connector-arrow {
    position:relative;
    z-index:1;
    width:0;
    height:0;
    border-left:6px solid transparent;
    border-right:6px solid transparent;
    border-top:7px solid rgba(6,182,212,.9);
    filter:drop-shadow(0 0 4px rgba(6,182,212,.4));
  }

  .ov-engine-step-ai { border-color:rgba(13,148,136,.18); background:linear-gradient(180deg, rgba(13,148,136,.10), rgba(255,255,255,.018)); }
  .ov-engine-step-out { border-color:rgba(6,182,212,.18); background:linear-gradient(180deg, rgba(6,182,212,.09), rgba(255,255,255,.018)); }

  .ov-ai-read { position:relative; margin-top:7px; border-radius:12px; border:1px solid rgba(255,255,255,.10); background:rgba(0,0,0,.14); overflow:hidden; height:74px; }
  .ov-ai-ind {
    position:absolute;
    top:8px;
    right:10px;
    z-index:2;
    font-size:.68rem;
    font-weight:750;
    letter-spacing:.02em;
    color:rgba(255,255,255,.70);
    display:flex;
    align-items:center;
    gap:6px;
    pointer-events:none;
    text-shadow:0 10px 24px rgba(0,0,0,.35);
  }
  .ov-ai-dot {
    width:6px;
    height:6px;
    border-radius:50%;
    background:rgba(253,224,71,.85);
    box-shadow:0 0 0 3px rgba(253,224,71,.10);
  }
  .ov-ai-read::before {
    content:'';
    position:absolute;
    inset:0;
    background:radial-gradient(120% 120% at 10% 0%, rgba(13,148,136,.10), transparent 55%),
               radial-gradient(120% 120% at 90% 100%, rgba(6,182,212,.08), transparent 55%);
    pointer-events:none;
  }

  .ov-ai-snippet {
    position:absolute;
    inset:10px 10px 10px 10px;
    opacity:0;
    transform:translateY(4px);
    transition:opacity .22s ease, transform .22s ease;
  }
  .ov-ai-snippet.ov-ai-active { opacity:1; transform:translateY(0); }
  .ov-ai-sn-body { position:relative; }
  .ov-ai-sn-body::after {
    content:'';
    display:inline-block;
    width:1px;
    height:1em;
    margin-left:2px;
    background:rgba(255,255,255,.55);
    transform:translateY(2px);
    opacity:0;
  }
  .ov-ai-typing .ov-ai-sn-body::after {
    opacity:1;
    animation:ovCaret 1s steps(2,end) infinite;
  }
  @keyframes ovCaret { 0%,49%{opacity:1} 50%,100%{opacity:0} }

  .ov-ai-sn-head { display:flex; align-items:center; gap:8px; margin-bottom:6px; }
  .ov-ai-sn-app { font-size:.72rem; font-weight:800; color:rgba(255,255,255,.90); letter-spacing:-.01em; }
  .ov-ai-sn-type { font-size:.7rem; color:rgba(255,255,255,.60); }
  .ov-ai-sn-body {
    font-size:.74rem;
    line-height:1.4;
    color:rgba(255,255,255,.76);
    display:-webkit-box;
    -webkit-line-clamp:3;
    -webkit-box-orient:vertical;
    overflow:hidden;
  }

  .ov-ai-explain-label {
    margin-top:9px;
    margin-bottom:4px;
    font-size:.72rem;
    font-weight:700;
    letter-spacing:.02em;
    color:rgba(255,255,255,.82);
  }
  .ov-ai-explain {
    margin-top:0;
    display:flex;
    flex-direction:column;
    gap:5px;
  }
  .ov-ai-ex-row {
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    gap:10px;
    padding:6px 9px;
    border-radius:10px;
    border:1px solid rgba(255,255,255,.08);
    background:rgba(255,255,255,.02);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
  }
  .ov-ai-ex-k {
    font-size:.7rem;
    font-weight:850;
    letter-spacing:.02em;
    color:rgba(255,255,255,.88);
    white-space:nowrap;
  }
  .ov-ai-ex-v {
    font-size:.72rem;
    line-height:1.35;
    color:rgba(255,255,255,.64);
    text-align:right;
  }

  @media (prefers-reduced-motion: reduce) {
    .ov-ai-snippet { opacity:1; transform:none; position:relative; inset:auto; padding:10px; transition:none; }
    .ov-ai-snippet:not(:first-child) { display:none; }
    .ov-ai-sn-body::after { display:none; }
    .ov-ai-read { height:auto; }
  }

  .ov-circle { width:116px; height:116px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; position:relative; cursor:default; transition:transform .2s ease; }
  .ov-circle:hover { transform:scale(1.04); }

  .ov-circle-de { border:1.5px solid rgba(13,148,136,.5); background:rgba(13,148,136,.08); animation:deGlow 3.2s ease-in-out infinite; }
  .ov-circle-ai { border:1.5px solid rgba(6,182,212,.5); background:rgba(6,182,212,.08); animation:aiGlow 3.2s ease-in-out infinite 1.6s; }

  @keyframes deGlow {
    0%,100% { box-shadow:0 0 28px rgba(13,148,136,.22), 0 0 56px rgba(13,148,136,.07); }
    50%      { box-shadow:0 0 48px rgba(13,148,136,.45), 0 0 90px rgba(13,148,136,.18); }
  }
  @keyframes aiGlow {
    0%,100% { box-shadow:0 0 28px rgba(6,182,212,.22), 0 0 56px rgba(6,182,212,.07); }
    50%      { box-shadow:0 0 48px rgba(6,182,212,.45), 0 0 90px rgba(6,182,212,.18); }
  }

  .ov-circle-inner { display:flex; flex-direction:column; align-items:center; gap:7px; pointer-events:none; }
  .ov-circle-de .ov-circle-svg { color:var(--color-primary); opacity:.9; }
  .ov-circle-ai .ov-circle-svg { color:var(--color-accent-to); opacity:.9; }
  .ov-circle-label { font-size:.65rem; font-weight:700; text-align:center; line-height:1.3; letter-spacing:.05em; text-transform:uppercase; }
  .ov-circle-de .ov-circle-label { color:var(--color-primary); }
  .ov-circle-ai .ov-circle-label { color:var(--color-accent-to); }

  /* Engine step tooltips — hidden in DOM, content copied to portal on hover */
  .ov-engine-tip { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
  .ov-engine-tip .ov-tip-title { font-size:.7rem; font-weight:700; color:var(--color-foreground); margin:0 0 7px; }
  .ov-engine-tip ul { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:5px; }
  .ov-engine-tip li { font-size:.7rem; color:var(--color-foreground); display:flex; align-items:flex-start; gap:6px; line-height:1.35; white-space:normal; }
  .ov-engine-tip li::before { content:''; width:3px; height:3px; border-radius:50%; background:var(--color-primary); flex-shrink:0; margin-top:6px; }

  /* Tooltip portal — modern card, rendered in body */
  .ov-tooltip-portal {
    position:fixed;
    z-index:99999;
    max-width:240px;
    width:max-content;
    padding:0;
    border-radius:12px;
    pointer-events:none;
    opacity:0;
    transition:opacity .2s ease, transform .2s ease;
    background:linear-gradient(165deg, rgba(24,24,27,.98), rgba(18,18,20,.99));
    border:1px solid rgba(255,255,255,.08);
    box-shadow:
      0 0 0 1px rgba(255,255,255,.03) inset,
      0 4px 24px rgba(0,0,0,.45),
      0 12px 48px rgba(0,0,0,.35);
    overflow:hidden;
  }
  .ov-tooltip-portal-visible { opacity:1; }
  .ov-tooltip-portal .ov-tip-title {
    font-size:.75rem;
    font-weight:800;
    letter-spacing:-.01em;
    color:rgba(255,255,255,.95);
    margin:0;
    padding:12px 14px 10px;
    border-bottom:1px solid rgba(255,255,255,.06);
    background:linear-gradient(180deg, rgba(255,255,255,.04) 0%, transparent 100%);
  }
  .ov-tooltip-portal ul { list-style:none; padding:10px 14px 12px; margin:0; display:flex; flex-direction:column; gap:8px; }
  .ov-tooltip-portal li {
    font-size:.72rem;
    color:rgba(255,255,255,.78);
    display:flex;
    align-items:flex-start;
    gap:8px;
    line-height:1.4;
    white-space:normal;
  }
  .ov-tooltip-portal li::before {
    content:'';
    width:4px;
    height:4px;
    border-radius:50%;
    background:linear-gradient(135deg, #6366F1, #818CF8);
    flex-shrink:0;
    margin-top:6px;
    box-shadow:0 0 8px rgba(99,102,241,.35);
  }

  /* Blur overlay — four panels covering viewport except .ov-out-col. Instant show (no transition) so it appears with the window; transition only on hide. */
  .ov-blur-overlay { position:fixed; inset:0; z-index:99997; pointer-events:none; opacity:0; transition:opacity .15s ease; }
  .ov-blur-overlay.ov-blur-overlay-visible { opacity:1; transition:none; }
  .ov-blur-panel { position:fixed; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); background:rgba(0,0,0,.12); }

  /* Copilot window portal — instant show so it appears with blur; transition only on hide. */
  .ov-copilot-window-portal { position:fixed; top:0; left:0; width:0; height:0; overflow:visible; z-index:99998; pointer-events:none; opacity:0; transition:opacity .15s ease; }
  .ov-copilot-window-portal.ov-copilot-window-visible { opacity:1; transition:none; }
  .ov-copilot-window-item { position:fixed; opacity:0; pointer-events:none; transition:opacity .15s ease; }
  .ov-copilot-window-item.ov-copilot-window-active { opacity:1; transition:none; }

  /* Connector spacer (line drawn by SVG overlay) */
  .ov-connector-spacer { width:2px; height:36px; flex-shrink:0; }

  /* RIGHT */
  .ov-out-col { padding:0 18px 0 0; display:flex; flex-direction:column; }
  .ov-out-col .ov-col-body { gap:25px; padding:12px 0 14px; justify-content:center; }
  /* RIGHT — outcome cards: purple tint for visibility on black */
  .ov-out-card {
    border:1px solid rgba(129,140,248,.45);
    border-radius:12px;
    background:rgba(99,102,241,.14);
    padding:8px 10px 9px;
    transition:border-color .2s, background .2s, transform .2s ease, box-shadow .2s ease;
    display:flex;
    flex-direction:column;
    min-height:64px;
    box-shadow:0 8px 24px rgba(99,102,241,.15), inset 0 1px 0 rgba(139,92,246,.08);
  }
  .ov-out-card:hover {
    border-color:rgba(129,140,248,.45);
    background:rgba(99,102,241,.14);
    transform:translateY(-1px);
    box-shadow:0 8px 24px rgba(99,102,241,.15), inset 0 1px 0 rgba(139,92,246,.08);
  }
  .ov-out-head {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    width:100%;
  }
  .ov-out-titles { min-width:0; flex:1; }
  .ov-out-titleline { display:flex; align-items:baseline; gap:6px; min-width:0; flex-wrap:nowrap; }
  .ov-out-name { font-size:.8125rem; font-weight:700; color:rgba(255,255,255,.95); white-space:nowrap; }
  .ov-out-subline { margin-top:2px; }
  .ov-out-sub {
    font-size:.75rem;
    color:rgba(255,255,255,.72);
    line-height:1.25;
    white-space:nowrap;
    min-width:0;
    overflow:hidden;
    text-overflow:ellipsis;
  }
  .ov-out-meta { font-size:.75rem; color:rgba(255,255,255,.65); white-space:nowrap; }
  .ov-out-body { font-size:.75rem; color:rgba(255,255,255,.75); line-height:1.45; margin:0; }
  .ov-out-actions { display:flex; justify-content:flex-end; align-items:center; }
  .ov-out-view {
    font-size:.68rem;
    font-weight:700;
    letter-spacing:.08em;
    text-transform:uppercase;
    background:linear-gradient(90deg, rgba(99,102,241,0.6) 0%, #fff 40%, #fff 60%, rgba(99,102,241,0.6) 100%);
    background-size:200% auto;
    color:transparent;
    -webkit-background-clip:text;
    background-clip:text;
    padding:0;
    border:0;
    cursor:pointer;
    white-space:nowrap;
    animation:ovShine 2.5s linear infinite;
    transition:filter .2s ease, transform .2s ease;
  }
  .ov-out-view::after { content:none; }
  .ov-out-view:hover {
    filter:drop-shadow(0 0 8px rgba(129,140,248,0.6));
    transform:scale(1.02);
  }
  @keyframes ovShine {
    to { background-position:200% center; }
  }
  .ov-out-view:active { transform:translateY(0); }
  .ov-out-view:focus-visible { outline:none; box-shadow:0 0 0 2px rgba(129,140,248,.35); border-radius:8px; }

  .ov-bbl-u,.ov-bbl-a { font-size:.75rem; line-height:1.45; border-radius:5px; padding:4px 7px; margin-bottom:3px; }
  .ov-bbl-a { margin-bottom:0; }
