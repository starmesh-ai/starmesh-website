---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!-- Exact copy of Features.astro CRM Write-back / Salesforce Sync design -->
<div class="rounded-xl overflow-hidden w-[520px] flex-shrink-0" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 16px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.03), 0 0 80px rgba(192,132,252,.04);">
  <div class="flex items-center px-4 py-3 border-b border-white/[0.06]" style="background:#111118;">
    <div class="flex gap-1.5 flex-shrink-0">
      <span class="w-3 h-3 rounded-full" style="background:#FF5F56;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#FFBD2E;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#27C93F;"></span>
    </div>
    <span class="text-[12px] text-[#71717A] flex-1 text-center font-medium">Starmesh · {title}</span>
    <div style="width:54px;" class="flex-shrink-0"></div>
  </div>
  <div class="flex" style="height:360px;">
    <div class="flex flex-col flex-shrink-0" style="width:160px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
      <div class="px-3 py-2.5 border-b border-white/[0.04]"><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider font-bold">Object</p></div>
      <div class="px-3 py-3 border-b border-white/[0.03] bg-violet-500/[0.06] border-l-2 border-l-violet-500/50"><p class="text-[12px] text-[#E4E4E7] font-semibold">Opportunity</p></div>
      <div class="px-3 py-3 border-b border-white/[0.03]"><p class="text-[12px] text-[#52525B]">Contact</p></div>
      <div class="px-3 py-3 border-b border-white/[0.03]"><p class="text-[12px] text-[#52525B]">Account</p></div>
      <div class="px-3 py-4 mt-auto border-t border-white/[0.04]">
        <div class="flex items-center gap-1.5 mb-2">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-50"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
          </span>
          <span class="text-[11px] text-green-400 font-semibold">Syncing</span>
        </div>
        <p class="text-[10px] text-[#52525B]">124 opps updated</p>
        <p class="text-[10px] text-[#3F3F46]">Last sync: 2m ago</p>
      </div>
    </div>
    <div class="flex-1 flex flex-col overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2 border-b border-white/[0.05]" style="background:rgba(255,255,255,0.01);">
        <span class="text-[13px] font-semibold text-[#FAFAFA]">Acme Corp · Enterprise · Q2</span>
        <span class="text-[11px] text-green-400 bg-green-500/10 border border-green-500/20 px-2 py-0.5 rounded-full font-semibold">5 fields written</span>
      </div>
      <div class="px-4 py-2 border-b border-white/[0.04] flex-shrink-0" style="background:rgba(255,255,255,0.01);">
        <div class="flex gap-3 text-[10px] text-[#52525B]">
          <span>Source: Mar 5 · Zoom call</span>
          <span>·</span>
          <span>Written: just now</span>
        </div>
      </div>
      <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Win_Probability__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-green-400">74%</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Deal_Risk__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-red-400">at_risk</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Slip_Risk_Flag__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-orange-400">elevated</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Competitor_Mention__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-yellow-400">Chorus · 3×</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Next_Step_Defined__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-green-400">true ✓</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
        <div class="flex items-center px-4 py-3 gap-3">
          <span class="text-[11px] font-mono text-[#71717A] flex-1 truncate">Champion_Status__c</span>
          <span class="text-[12px] font-semibold font-mono flex-shrink-0 text-green-400">warm</span>
          <span class="text-[12px] text-green-400 flex-shrink-0">✓</span>
        </div>
      </div>
    </div>
  </div>
</div>
