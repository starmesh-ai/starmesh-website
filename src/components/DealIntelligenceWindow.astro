---
interface Props {
  title: string;
  userText: string;
  aiText: string;
}
const { title, userText, aiText } = Astro.props;
---
<!-- Exact copy of Features.astro Deal Intelligence screenshot design — fixed width to match -->
<div class="ov-deal-intel-window rounded-xl overflow-hidden w-[520px] flex-shrink-0" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 16px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.03), 0 0 80px rgba(99,102,241,.06);">
  <div class="flex items-center px-4 py-3 border-b border-white/[0.06]" style="background:#111118;">
    <div class="flex gap-1.5 flex-shrink-0">
      <span class="w-3 h-3 rounded-full" style="background:#FF5F56;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#FFBD2E;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#27C93F;"></span>
    </div>
    <span class="text-[12px] text-[#71717A] flex-1 text-center font-medium">Starmesh · {title}</span>
    <div style="width:54px;" class="flex-shrink-0"></div>
  </div>
  <div class="flex" style="height:360px;">
    <div class="flex flex-col flex-shrink-0" style="width:160px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
      <div class="px-3 py-2.5 border-b border-white/[0.04]"><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider font-bold">Deals</p></div>
      <div class="px-3 py-3 border-b border-white/[0.03] flex items-center justify-between gap-2 bg-indigo-500/10 border-l-2 border-l-indigo-500/70">
        <p class="text-[12px] truncate text-[#E4E4E7] font-semibold">Acme Corp</p>
        <span class="text-[11px] font-mono font-bold flex-shrink-0 text-indigo-400">74%</span>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03] flex items-center justify-between gap-2">
        <p class="text-[12px] truncate text-[#52525B]">FinCo Ltd</p>
        <span class="text-[11px] font-mono font-bold flex-shrink-0 text-green-400">88%</span>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03] flex items-center justify-between gap-2">
        <p class="text-[12px] truncate text-[#52525B]">Meridian</p>
        <span class="text-[11px] font-mono font-bold flex-shrink-0 text-red-400">41%</span>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03] flex items-center justify-between gap-2">
        <p class="text-[12px] truncate text-[#52525B]">Brightwave</p>
        <span class="text-[11px] font-mono font-bold flex-shrink-0 text-green-400">79%</span>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03] flex items-center justify-between gap-2">
        <p class="text-[12px] truncate text-[#52525B]">Ironclad</p>
        <span class="text-[11px] font-mono font-bold flex-shrink-0 text-indigo-400">63%</span>
      </div>
    </div>
    <div class="flex-1 flex flex-col overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2 border-b border-white/[0.05]" style="background:rgba(255,255,255,0.01);">
        <div class="flex items-center gap-2">
          <span class="text-[13px] font-semibold text-[#FAFAFA]">Acme Corp</span>
          <span class="text-[11px] font-mono text-indigo-400/60">D-2847</span>
        </div>
        <div class="flex gap-1">
          <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.06] text-[#71717A]">Negotiation</span>
          <span class="text-[11px] px-1.5 py-0.5 rounded bg-yellow-500/10 border border-yellow-500/20 text-yellow-400">At risk</span>
        </div>
      </div>
      <div class="flex-1 px-4 py-4 space-y-3 overflow-auto">
        <div class="flex justify-end">
          <p class="text-[13px] text-[#A1A1AA] bg-white/[0.05] border border-white/[0.07] rounded-xl rounded-br-sm px-3 py-2 leading-relaxed max-w-[80%]">{userText}</p>
        </div>
        <div class="flex gap-2.5">
          <div class="w-5 h-5 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="8" height="8" viewBox="0 0 10 10" fill="none"><path d="M5 1l1.18 2.39 2.64.38-1.91 1.86.45 2.63L5 7l-2.36 1.26.45-2.63L1.18 3.77l2.64-.38L5 1z" fill="#818CF8"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-[13px] text-[#E4E4E7] bg-indigo-500/[0.07] border border-indigo-500/15 rounded-xl rounded-tl-sm px-3 py-2 leading-relaxed mb-2">{aiText}</p>
            <div class="flex gap-1.5 flex-wrap">
              <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-[#71717A]">↗ Mar 3 · Zoom</span>
              <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-[#71717A]">↗ Feb 28 · Gmail</span>
              <span class="text-[11px] px-1.5 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-[#71717A]">↗ Feb 21 · Zoom</span>
            </div>
          </div>
        </div>
      </div>
      <div class="px-4 py-3 border-t border-white/[0.05] flex items-center gap-2">
        <div class="flex-1 text-[12px] text-[#3F3F46] bg-white/[0.03] border border-white/[0.05] rounded-lg px-3 py-2">Ask about any deal, rep, or account…</div>
        <div class="w-7 h-7 rounded-lg bg-indigo-500/20 border border-indigo-500/25 flex items-center justify-center flex-shrink-0">
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 10L10 6L2 2V5.5L7 6L2 6.5V10Z" fill="#818CF8"/></svg>
        </div>
      </div>
    </div>
  </div>
</div>
