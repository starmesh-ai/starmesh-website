---
interface Props {
  title: string;
  events: Array<{ d: string; t: string }>;
}
const { title, events } = Astro.props;
const colors = ['red', 'yellow', 'green', 'blue', 'indigo'] as const;
const tags = ['Risk: high', 'No response', 'Momentum ↑', 'Opened 3×', 'MEDDICC: 68%'];
const sources = ['Zoom', 'Gmail', 'Zoom', 'Gmail', 'Zoom'];
---
<!-- Exact copy of Features.astro Interaction Timeline design -->
<div class="rounded-xl overflow-hidden w-[520px] flex-shrink-0" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 16px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.03), 0 0 80px rgba(45,212,191,.04);">
  <div class="flex items-center px-4 py-3 border-b border-white/[0.06]" style="background:#111118;">
    <div class="flex gap-1.5 flex-shrink-0">
      <span class="w-3 h-3 rounded-full" style="background:#FF5F56;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#FFBD2E;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#27C93F;"></span>
    </div>
    <span class="text-[12px] text-[#71717A] flex-1 text-center font-medium">Starmesh · {title}</span>
    <div style="width:54px;" class="flex-shrink-0"></div>
  </div>
  <div class="flex" style="height:360px;">
    <div class="flex flex-col flex-shrink-0" style="width:160px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
      <div class="px-3 py-2.5 border-b border-white/[0.04]"><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider font-bold">Deals</p></div>
      <div class="px-3 py-3 border-b border-white/[0.03] bg-teal-500/[0.06] border-l-2 border-l-teal-500/50">
        <p class="text-[12px] truncate text-[#E4E4E7] font-semibold">Acme Corp</p>
        <p class="text-[10px] text-[#3F3F46] mt-0.5">{events.length} events</p>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03]">
        <p class="text-[12px] truncate text-[#52525B]">FinCo Ltd</p>
        <p class="text-[10px] text-[#3F3F46] mt-0.5">3 events</p>
      </div>
      <div class="px-3 py-3 border-b border-white/[0.03]">
        <p class="text-[12px] truncate text-[#52525B]">Meridian</p>
        <p class="text-[10px] text-[#3F3F46] mt-0.5">2 events</p>
      </div>
    </div>
    <div class="flex-1 flex flex-col overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2 border-b border-white/[0.05]" style="background:rgba(255,255,255,0.01);">
        <span class="text-[13px] font-semibold text-[#FAFAFA]">Acme Corp · Timeline</span>
        <div class="flex gap-1">
          <span class="text-[11px] px-2 py-0.5 rounded border border-teal-500/30 bg-teal-500/10 text-teal-400">All</span>
          <span class="text-[11px] px-2 py-0.5 rounded border border-white/[0.06] text-[#52525B]">Calls</span>
          <span class="text-[11px] px-2 py-0.5 rounded border border-white/[0.06] text-[#52525B]">Email</span>
          <span class="text-[11px] px-2 py-0.5 rounded border border-white/[0.06] text-[#52525B]">CRM</span>
        </div>
      </div>
      <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05] flex-shrink-0">
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-[#FAFAFA]">{events.length}</p><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Events</p></div>
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-teal-400">3</p><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Calls</p></div>
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-red-400">1</p><p class="text-[10px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Risk flags</p></div>
      </div>
      <div class="flex-1 p-4 overflow-hidden">
        <div class="relative pl-5 border-l border-white/[0.06] space-y-4">
          {events.map((e, i) => {
            const color = colors[i % colors.length];
            const tag = tags[i % tags.length];
            const source = sources[i % sources.length];
            const bc = color === 'red' ? 'bg-red-500/10 border-red-500/20' : color === 'yellow' ? 'bg-yellow-500/10 border-yellow-500/20' : color === 'green' ? 'bg-green-500/10 border-green-500/20' : color === 'blue' ? 'bg-blue-500/10 border-blue-500/20' : 'bg-indigo-500/10 border-indigo-500/20';
            const tc = color === 'red' ? 'text-red-400' : color === 'yellow' ? 'text-yellow-400' : color === 'green' ? 'text-green-400' : color === 'blue' ? 'text-blue-400' : 'text-indigo-400';
            const dot = color === 'red' ? 'bg-red-400' : color === 'yellow' ? 'bg-yellow-400' : color === 'green' ? 'bg-green-400' : color === 'blue' ? 'bg-blue-400' : 'bg-indigo-400';
            return (
              <div class="relative flex items-center gap-3 min-w-0">
                <div class={`absolute -left-[1.45rem] w-2.5 h-2.5 rounded-full flex-shrink-0 ${dot}`} style="border:2px solid #0a0a0d;"></div>
                <span class="text-[11px] text-[#71717A] w-12 flex-shrink-0">{e.d}</span>
                <span class="text-[11px] text-[#71717A] px-1.5 rounded bg-white/[0.04] border border-white/[0.05] flex-shrink-0">{source}</span>
                <span class="text-[12px] text-[#A1A1AA] flex-1 truncate min-w-0">{e.t}</span>
                <span class={`text-[11px] px-1.5 py-0.5 rounded border flex-shrink-0 ${bc} ${tc}`}>{tag}</span>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</div>
