---
---
<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[#09090B]/80 border-b border-white/[0.06]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <img src="/images/starmesh-logo.png" alt="Starmesh" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-7">

      <!-- Product dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1.5 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors">
          Product
          <svg class="w-3 h-3 mt-px transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <!-- Dropdown panel -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-[340px] rounded-2xl border border-white/[0.08] bg-[#0e0e10] shadow-2xl shadow-black/40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">

          <!-- Arrow pointer -->
          <div class="absolute -top-[5px] left-1/2 -translate-x-1/2 w-2.5 h-2.5 rotate-45 bg-[#0e0e10] border-l border-t border-white/[0.08]"></div>

          <div class="p-3">
            <a href="/?team=sales#overview" class="dd-item group/item flex items-start gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 hover:bg-white/[0.05]">
              <span class="dd-icon mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#818CF8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>
                </svg>
              </span>
              <span>
                <span class="block text-sm font-medium text-[#E4E4E7] group-hover/item:text-white transition-colors">Sales</span>
                <span class="block text-xs text-[#71717A] mt-0.5">Close more deals with signal-backed forecasting</span>
              </span>
            </a>

            <a href="/?team=cx#overview" class="dd-item group/item flex items-start gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 hover:bg-white/[0.05]">
              <span class="dd-icon mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(20,184,166,0.1); border: 1px solid rgba(20,184,166,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2dd4bf" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
              </span>
              <span>
                <span class="block text-sm font-medium text-[#E4E4E7] group-hover/item:text-white transition-colors">CX</span>
                <span class="block text-xs text-[#71717A] mt-0.5">Catch churn risk before customers walk away</span>
              </span>
            </a>

            <a href="/?team=product#overview" class="dd-item group/item flex items-start gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 hover:bg-white/[0.05]">
              <span class="dd-icon mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(168,85,247,0.1); border: 1px solid rgba(168,85,247,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#c084fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </span>
              <span>
                <span class="block text-sm font-medium text-[#E4E4E7] group-hover/item:text-white transition-colors">Product</span>
                <span class="block text-xs text-[#71717A] mt-0.5">Build what customers actually ask for</span>
              </span>
            </a>

            <!-- Divider -->
            <div class="my-2 mx-3 border-t border-white/[0.06]"></div>

            <!-- What's Unique -->
            <a href="/#why-starmesh" class="dd-item group/item flex items-start gap-3 px-3 py-2.5 rounded-xl transition-all duration-150 hover:bg-white/[0.05]">
              <span class="dd-icon mt-0.5 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2);">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/>
                </svg>
              </span>
              <span>
                <span class="block text-sm font-medium text-[#E4E4E7] group-hover/item:text-white transition-colors">What's Unique</span>
                <span class="block text-xs text-[#71717A] mt-0.5">Why teams choose Starmesh over the rest</span>
              </span>
            </a>
          </div>
        </div>
      </div>

      <a href="/#benefits" class="text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors">Benefits</a>
      <a href="/pricing" class="text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors">Pricing</a>
      <a href="/integrations" class="text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors">Integrations</a>
    </nav>

    <!-- CTA + mobile menu button -->
    <div class="flex items-center gap-4">
      <a href="/contact" class="btn-primary text-sm hidden md:inline-flex">Request demo</a>

      <!-- Mobile hamburger -->
      <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
        <span class="w-5 h-0.5 bg-[#FAFAFA] transition-all"></span>
        <span class="w-5 h-0.5 bg-[#FAFAFA] transition-all"></span>
        <span class="w-5 h-0.5 bg-[#FAFAFA] transition-all"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/[0.06] bg-[#09090B]">
    <nav class="flex flex-col px-6 py-4 gap-1">

      <!-- Product accordion -->
      <button id="mobile-product-btn" class="flex items-center justify-between w-full py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors">
        Product
        <svg id="mobile-product-chevron" class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div id="mobile-product-menu" class="hidden pl-4 flex flex-col gap-1">
        <a href="/?team=sales#overview"   class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">Sales</a>
        <a href="/?team=cx#overview"      class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">CX</a>
        <a href="/?team=product#overview" class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">Product</a>
        <div class="my-1 border-t border-white/[0.06]"></div>
        <a href="/#why-starmesh" class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">What's Unique</a>
      </div>

      <a href="/#benefits"   class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">Benefits</a>
      <a href="/pricing"     class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">Pricing</a>
      <a href="/integrations" class="py-2 text-sm text-[#A1A1AA] hover:text-[#FAFAFA] transition-colors mobile-link">Integrations</a>
      <div class="pt-2">
        <a href="/contact" class="btn-primary text-sm w-fit">Request demo</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Mobile product accordion
  const productBtn = document.getElementById('mobile-product-btn');
  const productMenu = document.getElementById('mobile-product-menu');
  const productChevron = document.getElementById('mobile-product-chevron');
  productBtn?.addEventListener('click', () => {
    productMenu?.classList.toggle('hidden');
    productChevron?.classList.toggle('rotate-180');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
