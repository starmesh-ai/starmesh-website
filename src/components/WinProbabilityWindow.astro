---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!-- Exact copy of Features.astro PWin / Pipeline Intelligence design -->
<div class="rounded-xl overflow-hidden w-[520px] flex-shrink-0" style="background:#0c0c10; border:1px solid rgba(255,255,255,0.1); box-shadow:0 16px 60px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.03), 0 0 80px rgba(13,148,136,.06);">
  <div class="flex items-center px-4 py-3 border-b border-white/[0.06]" style="background:#111118;">
    <div class="flex gap-1.5 flex-shrink-0">
      <span class="w-3 h-3 rounded-full" style="background:#FF5F56;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#FFBD2E;"></span>
      <span class="w-3 h-3 rounded-full" style="background:#27C93F;"></span>
    </div>
    <span class="text-[12px] text-muted flex-1 text-center font-medium">Starmesh · {title}</span>
    <div style="width:54px;" class="flex-shrink-0"></div>
  </div>
  <div class="flex" style="height:360px;">
    <div class="flex flex-col flex-shrink-0" style="width:160px; background:#0a0a0d; border-right:1px solid rgba(255,255,255,0.05);">
      <div class="px-3 py-2 border-b border-white/[0.04]"><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold">Quarter</p></div>
      <div class="px-3 py-2.5 border-b border-white/[0.03]"><p class="text-[11px] text-[#52525B]">Q1 2025</p></div>
      <div class="px-3 py-2.5 border-b border-white/[0.03] bg-teal-500/10 border-l-2 border-l-teal-500/70"><p class="text-[11px] text-foreground font-semibold">Q2 2025</p></div>
      <div class="px-3 py-2.5 border-b border-white/[0.03]"><p class="text-[11px] text-[#52525B]">Q3 2025</p></div>
      <div class="px-3 py-2.5 border-b border-white/[0.03]"><p class="text-[11px] text-[#52525B]">Q4 2025</p></div>
      <div class="px-3 pt-3 mt-auto border-t border-white/[0.04]">
        <p class="text-[9px] text-[#3F3F46] uppercase tracking-wider font-bold mb-2">Filter</p>
        <p class="text-[11px] py-0.5 text-muted-foreground font-semibold">All</p>
        <p class="text-[11px] py-0.5 text-[#3F3F46]">At risk</p>
        <p class="text-[11px] py-0.5 text-[#3F3F46]">Healthy</p>
      </div>
    </div>
    <div class="flex-1 flex flex-col overflow-hidden">
      <div class="grid grid-cols-3 divide-x divide-white/[0.05] border-b border-white/[0.05] flex-shrink-0">
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-foreground">18</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Active</p></div>
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-primary">0.67</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">Avg PWin</p></div>
        <div class="px-3 py-2.5 text-center"><p class="text-base font-bold text-red-400">3</p><p class="text-[9px] text-[#3F3F46] uppercase tracking-wider mt-0.5">At risk</p></div>
      </div>
      <div class="flex-1 divide-y divide-white/[0.04] overflow-hidden">
        <div class="flex items-center px-3 py-2.5 gap-2">
          <div class="flex-1 min-w-0"><p class="text-[12px] font-medium text-[#E4E4E7] truncate">Acme Corp</p><p class="text-[10px] text-[#52525B]">Negotiation</p></div>
          <div class="flex items-center gap-1.5 flex-shrink-0">
            <div class="w-12 h-1.5 rounded-full bg-white/[0.06]"><div class="h-1.5 rounded-full bg-teal-500 opacity-70" style="width:74%"></div></div>
            <span class="text-[11px] font-mono font-bold w-6 text-right text-primary">74%</span>
          </div>
          <span class="text-[10px] px-1.5 py-0.5 rounded border font-medium w-12 text-center flex-shrink-0 text-yellow-400 bg-yellow-500/10 border-yellow-500/20">medium</span>
        </div>
        <div class="flex items-center px-3 py-2.5 gap-2">
          <div class="flex-1 min-w-0"><p class="text-[12px] font-medium text-[#E4E4E7] truncate">FinCo Ltd</p><p class="text-[10px] text-[#52525B]">Closing</p></div>
          <div class="flex items-center gap-1.5 flex-shrink-0">
            <div class="w-12 h-1.5 rounded-full bg-white/[0.06]"><div class="h-1.5 rounded-full bg-teal-500 opacity-70" style="width:88%"></div></div>
            <span class="text-[11px] font-mono font-bold w-6 text-right text-primary">88%</span>
          </div>
          <span class="text-[10px] px-1.5 py-0.5 rounded border font-medium w-12 text-center flex-shrink-0 text-green-400 bg-green-500/10 border-green-500/20">low</span>
        </div>
        <div class="flex items-center px-3 py-2.5 gap-2">
          <div class="flex-1 min-w-0"><p class="text-[12px] font-medium text-[#E4E4E7] truncate">Meridian</p><p class="text-[10px] text-[#52525B]">Discovery</p></div>
          <div class="flex items-center gap-1.5 flex-shrink-0">
            <div class="w-12 h-1.5 rounded-full bg-white/[0.06]"><div class="h-1.5 rounded-full bg-red-500 opacity-70" style="width:41%"></div></div>
            <span class="text-[11px] font-mono font-bold w-6 text-right text-red-400">41%</span>
          </div>
          <span class="text-[10px] px-1.5 py-0.5 rounded border font-medium w-12 text-center flex-shrink-0 text-red-400 bg-red-500/10 border-red-500/20">high</span>
        </div>
        <div class="flex items-center px-3 py-2.5 gap-2">
          <div class="flex-1 min-w-0"><p class="text-[12px] font-medium text-[#E4E4E7] truncate">Brightwave</p><p class="text-[10px] text-[#52525B]">Demo</p></div>
          <div class="flex items-center gap-1.5 flex-shrink-0">
            <div class="w-12 h-1.5 rounded-full bg-white/[0.06]"><div class="h-1.5 rounded-full bg-teal-500 opacity-70" style="width:79%"></div></div>
            <span class="text-[11px] font-mono font-bold w-6 text-right text-primary">79%</span>
          </div>
          <span class="text-[10px] px-1.5 py-0.5 rounded border font-medium w-12 text-center flex-shrink-0 text-green-400 bg-green-500/10 border-green-500/20">low</span>
        </div>
      </div>
    </div>
  </div>
</div>
