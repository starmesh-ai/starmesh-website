---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const tabs = [
  {
    id: 'sales',
    label: 'Sales',
    sources: ['Zoom call transcript', 'Gong deal review', 'Salesforce opportunity notes', 'HubSpot email thread'],
    outcomes: ['AI forecast confidence', 'Deal/account health', 'AE performance signals', 'Qualification coverage', 'Buyer timeline + next action', 'Writeback to CRM']
  },
  {
    id: 'cx',
    label: 'CX',
    sources: ['Intercom support chats', 'Zendesk escalation tickets', 'Email renewal thread', 'CSM handoff notes'],
    outcomes: ['Churn risk alerting', 'Renewal probability', 'Escalation detection', 'Root-cause themes', 'Suggested playbooks', 'Account risk timeline']
  },
  {
    id: 'product',
    label: 'Product',
    sources: ['Pendo feature usage', 'Mixpanel behavior cohorts', 'Jira linked requests', 'Community feedback'],
    outcomes: ['Feature demand ranking', 'Friction hotspot detection', 'Sentiment by feature', 'PM weekly brief', 'Roadmap evidence stream', 'Segment-level insights']
  },
  {
    id: 'leaders',
    label: 'Leaders',
    sources: ['Revenue system data', 'NPS/CSAT responses', 'Call themes summary', 'Support trend digest'],
    outcomes: ['Exec-level dashboard', 'Leading indicators', 'Segment health rollup', 'Org performance trends', 'Strategic risk radar', 'Weekly AI brief']
  }
];

const flow = [
  'Ingest',
  'Unify',
  'Transform',
  'Score',
  'Activate'
];
---

<Layout title="Tab UI Lab">
  <Navbar />
  <main class="lab-page">
    <section class="lab-hero">
      <h1>Tabbed Interface Lab</h1>
      <p>Choose a direction, and I will refine the selected one into production-quality UX.</p>
    </section>

    <section class="demo demo-a" data-tab-demo>
      <h2>Option A: Neon Pill Board</h2>
      <div class="tab-row">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="col">
            <h3>Signals</h3>
            {tab.sources.map((item) => <div class="card">{item}</div>)}
          </div>
          <div class="flow">
            {flow.map((step) => <div class="chip">{step}</div>)}
          </div>
          <div class="col">
            <h3>Outcomes</h3>
            {tab.outcomes.map((item) => <div class="card">{item}</div>)}
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-b" data-tab-demo>
      <h2>Option B: Underline Editorial</h2>
      <div class="tab-row">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="left">
            <h3>Source Apps</h3>
            <ul>{tab.sources.map((item) => <li>{item}</li>)}</ul>
          </div>
          <div class="center">
            <h3>Pipeline</h3>
            <ol>{flow.map((step) => <li>{step}</li>)}</ol>
          </div>
          <div class="right">
            <h3>Business Outputs</h3>
            <ul>{tab.outcomes.map((item) => <li>{item}</li>)}</ul>
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-c" data-tab-demo>
      <h2>Option C: Vertical Operator View</h2>
      <div class="shell">
        <div class="tab-col">
          {tabs.map((tab, i) => (
            <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
          ))}
        </div>
        <div class="content">
          {tabs.map((tab, i) => (
            <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
              <div class="stream">
                <h3>Incoming Data</h3>
                {tab.sources.map((item) => <p>{item}</p>)}
              </div>
              <div class="stream">
                <h3>AI Factory</h3>
                {flow.map((step) => <p>{step}</p>)}
              </div>
              <div class="stream">
                <h3>Delivered</h3>
                {tab.outcomes.map((item) => <p>{item}</p>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="demo demo-d" data-tab-demo>
      <h2>Option D: Glass Workflow Cards</h2>
      <div class="tab-row">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="glass card-col">
            <h3>Apps</h3>
            {tab.sources.map((item) => <div class="mini">{item}</div>)}
          </div>
          <div class="glass card-col center-col">
            <h3>Sausage Making</h3>
            {flow.map((step) => <div class="mini">{step}</div>)}
          </div>
          <div class="glass card-col">
            <h3>What Teams Get</h3>
            {tab.outcomes.map((item) => <div class="mini">{item}</div>)}
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-e" data-tab-demo>
      <h2>Option E: Compact Executive Dashboard</h2>
      <div class="tab-row">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="kpi-strip">
            <div class="kpi">Sources: {tab.sources.length}</div>
            <div class="kpi">Pipeline Stages: {flow.length}</div>
            <div class="kpi">Outcomes: {tab.outcomes.length}</div>
          </div>
          <div class="grid">
            <div>
              <h3>Data In</h3>
              {tab.sources.map((item) => <p>{item}</p>)}
            </div>
            <div>
              <h3>Engine</h3>
              {flow.map((step) => <p>{step}</p>)}
            </div>
            <div>
              <h3>Data Out</h3>
              {tab.outcomes.map((item) => <p>{item}</p>)}
            </div>
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-f" data-tab-demo>
      <h2>Option F: Editorial Split (Reference-Inspired)</h2>
      <div class="tab-row top-pills">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="variant rounded-variant">
            <div class="left-copy">
              <h3 class="eyebrow">Rounded corner variant</h3>
              <h4>Turn customer interactions into predictable outcomes</h4>
              <p>
                Unify signals from calls, support, CRM, and product activity in your own warehouse,
                then deliver team-specific intelligence with AI.
              </p>
              <div class="badge-row">
                {tab.sources.slice(0, 3).map((item) => <span>{item}</span>)}
              </div>
            </div>
            <div class="quote-card">
              <p>
                "{tab.label} teams now get faster signal-to-decision loops with AI summaries, timeline context,
                and clear next actions."
              </p>
            </div>
          </div>

          <div class="variant square-variant">
            <div class="left-copy">
              <h3 class="eyebrow">Square-ish corner variant</h3>
              <h4>From fragmented touchpoints to one decision layer</h4>
              <p>
                Keep data in your warehouse and run custom scoring, segmentation,
                and automation your teams can trust.
              </p>
              <div class="badge-row">
                {flow.map((step) => <span>{step}</span>)}
              </div>
            </div>
            <div class="quote-card">
              <p>
                "{tab.outcomes[0]} plus {tab.outcomes[1]} gives leaders a shared source of truth across GTM and product."
              </p>
            </div>
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-g" data-tab-demo>
      <h2>Option G: Insight Constellation</h2>
      <div class="tab-row top-pills">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="left-stack">
            {tab.sources.map((item, idx) => <div class={`quote q${idx % 4}`}>{item}</div>)}
          </div>
          <div class="signal-map">
            <div class="core">All Customer Signals</div>
            <div class="bubble b1">{tab.outcomes[0]}</div>
            <div class="bubble b2">{tab.outcomes[1]}</div>
            <div class="bubble b3">{tab.outcomes[2]}</div>
            <div class="bubble b4">{tab.outcomes[3]}</div>
          </div>
          <div class="brief">
            <h3>TL;DR</h3>
            <p>
              {tab.label} teams get high-confidence signals from unified sources and can prioritize action faster.
            </p>
            <ul>
              <li>{tab.outcomes[4]}</li>
              <li>{tab.outcomes[5]}</li>
              <li>{tab.outcomes[0]}</li>
            </ul>
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-h" data-tab-demo>
      <h2>Option H: Pipeline Storyboard</h2>
      <div class="tab-row top-pills">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="inputs">
            <h3>Inputs</h3>
            {tab.sources.map((item) => <div class="line-item">{item}</div>)}
          </div>
          <div class="pipeline-track">
            {flow.map((step, idx) => (
              <div class="track-step">
                <span>{step}</span>
                {idx < flow.length - 1 ? <em>→</em> : null}
              </div>
            ))}
            <div class="metrics">
              <div>Signal Coverage: 96%</div>
              <div>Decision Latency: -43%</div>
              <div>Automation Lift: +31%</div>
            </div>
          </div>
          <div class="outputs">
            <h3>Outputs</h3>
            {tab.outcomes.map((item) => <div class="line-item">{item}</div>)}
          </div>
        </div>
      ))}
    </section>

    <section class="demo demo-i" data-tab-demo>
      <h2>Option I: Signal Matrix + Briefing</h2>
      <div class="tab-row top-pills">
        {tabs.map((tab, i) => (
          <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.id}>{tab.label}</button>
        ))}
      </div>
      {tabs.map((tab, i) => (
        <div class={`panel ${i === 0 ? 'active' : ''}`} data-panel={tab.id}>
          <div class="left-stream">
            <h3>Fresh Inputs</h3>
            {tab.sources.map((item) => <p>{item}</p>)}
          </div>
          <div class="matrix">
            <h3>Signal Matrix</h3>
            <div class="rows">
              <div><span>Sentiment</span><strong>High impact</strong></div>
              <div><span>Intent</span><strong>Rising</strong></div>
              <div><span>Risk</span><strong>Stable</strong></div>
              <div><span>Opportunity</span><strong>Strong</strong></div>
            </div>
            <div class="tags">
              {tab.outcomes.slice(0, 5).map((item) => <span>{item}</span>)}
            </div>
          </div>
          <div class="briefing">
            <h3>Weekly Brief</h3>
            <p>
              Top shift for {tab.label}: {tab.outcomes[0].toLowerCase()} influenced by recent activity across
              {` ${tab.sources[0]}, ${tab.sources[1]}, and ${tab.sources[2]}.`}
            </p>
            <a href="#">Open detail view →</a>
          </div>
        </div>
      ))}
    </section>
  </main>
  <Footer />
</Layout>

<script>
  function initTabGroup(group) {
    const buttons = group.querySelectorAll('[data-tab]');
    const panels = group.querySelectorAll('[data-panel]');
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.getAttribute('data-tab');
        buttons.forEach((b) => b.classList.remove('active'));
        panels.forEach((p) => p.classList.remove('active'));
        button.classList.add('active');
        const panel = group.querySelector(`[data-panel="${target}"]`);
        if (panel) panel.classList.add('active');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-tab-demo]').forEach((group) => initTabGroup(group));
  });
</script>

<style>
  .lab-page {
    max-width: 1200px;
    margin: 4.8rem auto 2rem;
    padding: 0 1rem 2rem;
    display: grid;
    gap: 1.25rem;
  }
  .lab-hero h1 {
    margin: 0 0 0.4rem;
    font-size: clamp(2rem, 4vw, 2.8rem);
  }
  .lab-hero p {
    margin: 0;
    color: #b9b2f7;
  }
  .demo {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
  }
  .demo h2 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
  }
  .tab-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .tab-btn {
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #d8d1ff;
    padding: 0.5rem 0.85rem;
    border-radius: 0.6rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .tab-btn.active {
    color: #fff;
    border-color: #8b5cf6;
  }
  .panel {
    display: none;
    opacity: 0;
    transform: translateY(6px);
  }
  .panel.active {
    display: grid;
    opacity: 1;
    transform: translateY(0);
    animation: fadeIn 0.22s ease;
  }
  .col, .left, .center, .right, .stream, .card-col, .demo-e .grid > div {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.8rem;
    padding: 0.65rem;
    background: rgba(255, 255, 255, 0.02);
  }
  .card, .mini, .stream p, .demo-e p {
    margin: 0.4rem 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.55rem;
    padding: 0.45rem 0.5rem;
    background: rgba(255, 255, 255, 0.02);
    font-size: 0.87rem;
  }
  .demo-a .panel {
    grid-template-columns: 1fr 220px 1fr;
    gap: 0.75rem;
  }
  .demo-a .flow {
    border: 1px dashed rgba(139, 92, 246, 0.6);
    border-radius: 0.8rem;
    padding: 0.65rem;
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }
  .demo-a .chip {
    border-radius: 999px;
    background: rgba(139, 92, 246, 0.16);
    border: 1px solid rgba(139, 92, 246, 0.45);
    padding: 0.35rem 0.65rem;
    font-size: 0.8rem;
    text-align: center;
  }
  .demo-b .tab-btn {
    border-radius: 0;
    border: 0;
    border-bottom: 2px solid transparent;
    padding-inline: 0.25rem;
  }
  .demo-b .tab-btn.active {
    border-color: #8b5cf6;
    box-shadow: none;
  }
  .demo-b .panel {
    grid-template-columns: 1fr 220px 1fr;
    gap: 0.75rem;
  }
  .demo-b ul, .demo-b ol {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.35rem;
  }
  .demo-b li {
    color: #ddd7ff;
    font-size: 0.9rem;
  }
  .demo-c .shell {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 0.75rem;
  }
  .demo-c .tab-col {
    display: grid;
    gap: 0.45rem;
    align-content: start;
  }
  .demo-c .tab-col .tab-btn {
    text-align: left;
  }
  .demo-c .panel {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .demo-d .tab-btn.active {
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.35), rgba(76, 29, 149, 0.35));
  }
  .demo-d .panel {
    grid-template-columns: 1fr 240px 1fr;
    gap: 0.75rem;
  }
  .demo-d .glass {
    backdrop-filter: blur(6px);
    background: rgba(255, 255, 255, 0.045);
  }
  .demo-e .panel {
    gap: 0.75rem;
  }
  .demo-e .kpi-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
  }
  .demo-e .kpi {
    border: 1px solid rgba(139, 92, 246, 0.45);
    border-radius: 0.7rem;
    padding: 0.45rem 0.55rem;
    background: rgba(139, 92, 246, 0.12);
    font-size: 0.82rem;
    font-weight: 700;
  }
  .demo-e .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }
  .demo-f .panel {
    gap: 0.8rem;
  }
  .top-pills {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.7rem;
    padding: 0.35rem;
    width: fit-content;
    margin: 0 auto 0.75rem;
    justify-content: center;
  }
  .top-pills .tab-btn {
    border-radius: 0.5rem;
    border-color: transparent;
    padding: 0.55rem 1rem;
    color: #f0ebff;
  }
  .top-pills .tab-btn.active {
    background: rgba(139, 92, 246, 0.24);
    border: 1px solid transparent;
    color: #f4f2ff;
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.3);
  }
  .top-pills .tab-btn:hover {
    border-color: transparent;
    background: rgba(139, 92, 246, 0.08);
  }
  .demo-f .variant {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 0.9rem;
    background: rgba(255, 255, 255, 0.03);
    width: min(100%, 980px);
    margin: 0 auto;
  }
  .demo-f .rounded-variant {
    border-radius: 1.15rem;
  }
  .demo-f .square-variant {
    border-radius: 0.35rem;
  }
  .demo-f .left-copy h4 {
    margin: 0.35rem 0 0.45rem;
    font-size: clamp(1.25rem, 2.6vw, 2rem);
    line-height: 1.08;
    color: #f7f4ff;
    max-width: 28ch;
  }
  .demo-f .left-copy p {
    margin: 0 0 0.7rem;
    color: #c7bfff;
    max-width: 48ch;
    line-height: 1.45;
  }
  .demo-f .eyebrow {
    margin: 0;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #dbcfff;
  }
  .demo-f .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .demo-f .badge-row span {
    font-size: 0.8rem;
    padding: 0.38rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: #ece6ff;
  }
  .demo-f .rounded-variant .badge-row span {
    border-radius: 999px;
  }
  .demo-f .square-variant .badge-row span {
    border-radius: 0.3rem;
  }
  .demo-f .quote-card {
    padding: 0.95rem;
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.36);
    color: #efe9ff;
    font-size: clamp(1rem, 2vw, 1.45rem);
    line-height: 1.22;
    font-weight: 700;
    font-style: italic;
    display: flex;
    align-items: center;
  }
  .demo-f .rounded-variant .quote-card {
    border-radius: 0.9rem;
  }
  .demo-f .square-variant .quote-card {
    border-radius: 0.3rem;
  }
  .demo-g .panel,
  .demo-h .panel,
  .demo-i .panel {
    grid-template-columns: 1fr 1.1fr 0.9fr;
    gap: 0.8rem;
    width: min(100%, 980px);
    margin: 0 auto;
  }
  .demo-g .panel {
    min-height: min(68vh, 660px);
    align-items: stretch;
  }
  .demo-h .inputs,
  .demo-h .outputs,
  .demo-i .left-stream,
  .demo-i .briefing {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.03);
    border-radius: 0.65rem;
    padding: 0.7rem;
  }
  .demo-g .left-stack {
    padding: 0.25rem 0.15rem;
    display: grid;
    align-content: start;
    gap: 0.45rem;
  }
  .demo-g .quote {
    margin: 0;
    padding: 0.22rem 0.1rem 0.22rem 0.7rem;
    background: transparent;
    border: 0;
    border-left: 2px solid #8b5cf6;
    font-size: 0.89rem;
    color: #e2dcff;
    line-height: 1.4;
  }
  .demo-g .quote.q1 { border-left-color: #22d3ee; }
  .demo-g .quote.q2 { border-left-color: #f97316; }
  .demo-g .quote.q3 { border-left-color: #34d399; }
  .demo-g .signal-map {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.75rem;
    position: relative;
    min-height: 100%;
    background: radial-gradient(circle at center, rgba(139, 92, 246, 0.08), rgba(255, 255, 255, 0.01));
    overflow: hidden;
  }
  .demo-g .core {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
    font-size: 0.86rem;
    font-weight: 700;
  }
  .demo-g .bubble {
    position: absolute;
    width: 150px;
