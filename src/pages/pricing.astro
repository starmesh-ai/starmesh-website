---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/nav/Navbar.astro';
import CTASection from '../components/sections/CTASection.astro';
import Footer from '../components/ui/Footer.astro';

const enterprise = [
  { text: 'Unlimited call & email ingestion' },
  { text: 'All AI signals — PWin, EWI, Deal Health, Churn Risk' },
  { text: 'CRM write-back to Salesforce & HubSpot' },
  { text: 'Custom warehouse destinations — BigQuery, Snowflake, Redshift' },
  { text: 'Role-based access & SSO' },
  { text: 'Dedicated onboarding & customer success manager' },
  { text: 'Audit logging & compliance controls' },
  { text: 'SLA-backed support with named contacts' },
];
---
<BaseLayout
  title="Pricing — Starmesh"
  description="Simple, transparent pricing for conversation intelligence. Built for revenue and data teams."
>
  <Navbar />
  <main class="pt-16">
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-xs text-[#71717A] uppercase tracking-widest mb-3">Pricing</p>
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
            Built for <span class="gradient-text">enterprise teams</span>
          </h1>
          <p class="text-[#A1A1AA] text-lg max-w-xl mx-auto">Starmesh deploys alongside your existing data stack. Pricing is usage-based — we'll give you a number after understanding your use case.</p>
        </div>

        <div class="max-w-2xl mx-auto">
          <div class="rounded-2xl overflow-hidden" style="border:1px solid rgba(139,92,246,.35); background:#0a0a0d; box-shadow:0 0 80px rgba(99,102,241,.1), inset 0 1px 0 rgba(255,255,255,.04);">

            <div class="px-8 py-8 border-b border-white/[0.06]">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs text-[#818CF8] uppercase tracking-widest font-bold mb-3">Enterprise</p>
                  <div class="flex items-baseline gap-2 mb-2">
                    <span class="text-5xl font-bold text-[#FAFAFA] tracking-tight">Custom</span>
                  </div>
                  <p class="text-[#71717A] text-sm">Usage-based pricing · scales with your data volume</p>
                </div>
                <span class="flex-shrink-0 text-xs px-2.5 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 font-semibold mt-1">Available now</span>
              </div>
            </div>

            <div class="px-8 py-8">
              <p class="text-xs text-[#52525B] uppercase tracking-widest font-semibold mb-6">What's included</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {enterprise.map(f => (
                  <li class="flex items-start gap-3">
                    <span class="text-[#6366F1] flex-shrink-0 mt-1">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    <span class="text-sm text-[#A1A1AA] leading-snug">{f.text}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="px-8 py-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center gap-4" style="background:rgba(255,255,255,.01);">
              <a
                href="mailto:abhinav@starmesh.ai"
                class="w-full sm:w-auto flex-shrink-0 text-center font-semibold text-sm px-8 py-3 rounded-xl transition-all"
                style="background:linear-gradient(135deg,#6366F1,#8B5CF6); color:white; box-shadow:0 4px 20px rgba(99,102,241,.35);"
              >
                Talk to sales
              </a>
              <p class="text-[#52525B] text-sm text-center sm:text-left">No commitment required — we'll walk you through a live demo first.</p>
            </div>

          </div>
        </div>
      </div>
    </section>
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
