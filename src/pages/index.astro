---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/nav/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import OverviewSection from '../components/sections/OverviewSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import ProblemSection from '../components/sections/ProblemSection.astro';
// import HowItWorks from '../components/sections/HowItWorks.astro';
import UseCases from '../components/sections/UseCases.astro';
import Features from '../components/sections/Features.astro';
import WhyChoose from '../components/sections/WhyChoose.astro';
import CTASection from '../components/sections/CTASection.astro';
import Footer from '../components/ui/Footer.astro';
---
<BaseLayout
  title="Starmesh | Turn Customer Interactions into Actionable Signals"
  description="Starmesh connects to your calls, emails, and meetings — then extracts topics, intent, and sentiment — and delivers clean, queryable data directly to your warehouse."
>
  <Navbar />
  <main>
    <Hero />
    <OverviewSection />
    <Testimonials />
    <ProblemSection />
    <WhyChoose />
    {/*
    <HowItWorks />
    */}
    <UseCases />
    <Features />
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
